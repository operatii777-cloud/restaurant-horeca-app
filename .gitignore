
# Exclude node_modules and lock files
node_modules/
package-lock.json

# Exclude build artifacts
dist/
build/
.vite/

# Exclude local environment overrides (but keep .env for development)
.env.local
.env.production

# Exclude backup folders
restaurant_app_backup_*/
tipizate_fixed_backup_*/

# Exclude project backup and build folders
restaurant_app_v3_translation_system/backups/
restaurant_app_v3_translation_system/server/backups/
restaurant_app_v3_translation_system/courier-flutter-app/build/
restaurant_app_v3_translation_system/courier-flutter-app/.dart_tool/

# Exclude large investigation and report files
restaurant_app_v3_translation_system/server/admin-vite/errorboundary-investigation.json
restaurant_app_v3_translation_system/server/backups/bkp-10dec/DEV-REPORTS/backend-route-audit.json

# Exclude logs and reports
*.log
*.csv
*.txt

# Exclude scripts and analysis (but allow setup scripts and documentation)
*.ps1
*.py

# Allow important setup scripts and documentation
!setup.sh
!setup.bat
!README.md
!QUICKSTART.md
!CONTRIBUTING.md

# Exclude dev and test files
*.test.*
*.spec.*

# Exclude .vscode and other editor configs
.vscode/

# Exclude database and temp files
*.db

# Exclude other non-essential files
hs_err_*.log
replay_*.log
