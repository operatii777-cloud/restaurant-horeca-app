{
  "name": "restaurant-app-server",
  "version": "3.0.0",
  "description": "Restaurant Management System - Backend Server",
  "main": "server.js",
  "scripts": {
    "backup:full": "node scripts/backup-full-app.js",
    "start": "node server.js",
    "start:prod": "node server.js",
    "build:frontend": "cd admin-vite && npm run build",
    "build:all": "npm run build:frontend && npm run start:prod",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:playwright": "npx playwright test",
    "test:puppeteer": "node tests/puppeteer-critical-tests.js",
    "test:s8": "jest tests/s8-final.test.js",
    "audit:s8": "node scripts/s8-final-audit.js",
    "fix:s8": "node scripts/s8-fix-imports.js",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "compile:ts": "node scripts/compile-typescript.js",
    "build:ts": "tsc",
    "doctor": "node doctor.js",
    "doctor:fix": "node doctor.js --fix",
    "doctor:lint": "node doctor.js --check=linting --fix",
    "doctor:api": "node doctor.js --check=endpoints",
    "doctor:db": "node doctor.js --check=database",
    "production:check": "node production-readiness.js",
    "validate:production-files": "node .production-files-validator.js",
    "test:contracts": "jest tests/contracts/",
    "test:smoke": "npx playwright test tests/smoke/",
    "test:all": "npm run test:contracts && npm run test:smoke",
    "impact:analyze": "node src/contracts/impact-analysis-helper.js",
    "benchmark": "node tests/benchmark/horeca-benchmark.js",
    "benchmark:full": "node tests/benchmark/horeca-benchmark.js http://localhost:3001"
  },
  "keywords": [
    "restaurant",
    "pos",
    "management"
  ],
  "author": "Restaurant App Team",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@apollo/server": "^4.12.2",
    "argon2": "~0.44.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.6.2",
    "body-parser": "~1.20.2",
    "compression": "~1.8.1",
    "cors": "~2.8.5",
    "dotenv": "~16.0.3",
    "exceljs": "~4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "~7.4.0",
    "express-validator": "~7.3.1",
    "fuse.js": "^7.1.0",
    "graphql": "^16.12.0",
    "graphql-tag": "^2.12.6",
    "handlebars": "~4.7.8",
    "helmet": "~7.1.0",
    "jsonwebtoken": "~9.0.2",
    "morgan": "~1.10.1",
    "multer": "~1.4.5-lts.1",
    "node-cron": "~4.2.1",
    "nodemailer": "~7.0.11",
    "pdfkit": "~0.13.0",
    "qr-image": "~3.2.0",
    "qrcode": "~1.5.3",
    "serialport": "~13.0.0",
    "sharp": "~0.34.5",
    "socket.io": "^4.8.3",
    "sqlite3": "~5.1.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "~3.18.3",
    "winston-daily-rotate-file": "~5.0.0",
    "xlsx": "~0.18.5",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "@playwright/test": "~1.57.0",
    "@types/express": "^5.0.6",
    "@types/jest": "~29.5.0",
    "@types/node": "^25.0.2",
    "@types/supertest": "~6.0.3",
    "chalk": "^4.1.2",
    "glob": "^13.0.0",
    "jest": "~29.7.0",
    "nodemon": "~3.0.1",
    "puppeteer": "^24.34.0",
    "socket.io-client": "^4.8.1",
    "supertest": "~7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
