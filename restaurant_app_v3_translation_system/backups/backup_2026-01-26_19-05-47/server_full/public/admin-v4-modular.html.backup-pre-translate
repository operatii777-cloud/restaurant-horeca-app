        // ==================== LANGUAGE SWITCH ====================
        function switchLanguage(lang) {
            currentLang = lang;
            localStorage.setItem('selectedLanguage', lang); // ✅ IMPORTANT: Salvează în localStorage pentru sincronizare
            localStorage.setItem('language', lang); // Păstrează și pentru compatibilitate
            
            // Update button states
            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.lang === lang);
            });

            // Update translations
            updateTranslations();
            
            // Notify iframe if loaded
            const iframe = document.getElementById('module-iframe');
            if (iframe.src !== 'about:blank') {
                try {
                    iframe.contentWindow.postMessage({ type: 'languageChange', lang }, '*');
                } catch (e) {
                    console.log('Could not send message to iframe:', e);
                }
            }
        }

        function updateTranslations() {
            const t = translations[currentLang];
            
            // Update header
            document.getElementById('app-title').textContent = t.appTitle;
            document.getElementById('logout-text').textContent = t.logout;
            
            // Update welcome screen
            const welcomeTitle = document.getElementById('welcome-title');
            const welcomeSubtitle = document.getElementById('welcome-subtitle');
            if (welcomeTitle) welcomeTitle.textContent = t.welcomeTitle;
            if (welcomeSubtitle) welcomeSubtitle.textContent = t.welcomeSubtitle;
        }

        // ==================== MAIN TAB SWITCHING ====================
        function switchMainTab(tabName) {
            currentMainTab = tabName;
            
            // 💾 PERSISTENȚĂ: Salvează ultimul main tab vizitat
            localStorage.setItem('adminV4_lastMainTab', tabName);
            
            // Update tab states
            document.querySelectorAll('.main-tab').forEach(tab => {
                tab.classList.toggle('active', tab.dataset.tab === tabName);
            });

            // Hide all submenus
            document.querySelectorAll('.submenu-bar').forEach(submenu => {
                submenu.classList.remove('active');
            });

            // Hide all content panels
            document.querySelectorAll('.content-panel').forEach(panel => {
                panel.classList.remove('active');
            });

            // Show corresponding submenu (if not welcome)
            if (tabName !== 'welcome') {
                const submenu = document.getElementById(`submenu-${tabName}`);
                if (submenu) {
                    submenu.classList.add('active');
