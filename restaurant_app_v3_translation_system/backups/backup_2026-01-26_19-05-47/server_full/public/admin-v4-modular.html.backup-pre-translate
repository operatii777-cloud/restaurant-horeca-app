        // FIX: Debounce mechanism to prevent rapid clicks
        let isLoadingModule = false;
        let loadTimeout = null;

        // ==================== LAZY LOADING + INSTANT MODULE SWITCHING ====================
        function loadModule(moduleName, moduleUrl) {
            // FIX: Prevent double-clicks
            if (isLoadingModule) {
                console.log('⚠️ Module loading in progress, please wait...');
                return;
            }
            
            const startTime = performance.now();
            currentModule = moduleName;
            isLoadingModule = true;
            
            // 💾 PERSISTENȚĂ: Salvează ultimul modul vizitat
            localStorage.setItem('adminV4_lastModule', moduleName);
            
            // Show module container
            document.getElementById('content-welcome').classList.remove('active');
            document.getElementById('module-container').classList.add('active');
            
            // Update submenu button states
            document.querySelectorAll('.submenu-btn').forEach(btn => {
                btn.classList.remove('active', 'loading');
            });
            if (event && event.target) {
                const btn = event.target.closest('.submenu-btn');
                if (btn) {
                    btn.classList.add('active', 'loading');
                }
            }
            
            // LAZY LOADING + INSTANT SWITCH
            const targetIframeId = moduleIframeMap[moduleName];
            
            if (targetIframeId) {
                // Hide ALL iframes
                document.querySelectorAll('.module-iframe').forEach(iframe => {
                    iframe.classList.add('hidden');
                });
                
                const targetIframe = document.getElementById(targetIframeId);
                if (targetIframe) {
                    // ✅ LAZY LOAD: Load iframe only on first access
                    // FORCE RELOAD if src is wrong
                    const expectedSrc = targetIframe.dataset.src;
                    if (!targetIframe.src || targetIframe.src.indexOf(expectedSrc) === -1) {
                        const iframeSrc = targetIframe.dataset.src;
                        const sectionName = targetIframe.dataset.section; // For admin.html (showSection)
                        const tabName = targetIframe.dataset.tab; // For admin-advanced.html (Bootstrap tabs)
                        
                        console.log(`⚡ Lazy loading module: ${moduleName}`);
                        console.log(`📍 Iframe src: ${iframeSrc}`);
                        if (sectionName) {
                            console.log(`📌 Will show section: ${sectionName} (admin.html)`);
                        }
                        if (tabName) {
                            console.log(`📌 Will activate tab: ${tabName} (admin-advanced.html)`);
                        }
                        
                        // FIX: Show loading overlay IMMEDIATELY
                        const overlay = document.getElementById('loading-overlay');
                        overlay.classList.remove('hidden');
                        overlay.style.display = 'flex'; // Force visibility
                        
                        // FIX: Update loading text based on language
                        const loadingText = overlay.querySelector('.loading-text');
                        if (loadingText) {
                            loadingText.textContent = currentLang === 'ro' ? 
                                'Se încarcă modulul...' : 
                                'Loading module...';
                        }
                        
                        // DEBUG: Log before setting src
                        console.log(`⏳ Setting iframe src...`);
                        targetIframe.src = iframeSrc;
                        console.log(`✓ Iframe src set`);
                        
                        // Hide loading when iframe loads + timeout fallback
                        targetIframe.onload = function() {
                            console.log(`🎯 Iframe onload triggered for ${moduleName}`);
                            
                            // Check if this is a React module (no data-section attribute)
                            const isReactModule = !sectionName && iframeSrc.includes('/react-modules/');
                            
                            if (isReactModule) {
                                console.log(`✅ React module detected - no function waiting needed`);
                                // React modules don't need showSection/showStockSubsection
                                // They expose their own functions (e.g., showAlergeniForm)
                                // Just hide loading and we're done
                                setTimeout(() => {
                                    const overlay = document.getElementById('loading-overlay');
                                    if (overlay) {
                                        overlay.classList.add('hidden');
                                        console.log('✅ Loading overlay hidden for React module');
                                    }
                                }, 200);
                                return; // Skip waitForFunctions for React modules
                            }
                            
                            // NEW: Wait for functions to be available in admin.html
                            function waitForFunctions(callback, maxAttempts = 20, interval = 200) {
                                let attempts = 0;
                                const checkInterval = setInterval(() => {
                                    attempts++;
                                    if (targetIframe.contentWindow.showSection && targetIframe.contentWindow.showStockSubsection) {
                                        clearInterval(checkInterval);
                                        console.log(`✅ Functions available after ${attempts * interval}ms`);
                                        callback();
                                    } else if (attempts >= maxAttempts) {
                                        clearInterval(checkInterval);
                                        console.error(`❌ Timeout waiting for functions after ${maxAttempts * interval}ms`);
                                    }
                                }, interval);
                            }
                            
                            // Wait for functions, then activate sections (only for admin.html)
                            waitForFunctions(() => {
                                try {
                                    // Option 1: admin.html with showSection()
                                    if (sectionName) {
                                        console.log(`🎯 Showing section: ${sectionName}`);
                                        targetIframe.contentWindow.showSection(sectionName);
                                        console.log(`✅ Section ${sectionName} activated`);
                                        
                                        // NEW: Activate specific subsection if data-subsection is present
                                        const subsectionName = targetIframe.dataset.subsection;
                                        if (subsectionName) {
                                            console.log(`📌 Subsection requested: ${subsectionName}`);
                                            setTimeout(() => {
                                                try {
                                                    if (targetIframe.contentWindow.showStockSubsection) {
                                                        console.log(`🎯 Calling showStockSubsection('${subsectionName}')`);
                                                        targetIframe.contentWindow.showStockSubsection(subsectionName, null);
                                                        console.log(`✅ Subsection ${subsectionName} activated successfully`);
                                                        
                                                        // NEW: Handle data-action (e.g., openFTP for Fișe Tehnice)
                                                        const actionName = targetIframe.dataset.action;
                                                        if (actionName === 'openFTP') {
                                                            console.log(`🎯 Action requested: ${actionName}`);
                                                            setTimeout(() => {
                                                                try {
                                                                    if (targetIframe.contentWindow.showRecipeFTPModal) {
                                                                        console.log(`🎯 Opening FTP Modal...`);
                                                                        targetIframe.contentWindow.showRecipeFTPModal();
                                                                        console.log(`✅ FTP Modal opened successfully`);
                                                                    } else {
                                                                        console.error(`❌ showRecipeFTPModal function not found in iframe`);
                                                                    }
                                                                } catch (actionError) {
                                                                    console.error(`❌ Error executing action:`, actionError);
                                                                }
                                                            }, 500); // Wait for subsection to load
                                                        }
                                                    } else {
                                                        console.error(`❌ showStockSubsection function not found in iframe`);
                                                    }
                                                } catch (subsectionError) {
                                                    console.error(`❌ Error activating subsection:`, subsectionError);
                                                }
                                            }, 500); // Wait for section to activate
                                        }
                                    }
                                    // Option 2: admin-advanced.html with Bootstrap tabs
                                    else if (tabName) {
                                        console.log(`🎯 Activating Bootstrap tab: ${tabName}`);
                                        // Try multiple selectors for Bootstrap tabs (pills use href, tabs use data-bs-target)
                                        const tabEl = targetIframe.contentDocument.querySelector(`a[href="#${tabName}"]`) ||
                                                     targetIframe.contentDocument.querySelector(`[data-bs-target="#${tabName}"]`);
                                        if (tabEl) {
                                            console.log(`✅ Found tab element for: ${tabName}`);
                                            // Use Bootstrap Tab API (for pills)
                                            const bootstrap = targetIframe.contentWindow.bootstrap;
                                            if (bootstrap && bootstrap.Tab) {
                                                try {
                                                    const tab = new bootstrap.Tab(tabEl);
                                                    tab.show();
                                                    console.log(`✅ Tab ${tabName} activated via Bootstrap API`);
                                                } catch (tabError) {
                                                    console.warn(`⚠️ Bootstrap Tab API failed, using click fallback`);
                                                    tabEl.click();
                                                    console.log(`✅ Tab ${tabName} activated via click`);
                                                }
                                            } else {
                                                // Fallback: direct click
                                                console.log(`⚠️ Bootstrap not available, using click`);
                                                tabEl.click();
                                                console.log(`✅ Tab ${tabName} activated via click`);
                                            }
                                            
                                            // NEW: Scroll to specific element if data-scroll-to is present
                                            const scrollToId = targetIframe.dataset.scrollTo;
                                            if (scrollToId) {
                                                console.log(`📜 Scroll requested to: #${scrollToId}`);
                                                setTimeout(() => {
                                                    try {
                                                        const scrollTarget = targetIframe.contentDocument.getElementById(scrollToId);
                                                        if (scrollTarget) {
                                                            scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
                                                            console.log(`✅ Scrolled to #${scrollToId}`);
                                                        } else {
                                                            console.warn(`⚠️ Scroll target not found: #${scrollToId}`);
                                                        }
                                                    } catch (scrollError) {
                                                        console.error(`❌ Error scrolling: ${scrollError.message}`);
                                                    }
                                                }, 300); // Wait for tab transition
                                            }
                                        } else {
                                            console.warn(`⚠️ Tab element not found for: ${tabName}`);
                                            console.log(`Tried selectors: a[href="#${tabName}"], [data-bs-target="#${tabName}"]`);
                                        }
                                    }
                                    else {
                                        console.warn(`⚠️ No section or tab configured for: ${moduleName}`);
                                    }
                                } catch (e) {
                                    console.error(`❌ Error activating section/tab: ${e.message}`);
                                }
                            }); // End of waitForFunctions callback
                            
                            setTimeout(() => {
                                overlay.classList.add('hidden');
                                overlay.style.display = ''; // Reset
                            const loadTime = (performance.now() - startTime).toFixed(2);
                            console.log(`✅ Module ${moduleName} loaded in ${loadTime}ms`);
                                
                                // FIX: Remove loading state from button
                                document.querySelectorAll('.submenu-btn.loading').forEach(btn => {
                                    btn.classList.remove('loading');
                                });
                                
                                // FIX: Allow new loads after 300ms
                                setTimeout(() => { isLoadingModule = false; }, 300);
                            }, 100); // Small delay to ensure content is rendered
                        };
                        
                        // ERROR HANDLER
                        targetIframe.onerror = function() {
                            console.error(`❌ Iframe error for ${moduleName}`);
                            overlay.classList.add('hidden');
                            isLoadingModule = false;
                            alert(`Eroare la încărcarea modulului: ${moduleName}`);
                        };
                        
                        // FIX: Timeout fallback (max 5s pentru debugging)
                        clearTimeout(loadTimeout);
                        loadTimeout = setTimeout(() => {
                            console.warn(`⚠️ Module ${moduleName} load timeout after 5s`);
                            console.warn(`📍 Iframe src was: ${iframeSrc}`);
                            console.warn(`📊 Iframe readyState: ${targetIframe.contentDocument?.readyState || 'unknown'}`);
                            overlay.classList.add('hidden');
                            isLoadingModule = false;
                        }, 5000); // REDUCED from 10s to 5s for debugging
                    } else {
                        // Already loaded, instant switch
                        const sectionName = targetIframe.dataset.section;
                        const tabName = targetIframe.dataset.tab;
                        const subsectionName = targetIframe.dataset.subsection;
                        const scrollToId = targetIframe.dataset.scrollTo;
                        
                        // Show specific section OR tab
                        try {
                            if (sectionName) {
                                console.log(`🎯 Switching to already loaded section: ${sectionName}`);
                                if (targetIframe.contentWindow && targetIframe.contentWindow.showSection) {
                                    targetIframe.contentWindow.showSection(sectionName);
                                    console.log(`✅ Section ${sectionName} activated instantly`);
                                    
                                    // FIX: Activate subsection if specified (for already loaded iframes)
                                    if (subsectionName) {
                                        console.log(`📌 Subsection requested: ${subsectionName}`);
                                        setTimeout(() => {
                                            try {
                                                if (targetIframe.contentWindow.showStockSubsection) {
                                                    console.log(`🎯 Calling showStockSubsection('${subsectionName}')`);
                                                    targetIframe.contentWindow.showStockSubsection(subsectionName, null);
                                                    console.log(`✅ Subsection ${subsectionName} activated successfully`);
                                                } else {
                                                    console.error(`❌ showStockSubsection function not found in iframe`);
                                                }
                                            } catch (subsectionError) {
                                                console.error(`❌ Error activating subsection:`, subsectionError);
                                            }
                                        }, 500); // Delay to ensure section is fully visible
                                    }
                                }
                            } else if (tabName) {
                                console.log(`🎯 Switching to already loaded tab: ${tabName}`);
                                const tabEl = targetIframe.contentDocument.querySelector(`a[href="#${tabName}"]`) ||
                                             targetIframe.contentDocument.querySelector(`[data-bs-target="#${tabName}"]`);
                                if (tabEl) {
                                    const bootstrap = targetIframe.contentWindow.bootstrap;
                                    if (bootstrap && bootstrap.Tab) {
                                        const tab = new bootstrap.Tab(tabEl);
                                        tab.show();
                                    } else {
                                        tabEl.click();
                                    }
                                    console.log(`✅ Tab ${tabName} activated instantly`);
                                    
                                    // FIX: Scroll to specific element if specified (for already loaded iframes)
                                    if (scrollToId) {
                                        console.log(`📜 Scroll requested to: #${scrollToId}`);
                                        setTimeout(() => {
                                            try {
                                                const scrollTarget = targetIframe.contentDocument.getElementById(scrollToId);
                                                if (scrollTarget) {
                                                    scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
                                                    console.log(`✅ Scrolled to #${scrollToId}`);
                                                } else {
                                                    console.error(`❌ Scroll target #${scrollToId} not found`);
                                                }
                                            } catch (scrollError) {
                                                console.error(`❌ Error scrolling:`, scrollError);
                                            }
                                        }, 300);
                                    }
                                }
                            }
                        } catch (e) {
                            console.error(`❌ Error switching section/tab: ${e.message}`);
                        }
                        
                        isLoadingModule = false;
                        document.querySelectorAll('.submenu-btn.loading').forEach(btn => {
                            btn.classList.remove('loading');
                        });
                    }
                    
                    // Show target iframe INSTANTLY
                    targetIframe.classList.remove('hidden');
                    
                    // Notify iframe about language if loaded
                    if (targetIframe.src) {
                        // FIX: Delay message to ensure iframe is ready
                        setTimeout(() => {
                        try {
                            targetIframe.contentWindow.postMessage({ 
                                type: 'languageChange', 
                                lang: currentLang 
                            }, '*');
                        } catch (e) {
                            // Iframe not ready yet, will auto-sync on load
                        }
                        }, 200);
                    }
                    
                    const switchTime = (performance.now() - startTime).toFixed(2);
                    if (targetIframe.src && switchTime < 100) {
                        console.log(`⚡ INSTANT switch to ${moduleName}: ${switchTime}ms`);
                    }
                }
            } else {
                console.warn('No iframe mapped for:', moduleName);
                isLoadingModule = false;
            }
        }

        // ==================== LOGOUT ====================
        function logout() {
            window.location.href = '/';
        }

        // FIX: Preload critical modules for faster access
        function preloadCriticalModules() {
            // TEMPORARY DISABLED - Debugging latency issues
            console.log('⚠️ Preloading DISABLED for debugging');
            return;
            
            const criticalModules = [
                'iframe-catalog-produse',
                'iframe-nir',
                'iframe-rapoarte'
            ];
            
            // Preload after 2 seconds (user has time to see welcome screen)
            setTimeout(() => {
                console.log('🚀 Preloading critical modules...');
                criticalModules.forEach(iframeId => {
                    const iframe = document.getElementById(iframeId);
                    if (iframe && !iframe.src && iframe.dataset.src) {
                        // Silent preload (no loading overlay)
                        iframe.src = iframe.dataset.src;
                        console.log(`✅ Preloaded: ${iframeId}`);
                    }
                });
            }, 2000);
        }

        // ==================== INITIALIZATION ====================
        document.addEventListener('DOMContentLoaded', () => {
            console.log('🚀 Admin v4.0 Modular initialized');
            updateTranslations();
            
            // FIX: Start preloading critical modules
            preloadCriticalModules();
        });

        // ==================== IFRAME MESSAGE HANDLING ====================
        window.addEventListener('message', (event) => {
            // Handle messages from iframes if needed
            if (event.data.type === 'ready') {
                console.log('Module ready:', event.data.module);
            }
            
            // FIX: Handle authentication complete message from admin.html iframe
            if (event.data.type === 'adminAuthenticationComplete') {
                console.log('🔔 Received authentication complete notification');
                
                // Find which iframe sent the message
                const iframes = document.querySelectorAll('.module-iframe');
                let sourceIframe = null;
                
                for (const iframe of iframes) {
                    try {
                        if (iframe.contentWindow === event.source) {
                            sourceIframe = iframe;
                            break;
                        }
                    } catch (e) {
                        // Cross-origin iframe, skip
                    }
                }
                
                if (sourceIframe) {
                    console.log('🎯 Found source iframe:', sourceIframe.id);
                    
                    // Check if this iframe has a section to activate
                    const sectionName = sourceIframe.dataset.section;
                    const subsectionName = sourceIframe.dataset.subsection;
                    const actionName = sourceIframe.dataset.action;
                    
                    if (sectionName) {
                        console.log('📌 Activating section after auth:', sectionName);
                        console.log('   sourceIframe:', sourceIframe);
                        console.log('   sourceIframe.id:', sourceIframe?.id);
                        
                        // FIX: Capture iframe reference in closure to prevent loss
                        const targetIframe = sourceIframe;
                        console.log('   targetIframe set:', !!targetIframe);
                        
                        const iframeId = targetIframe.id;
                        console.log('   iframeId:', iframeId);
                        
                        console.log('⏱️ Setting timeout for section activation (800ms)...');
                        
                        // Wait a bit for the iframe to fully rendered
                        setTimeout(() => {
                            console.log('⏰ TIMEOUT FIRED! iframe id:', iframeId);
                            console.log('⏰ Timer expired, checking iframe state...');
                            console.log('  contentWindow exists:', !!targetIframe.contentWindow);
                            console.log('  showSection exists:', !!targetIframe.contentWindow?.showSection);
                            
                            try {
                                if (targetIframe.contentWindow && targetIframe.contentWindow.showSection) {
                                    console.log('🎯 Calling showSection("' + sectionName + '")...');
                                    targetIframe.contentWindow.showSection(sectionName);
                                    console.log('✅ Section activated:', sectionName);
                                    
                                    // If there's a subsection, activate it too
                                    if (subsectionName) {
                                        console.log('📌 Activating subsection after auth:', subsectionName);
                                        setTimeout(() => {
                                            console.log('⏰ Subsection timer expired...');
                                            console.log('  showStockSubsection exists:', !!targetIframe.contentWindow?.showStockSubsection);
                                            
                                            try {
                                                if (targetIframe.contentWindow.showStockSubsection) {
                                                    console.log('🎯 Calling showStockSubsection("' + subsectionName + '")...');
                                                    targetIframe.contentWindow.showStockSubsection(subsectionName, null);
                                                    console.log('✅ Subsection activated:', subsectionName);
                                                    
                                                    // FIX: Manually activate the button since we passed null for event
                                                    const iframeDoc = targetIframe.contentDocument || targetIframe.contentWindow.document;
                                                    const buttons = iframeDoc.querySelectorAll('.stock-nav-btn');
                                                    console.log('  Found', buttons.length, 'stock navigation buttons');
                                                    for (const btn of buttons) {
                                                        if (btn.textContent.toLowerCase().includes(subsectionName.toLowerCase()) ||
                                                            btn.textContent.toLowerCase().includes('recipes') ||
                                                            btn.textContent.toLowerCase().includes('rețete')) {
                                                            btn.classList.add('active');
                                                            console.log('✅ Button marked as active:', btn.textContent.trim());
                                                            break;
                                                        }
                                                    }
                                                } else {
                                                    console.error('❌ showStockSubsection not found in iframe');
                                                }
                                            } catch (subsectionError) {
                                                console.error('❌ Error activating subsection:', subsectionError);
                                                console.error('   Error details:', subsectionError.message, subsectionError.stack);
                                            }
                                        }, 500); // Wait for section to be fully visible
                                    }
                                } else {
                                    console.error('❌ showSection not found in iframe');
                                    if (!targetIframe.contentWindow) {
                                        console.error('   contentWindow is null or undefined');
                                    } else {
                                        console.error('   contentWindow exists but showSection is missing');
                                        console.error('   Available functions:', Object.keys(targetIframe.contentWindow).filter(k => typeof targetIframe.contentWindow[k] === 'function').slice(0, 20).join(', '));
                                    }
                                }
                            } catch (sectionError) {
                                console.error('❌ Error activating section:', sectionError);
                                console.error('   Error details:', sectionError.message, sectionError.stack);
                            }
                        }, 800); // Increased wait time to 800ms for admin panel to be fully rendered
                    } else if (actionName) {
                        // FIX: Handle custom actions (like toggleMessagesModal)
                        console.log('📌 Executing action after auth:', actionName);
                        
                        const targetIframe = sourceIframe;
                        const iframeId = targetIframe.id;
                        
                        console.log('⏱️ Setting timeout for action execution (800ms)...');
                        
                        setTimeout(() => {
                            console.log('⏰ ACTION TIMEOUT FIRED! iframe id:', iframeId);
                            console.log('⏰ Executing action:', actionName);
                            
                            try {
                                if (targetIframe.contentWindow && targetIframe.contentWindow[actionName]) {
                                    console.log('🎯 Calling ' + actionName + '()...');
                                    targetIframe.contentWindow[actionName]();
                                    console.log('✅ Action executed:', actionName);
                                } else {
                                    console.error('❌ Action function not found:', actionName);
                                    if (!targetIframe.contentWindow) {
                                        console.error('   contentWindow is null or undefined');
                                    } else {
                                        console.error('   Function "' + actionName + '" does not exist');
                                    }
                                }
                            } catch (actionError) {
                                console.error('❌ Error executing action:', actionError);
                                console.error('   Error details:', actionError.message, actionError.stack);
                            }
                        }, 800);
                    }
                } else {
                    console.warn('⚠️ Could not find source iframe');
                }
            }
        });
        
        // ============================================================
        // 💾 TAB PERSISTENCE: Restore last visited tab/module on page load
        // ============================================================
        (function() {
            console.log('💾 Inițializare Tab Persistence pentru admin-v4-modular.html');
            
            // Așteaptă ca DOM-ul să fie complet încărcat
            window.addEventListener('load', function() {
                setTimeout(function() {
                    const lastMainTab = localStorage.getItem('adminV4_lastMainTab');
                    const lastModule = localStorage.getItem('adminV4_lastModule');
                    
                    console.log('💾 Restaurare stare salvată:');
                    console.log('   - Main Tab:', lastMainTab || 'none');
                    console.log('   - Module:', lastModule || 'none');
                    
                    // Restaurează main tab-ul
                    if (lastMainTab && lastMainTab !== 'welcome') {
                        console.log('🔄 Restaurare main tab:', lastMainTab);
                        switchMainTab(lastMainTab);
                        
                        // Așteaptă un pic și apoi restaurează modulul
                        if (lastModule) {
                            setTimeout(function() {
                                console.log('🔄 Restaurare modul:', lastModule);
                                
                                // Găsește butonul corespunzător modulului
                                const moduleButtons = document.querySelectorAll('.submenu-btn');
                                let targetButton = null;
                                
                                moduleButtons.forEach(function(btn) {
                                    const onclickAttr = btn.getAttribute('onclick');
                                    if (onclickAttr && onclickAttr.includes(`'${lastModule}'`)) {
                                        targetButton = btn;
                                    }
                                });
                                
                                if (targetButton) {
                                    // Simulează click pe buton
                                    targetButton.click();
                                    console.log('✅ Modul restaurat cu succes:', lastModule);
                                } else {
                                    console.log('⚠️  Buton pentru modulul', lastModule, 'nu a fost găsit');
                                }
                            }, 300);
                        }
                    } else {
                        console.log('ℹ️  Nu există stare salvată, se afișează Welcome screen');
                    }
                }, 500); // Așteaptă 500ms ca totul să se încarce
            });
            
            console.log('✅ Tab Persistence inițializat pentru admin-v4-modular.html');
        })();
        
