<!DOCTYPE html>
<html lang="{{metadata.lang}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{menu_title}} - {{restaurant.name}}</title>
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Merriweather:wght@400;700&display=swap" rel="stylesheet">
  
  <!-- Nordic Luxury CSS -->
  <style>
    {{{css}}}
  </style>
</head>
<body>
  <div class="menu-container">
    
    <!-- HEADER -->
    <header class="menu-header">
      <!-- BRANDING QrOMS - Colțul din dreapta sus -->
      {{#if qrOMSLogo}}
      <div class="qroms-branding-first-page">
        <img src="{{qrOMSLogo}}" alt="QrOMS" class="qroms-logo">
        <span class="qroms-text">Powered by QrOMS</span>
      </div>
      {{/if}}
      
      <div class="restaurant-logo">🤗</div>
      <h1 class="restaurant-name">{{restaurant.name_full}}</h1>
      
      <h2 class="menu-title">{{menu_title}}</h2>
      <p class="menu-subtitle">{{menu_subtitle}}</p>
      
      <p class="generated-date">
        {{#if (eq metadata.lang "ro")}}
          Actualizat la: {{metadata.generated_at_formatted}}
        {{else}}
          Updated: {{metadata.generated_at_formatted}}
        {{/if}}
      </p>
    </header>
    
    <!-- FISCAL INFO PAGE - A DOUA PAGINĂ (pentru TOATE meniurile) -->
    {{> fiscal-receipt-info}}
    
    <!-- CATEGORIES -->
    {{#each categories}}
      {{> category-section}}
    {{/each}}
    
  </div>
</body>
</html>

