// GET /api/reports/profit-loss - Raport Profit & Loss (P&L)
app.get('/api/reports/profit-loss', checkAdminAuth, async (req, res) => {
    try {
        const { start_date, end_date } = req.query;
        const db = await dbPromise;
        
        // Calculează veniturile din comenzi finalizate
        const revenueQuery = `
            SELECT 
                DATE(timestamp) as date,
                SUM(
                    CASE 
                        WHEN total IS NOT NULL AND total > 0 
                        THEN total
                        ELSE 0
                    END
                ) as revenue
            FROM orders 
            WHERE is_paid = 1
            AND DATE(timestamp) BETWEEN ? AND ?
            GROUP BY DATE(timestamp)
            ORDER BY date
        `;
        
        const revenueData = await new Promise((resolve, reject) => {
            db.all(revenueQuery, [start_date, end_date], (err, rows) => {
                if (err) {
                    console.error('❌ Eroare la query venituri P&L:', err);
                    reject(err);
                } else {
                    resolve(rows || []);
                }
            });
        });
        
        // Calculează COGS (Cost of Goods Sold) - simplificat
        const cogsQuery = `
            SELECT 
                DATE(timestamp) as date,
                SUM(
                    CASE 
                        WHEN total IS NOT NULL AND total > 0 
                        THEN total * 0.3  -- Estimare simplă: 30% din venituri sunt costuri
                        ELSE 0
                    END
                ) as costs
            FROM orders
            WHERE is_paid = 1
            AND DATE(timestamp) BETWEEN ? AND ?
            GROUP BY DATE(timestamp)
            ORDER BY date
        `;
        
        const cogsData = await new Promise((resolve, reject) => {
            db.all(cogsQuery, [start_date, end_date], (err, rows) => {
                if (err) {
                    console.error('❌ Eroare la query COGS P&L:', err);
                    reject(err);
                } else {
                    resolve(rows || []);
                }
            });
        });
        
        // Combină datele și calculează profitul
        const combinedData = revenueData.map(revenue => {
            const costs = cogsData.find(c => c.date === revenue.date)?.costs || 0;
            const profit = revenue.revenue - costs;
            const margin = revenue.revenue > 0 ? ((profit / revenue.revenue) * 100).toFixed(2) + '%' : '0%';
            
            return {
                date: revenue.date,
                revenue: revenue.revenue,
                costs: costs,
                profit: profit,
                margin: margin
            };
        });
        
        // Calculează totalurile
        const totals = combinedData.reduce((acc, day) => ({
            total_revenue: acc.total_revenue + day.revenue,
            total_costs: acc.total_costs + day.costs,
            total_profit: acc.total_profit + day.profit
        }), { total_revenue: 0, total_costs: 0, total_profit: 0 });
        
        res.json({
            period: { start_date, end_date },
            totals: totals,
            data: combinedData
        });
        
    } catch (error) {
        console.error('❌ Eroare la generarea raportului P&L:', error);
        res.status(500).json({ error: 'Eroare la generarea raportului P&L' });
    }
});

// GET /api/reports/abc-analysis - Analiză ABC (Valoarea produselor)
app.get('/api/reports/abc-analysis', checkAdminAuth, async (req, res) => {
    try {
        const { period_months = 3 } = req.query;
        const db = await dbPromise;
        
        const startDate = new Date();
        startDate.setMonth(startDate.getMonth() - parseInt(period_months));
        const startDateStr = startDate.toISOString().slice(0, 10);
        
        // Obține veniturile per produs din ultimele N luni
        const productRevenueQuery = `
            SELECT 
                m.id,
                m.name,
                m.category,
                SUM(
                    CASE 
                        WHEN o.total IS NOT NULL AND o.total > 0 
                        THEN o.total * 0.1  -- Estimare simplă: fiecare comandă contribuie cu 10% din total per produs
                        ELSE 0
                    END
                ) as total_revenue,
                COUNT(*) as total_orders
            FROM orders o
            JOIN menu m ON 1=1  -- Join simplu pentru a obține toate produsele
            WHERE o.status IN ('completed', 'paid', 'paid_by_invoice')
            AND DATE(o.timestamp) >= ?
            GROUP BY m.id, m.name, m.category
            ORDER BY total_revenue DESC
        `;
        
        const products = await new Promise((resolve, reject) => {
            db.all(productRevenueQuery, [startDateStr], (err, rows) => {
                if (err) {
                    console.error('❌ Eroare la query ABC Analysis:', err);
                    reject(err);
                } else {
                    resolve(rows || []);
                }
            });
        });
        
        if (products.length === 0) {
            return res.json({
                summary: { class_A: 0, class_B: 0, class_C: 0 },
                products: []
            });
        }
        
        // Calculează totalul veniturilor
        const totalRevenue = products.reduce((sum, p) => sum + p.total_revenue, 0);
        
        // Clasifică produsele în clasele A, B, C
        let cumulativePercentage = 0;
        const classifiedProducts = products.map((product, index) => {
            const percentage = (product.total_revenue / totalRevenue) * 100;
            cumulativePercentage += percentage;
            
            let classification = 'C';
            if (cumulativePercentage <= 70) {
                classification = 'A';
            } else if (cumulativePercentage <= 90) {
                classification = 'B';
            }
            
            return {
                ...product,
                revenue_percentage: percentage.toFixed(2),
                cumulative_percentage: cumulativePercentage.toFixed(2),
                classification: classification
            };
        });
        
        // Calculează sumarul
        const summary = {
            class_A: classifiedProducts.filter(p => p.classification === 'A').length,
            class_B: classifiedProducts.filter(p => p.classification === 'B').length,
            class_C: classifiedProducts.filter(p => p.classification === 'C').length
        };
        
        res.json({
            period_months: parseInt(period_months),
            total_revenue: totalRevenue,
            summary: summary,
            products: classifiedProducts
        });
        
    } catch (error) {
        console.error('❌ Eroare la generarea analizei ABC:', error);
        res.status(500).json({ error: 'Eroare la generarea analizei ABC' });
    }
});

