  // POST /api/supplier-orders/:id/receive - Primire livrare + generare NIR automat
  app.post('/api/supplier-orders/:id/receive', checkAdminAuth, async (req, res) => {
    try {
      const { id } = req.params;
      const { items_delivered, invoice_number } = req.body; // items_delivered = [{id, quantity_delivered, quantity_damaged}]
      
      // 1. Obține comanda
      const order = await new Promise((resolve, reject) => {
        db.get('SELECT * FROM supplier_orders WHERE id = ?', [id], (err, row) => {
          if (err) reject(err);
          else resolve(row);
        });
      });
      
      if (!order) {
        return res.status(404).json({ error: 'Comandă negăsită' });
      }
      
      // 2. Obține furnizor
      const supplier = await new Promise((resolve, reject) => {
        db.get('SELECT company_name FROM suppliers WHERE id = ?', [order.supplier_id], (err, row) => {
          if (err) reject(err);
          else resolve(row);
        });
      });
      
      // 3. Obține toate items ale comenzii
      const orderItems = await new Promise((resolve, reject) => {
        db.all('SELECT * FROM supplier_order_items WHERE supplier_order_id = ?', [id], (err, rows) => {
          if (err) reject(err);
          else resolve(rows);
        });
      });
      
      // 4. Update cantități livrate în supplier_order_items
      if (items_delivered && items_delivered.length > 0) {
        const updatePromises = items_delivered.map(item => {
          return new Promise((resolve, reject) => {
            db.run(
              'UPDATE supplier_order_items SET quantity_delivered = ?, quantity_damaged = ? WHERE id = ?',
              [item.quantity_delivered || 0, item.quantity_damaged || 0, item.id],
              (err) => {
                if (err) reject(err);
                else resolve();
              }
            );
          });
        });
        
        await Promise.all(updatePromises);
      }
      
      // 5. Generare NIR automat
      const nirNumber = await generateFiscalNumber('NIR');
      const nirDate = new Date().toISOString().slice(0, 10);
      
      const nirId = await new Promise((resolve, reject) => {
        db.run(
          'INSERT INTO nir_documents (nir_number, supplier_name, document_date, reception_date, total_value, total_vat, created_by) VALUES (?, ?, ?, ?, ?, ?, ?)',
          [nirNumber, supplier?.company_name || 'Unknown', nirDate, nirDate, order.subtotal, order.vat_amount, 'Auto-generated'],
          function(err) {
            if (err) reject(err);
            else resolve(this.lastID);
          }
        );
      });
      
      // 6. Insert NIR items
      const nirItemsPromises = orderItems.map(item => {
        return new Promise((resolve, reject) => {
          db.run(
            'INSERT INTO nir_items (nir_id, ingredient_id, quantity, unit, unit_price, total_price) VALUES (?, ?, ?, ?, ?, ?)',
            [nirId, item.ingredient_id, item.quantity_ordered, item.unit_of_measure, item.unit_price, item.total_price],
            (err) => {
              if (err) reject(err);
              else resolve();
            }
          );
        });
      });
      
      await Promise.all(nirItemsPromises);
      
      // 7. Update supplier_orders cu NIR ID și status
      await new Promise((resolve, reject) => {
        db.run(
          'UPDATE supplier_orders SET nir_id = ?, nir_generated = 1, status = "delivered", actual_delivery_date = DATE("now", "localtime"), invoice_number = ?, invoice_received = 1, updated_at = datetime("now", "localtime") WHERE id = ?',
          [nirId, invoice_number || null, id],
          (err) => {
            if (err) reject(err);
            else resolve();
          }
        );
      });
      
      // 8. Update stocuri automat (pentru fiecare ingredient livrat)
      for (const item of orderItems) {
        await new Promise((resolve) => {
          db.run(
            'UPDATE ingredients SET stock = stock + ? WHERE id = ?',
            [item.quantity_ordered, item.ingredient_id],
            () => resolve() // Ignore errors pentru stocuri
          );
        });
      }
      
      console.log(`✅ Livrare primită pentru comandă ${order.order_number} - NIR ${nirNumber} generat - Stocuri actualizate`);
      
      res.json({
        success: true,
        nir_id: nirId,
        nir_number: nirNumber,
        message: 'Livrare primită, NIR generat, stocuri actualizate'
      });
      
    } catch (error) {
      console.error('❌ Error in POST /api/supplier-orders/:id/receive:', error);
      res.status(500).json({ error: error.message });
    }
  });
  
  // POST /api/supplier-orders/smart-order - Smart ordering (comenzi automate când stoc scăzut)
  app.post('/api/supplier-orders/smart-order', checkAdminAuth, async (req, res) => {
    try {
      // 1. Găsește toate ingredientele cu stoc sub minim
      db.all(
        'SELECT * FROM ingredients WHERE current_stock < min_stock AND min_stock > 0 ORDER BY (min_stock - current_stock) DESC',
        [],
        async (err, lowStockIngredients) => {
          if (err) {
            return res.status(500).json({ error: err.message });
          }
          
          if (lowStockIngredients.length === 0) {
            return res.json({ success: true, message: 'Toate ingredientele sunt în stoc', suggestions: [] });
          }
          
          // 2. Grupare per furnizor preferențial (dacă există)
          const suggestions = lowStockIngredients.map(ing => {
            const quantityNeeded = ing.min_stock - ing.current_stock;
            const optimalQuantity = Math.max(quantityNeeded, ing.min_stock * 1.5); // Comandă 150% din minim
            
            return {
              ingredient_id: ing.id,
              ingredient_name: ing.name,
              current_stock: ing.current_stock,
              minimum_stock: ing.min_stock,
              quantity_needed: quantityNeeded,
              suggested_quantity: Math.ceil(optimalQuantity),
              unit: ing.unit || 'kg'
            };
          });
          
          console.log(`✅ Smart Ordering: ${suggestions.length} ingrediente sub stoc minim`);
          
          res.json({
            success: true,
            message: `${suggestions.length} ingrediente necesită comandă`,
            suggestions: suggestions
          });
        }
      );
    } catch (error) {
      console.error('❌ Error in POST /api/supplier-orders/smart-order:', error);
      res.status(500).json({ error: error.message });
    }
  });
  
