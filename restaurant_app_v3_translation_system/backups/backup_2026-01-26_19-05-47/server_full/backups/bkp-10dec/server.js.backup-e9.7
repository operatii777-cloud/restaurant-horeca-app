// ========================================
// 🛡️ ASYNC ROUTE WRAPPER - Previne crash-urile din rutele async
// ========================================
function asyncHandler(fn) {
  return (req, res, next) => {
    Promise.resolve(fn(req, res, next)).catch((error) => {
      console.error('❌ [ROUTE ERROR] Eroare în rută:', error.message);
      console.error('📍 URL:', req.originalUrl);
      console.error('📍 Method:', req.method);
      if (error.stack) {
        console.error('📚 Stack Trace:', error.stack);
      }
      
      // Nu oprim serverul - trimitem răspuns de eroare
      if (!res.headersSent) {
        res.status(error.status || 500).json({
          error: error.message || 'Eroare internă server',
          code: error.code || 'INTERNAL_ERROR'
        });
      }
    });
  };
}

// ========================================
// 🛡️ DATABASE QUERY WRAPPER - Previne crash-urile din query-uri
// ========================================
function safeDbQuery(db, query, params = [], callback) {
  try {
    if (typeof callback === 'function') {
      db.all(query, params, (err, rows) => {
        if (err) {
          console.error('❌ [DB QUERY ERROR]', err.message);
          console.error('📍 Query:', query.substring(0, 100));
          callback(err, null);
        } else {
          callback(null, rows);
        }
      });
    } else {
      return new Promise((resolve, reject) => {
        db.all(query, params, (err, rows) => {
          if (err) {
            console.error('❌ [DB QUERY ERROR]', err.message);
            console.error('📍 Query:', query.substring(0, 100));
            reject(err);
          } else {
            resolve(rows);
          }
        });
      });
    }
  } catch (error) {
    console.error('❌ [DB QUERY EXCEPTION]', error.message);
    if (typeof callback === 'function') {
      callback(error, null);
    } else {
      return Promise.reject(error);
    }
  }
}

