  // POST /api/supplier-orders - Creare comandă furnizor
  app.post('/api/supplier-orders', checkAdminAuth, async (req, res) => {
    try {
      const { supplier_id, items, expected_delivery_date, notes, created_by } = req.body;
      
      if (!supplier_id || !items || items.length === 0) {
        return res.status(400).json({ error: 'Supplier și items sunt obligatorii' });
      }
      
      // Generare număr comandă
      const orderNumber = await generateFiscalNumber('OF'); // OF = Order Furnizor
      const orderDate = new Date().toISOString().slice(0, 10);
      
      // Calculare totaluri
      let subtotal = 0;
      let vatAmount = 0;
      
      items.forEach(item => {
        const itemTotal = item.quantity * item.unit_price;
        subtotal += itemTotal;
        vatAmount += itemTotal * (item.vat_rate || 11) / 100;
      });
      
      const totalAmount = subtotal + vatAmount;
      
      // Calculare payment_due_date
      const supplier = await new Promise((resolve, reject) => {
        db.get('SELECT payment_terms FROM suppliers WHERE id = ?', [supplier_id], (err, row) => {
          if (err) reject(err);
          else resolve(row);
        });
      });
      
      const paymentTerms = supplier?.payment_terms || 30;
      const dueDate = new Date();
      dueDate.setDate(dueDate.getDate() + paymentTerms);
      const paymentDueDate = dueDate.toISOString().slice(0, 10);
      
      // Insert comandă
      db.run(
        `INSERT INTO supplier_orders (order_number, supplier_id, order_date, expected_delivery_date, subtotal, vat_amount, total_amount, payment_terms, payment_due_date, notes, created_by, status)
         VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'draft')`,
        [orderNumber, supplier_id, orderDate, expected_delivery_date || null, subtotal, vatAmount, totalAmount, paymentTerms, paymentDueDate, notes || null, created_by || 'Admin'],
        function(err) {
          if (err) {
            console.error('❌ Error creating supplier order:', err);
            return res.status(500).json({ error: err.message });
          }
          
          const orderId = this.lastID;
          
          // Insert items
          const itemInserts = items.map(item => {
            return new Promise((resolve, reject) => {
              db.run(
                `INSERT INTO supplier_order_items (supplier_order_id, ingredient_id, quantity_ordered, unit_of_measure, unit_price, vat_rate, total_price)
                 VALUES (?, ?, ?, ?, ?, ?, ?)`,
                [orderId, item.ingredient_id, item.quantity, item.unit_of_measure, item.unit_price, item.vat_rate || 11, item.quantity * item.unit_price],
                (err) => {
                  if (err) reject(err);
                  else resolve();
                }
              );
            });
          });
          
          Promise.all(itemInserts)
            .then(() => {
              console.log(`✅ Comandă furnizor creată: ${orderNumber} - ${items.length} items - ${totalAmount.toFixed(2)} RON`);
              res.json({ success: true, id: orderId, order_number: orderNumber });
            })
            .catch(err => {
              console.error('❌ Error inserting items:', err);
              res.status(500).json({ error: err.message });
            });
        }
      );
    } catch (error) {
      console.error('❌ Error in POST /api/supplier-orders:', error);
      res.status(500).json({ error: error.message });
    }
  });
  
