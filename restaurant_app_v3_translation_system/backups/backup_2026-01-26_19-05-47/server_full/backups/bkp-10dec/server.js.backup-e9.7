// Adaugă un ingredient nou - CU VERIFICARE ANTI-DUPLICATE și VALIDARE MANUALĂ
app.post('/api/ingredients', checkAdminAuth, async (req, res) => {
    const {
        name,
        category,
        unit,
        current_stock,
        min_stock,
        cost_per_unit,
        supplier,
        force,
        validation_reason,
        official_name,
        category_id,
        subcategory_id,
        origin_country,
        storage_temp_min,
        storage_temp_max,
        haccp_notes,
        traceability_code,
        default_supplier_id,
        name_en,
        category_en,
        description,
        energy_kcal,
        fat,
        saturated_fat,
        carbs,
        sugars,
        protein,
        salt,
        fiber,
        additives,
        allergens,
        potential_allergens,
        notes
    } = req.body;

    if (!name || !unit || (!category && !category_id)) {
        res.status(400).json({ error: 'Numele, categoria și unitatea sunt obligatorii' });
        return;
    }

    try {
        const db = await dbPromise;
        
        // Obține toate ingredientele pentru verificare similaritate
        const allIngredients = await new Promise((resolve, reject) => {
            db.all('SELECT id, name, category, unit, current_stock FROM ingredients', [], (err, rows) => {
                if (err) reject(err);
                else resolve(rows || []);
            });
        });

        // Verifică duplicate și similaritate
        const duplicateCheck = checkIngredientExists(name, allIngredients);

        // Dacă există exact sau foarte similar și nu e forțat
        if (duplicateCheck.exists && !force) {
            if (duplicateCheck.exact) {
                return res.status(409).json({
                    error: 'Ingredientul există deja în sistem',
                    duplicate: true,
                    exact: true,
                    existing: duplicateCheck.match,
                    message: `"${duplicateCheck.match.name}" există deja (ID: ${duplicateCheck.match.id})`
                });
            } else {
                // Analizează diferențele pentru a ajuta utilizatorul
                const analysis = analyzeDifferences(name, duplicateCheck.similar[0].name);
                
                // Ingrediente similare găsite - cere validare manuală
                return res.status(409).json({
                    error: 'Ingrediente similare găsite',
                    duplicate: true,
                    exact: false,
                    similar: duplicateCheck.similar,
                    analysis: analysis,
                    message: `Atenție! Găsite ${duplicateCheck.similar.length} ingrediente similare. Sigur vrei să adaugi "${name}"?`,
                    suggestion: `Ai vrut să zici "${duplicateCheck.similar[0].name}"?`,
                    requiresValidation: true,
                    validationPrompt: analysis.hasDifferences 
                        ? 'Pare a fi ingredient diferit. Te rog confirmă sau explică diferența:'
                        : 'Ingredientele par identice. Dacă sunt diferite, te rog explică diferența:'
                });
            }
        }

        // Determină categoria și furnizorul implicit pe baza ID-urilor, dacă sunt oferite
        let resolvedCategory = category || null;
        let resolvedCategoryEn = category_en || null;
        if (category_id) {
            const categoryRow = await new Promise((resolve, reject) => {
                db.get(
                    'SELECT name_ro, name_en FROM ingredient_categories WHERE id = ?',
                    [category_id],
                    (err, row) => {
                        if (err) reject(err);
                        else resolve(row || null);
                    }
                );
            });
            if (categoryRow) {
                resolvedCategory = categoryRow.name_ro || resolvedCategory;
                resolvedCategoryEn = categoryRow.name_en || resolvedCategoryEn;
            }
        }

        let resolvedSupplier = supplier || '';
        if (default_supplier_id && !supplier) {
            const supplierRow = await new Promise((resolve, reject) => {
                db.get(
                    'SELECT company_name AS name FROM suppliers WHERE id = ?',
                    [default_supplier_id],
                    (err, row) => {
                        if (err) reject(err);
                        else resolve(row || null);
                    }
                );
            });
            if (supplierRow) {
                resolvedSupplier = supplierRow.name;
            }
        }

        const parseArrayField = (value) => {
            if (!value) return null;
            if (typeof value === 'string') return value;
            if (Array.isArray(value) || typeof value === 'object') return JSON.stringify(value);
            return null;
        };

        const serializedAllergens = parseArrayField(allergens);
        const serializedPotentialAllergens = parseArrayField(potential_allergens);
        const serializedAdditives = parseArrayField(additives);

        // ✅ SĂPTĂMÂNA 1 - ZIUA 4: Adaugă max_stock, safety_stock, reorder_quantity
        const max_stock = req.body.max_stock !== undefined && req.body.max_stock !== null && req.body.max_stock !== '' ? parseFloat(req.body.max_stock) : null;
        const safety_stock = req.body.safety_stock !== undefined && req.body.safety_stock !== null && req.body.safety_stock !== '' ? parseFloat(req.body.safety_stock) : null;
        const reorder_quantity = req.body.reorder_quantity !== undefined && req.body.reorder_quantity !== null && req.body.reorder_quantity !== '' ? parseFloat(req.body.reorder_quantity) : null;
        
        // Validare pentru POST (similar cu PUT)
        const minStockVal = min_stock !== undefined ? parseFloat(min_stock ?? 0) : null;
        if (max_stock !== null && minStockVal !== null && max_stock < minStockVal) {
            return res.status(400).json({ 
                success: false, 
                error: 'Stoc maxim trebuie să fie mai mare decât stoc minim' 
            });
        }
        if (safety_stock !== null && minStockVal !== null && safety_stock < minStockVal) {
            return res.status(400).json({ 
                success: false, 
                error: 'Stoc siguranță trebuie să fie >= stoc minim' 
            });
        }
        if (safety_stock !== null && max_stock !== null && safety_stock > max_stock) {
            return res.status(400).json({ 
                success: false, 
                error: 'Stoc siguranță trebuie să fie <= stoc maxim' 
            });
        }
        
        // ✅ SĂPTĂMÂNA 2 - ZIUA 4: Adaugă purchase units în INSERT
        const purchase_unit = req.body.purchase_unit || null;
        const recipe_unit = req.body.recipe_unit || null;
        const inventory_unit = req.body.inventory_unit || null;
        const purchase_to_inventory_factor = req.body.purchase_to_inventory_factor !== undefined && req.body.purchase_to_inventory_factor !== null && req.body.purchase_to_inventory_factor !== '' ? parseFloat(req.body.purchase_to_inventory_factor) : null;
        const inventory_to_recipe_factor = req.body.inventory_to_recipe_factor !== undefined && req.body.inventory_to_recipe_factor !== null && req.body.inventory_to_recipe_factor !== '' ? parseFloat(req.body.inventory_to_recipe_factor) : null;
        
        // Adaugă ingredient (cu sau fără validare)
        const query = `
            INSERT INTO ingredients 
            (name, name_en, official_name, category, category_en, category_id, subcategory_id, unit, current_stock, min_stock, max_stock, safety_stock, reorder_quantity, purchase_unit, recipe_unit, inventory_unit, purchase_to_inventory_factor, inventory_to_recipe_factor, cost_per_unit, supplier, origin_country, storage_temp_min, storage_temp_max, haccp_notes, traceability_code, default_supplier_id, description, energy_kcal, fat, saturated_fat, carbs, sugars, protein, salt, fiber, additives, allergens, potential_allergens, created_at, last_updated, notes)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP, ?)
        `;

        const result = await new Promise((resolve, reject) => {
            db.run(
                query,
                [
                    name,
                    name_en || null,
                    official_name || null,
                    resolvedCategory,
                    resolvedCategoryEn,
                    category_id || null,
                    subcategory_id || null,
                    unit,
                    current_stock || 0,
                    min_stock || 0,
                    max_stock,  // ✅ SĂPTĂMÂNA 1 - ZIUA 4
                    safety_stock,  // ✅ SĂPTĂMÂNA 1 - ZIUA 4
                    reorder_quantity,  // ✅ SĂPTĂMÂNA 1 - ZIUA 4
                    purchase_unit,  // ✅ SĂPTĂMÂNA 2 - ZIUA 4
                    recipe_unit,  // ✅ SĂPTĂMÂNA 2 - ZIUA 4
                    inventory_unit,  // ✅ SĂPTĂMÂNA 2 - ZIUA 4
                    purchase_to_inventory_factor,  // ✅ SĂPTĂMÂNA 2 - ZIUA 4
                    inventory_to_recipe_factor,  // ✅ SĂPTĂMÂNA 2 - ZIUA 4
                    cost_per_unit || 0,
                    resolvedSupplier,
                    origin_country || null,
                    storage_temp_min !== undefined ? parseFloat(storage_temp_min) : null,
                    storage_temp_max !== undefined ? parseFloat(storage_temp_max) : null,
                    haccp_notes || null,
                    traceability_code || null,
                    default_supplier_id || null,
                    description || null,
                    energy_kcal !== undefined ? parseFloat(energy_kcal) : null,
                    fat !== undefined ? parseFloat(fat) : null,
                    saturated_fat !== undefined ? parseFloat(saturated_fat) : null,
                    carbs !== undefined ? parseFloat(carbs) : null,
                    sugars !== undefined ? parseFloat(sugars) : null,
                    protein !== undefined ? parseFloat(protein) : null,
                    salt !== undefined ? parseFloat(salt) : null,
                    fiber !== undefined ? parseFloat(fiber) : null,
                    serializedAdditives,
                    serializedAllergens,
                    serializedPotentialAllergens,
                    notes || null
                ],
                function(err) {
                    if (err) reject(err);
                    else resolve(this.lastID);
                }
            );
        });

        // Log validare manuală dacă există
        if (force && validation_reason) {
            console.log(`✅ Ingredient adăugat cu validare manuală: "${name}" (ID: ${result})`);
            console.log(`   Motiv: ${validation_reason}`);
            
            db.run(
                'UPDATE ingredients SET notes = COALESCE(notes, "") || ? WHERE id = ?',
                [`\nValidat manual: ${validation_reason}`, result],
                (err) => {
                    if (err) console.error('Eroare salvare motiv validare:', err);
                }
            );
        } else {
            console.log(`✅ Ingredient nou adăugat: "${name}" (ID: ${result})`);
        }

        await invalidateCache(['ingredients'], true);

        res.json({
            success: true,
            message: 'Ingredientul a fost adăugat cu succes',
            ingredient_id: result,
            warning: force ? (validation_reason ? `Validat manual: ${validation_reason}` : 'Ingredient adăugat cu forțare') : null
        });
    } catch (error) {
        console.error('❌ Eroare la adăugarea ingredientului:', error);
        res.status(500).json({ error: 'Eroare la adăugarea ingredientului', details: error.message });
    }
});

const buildSerializedField = (value) => {
    if (value === undefined || value === null) return null;
    if (typeof value === 'string') return value;
    if (Array.isArray(value) || typeof value === 'object') return JSON.stringify(value);
    return null;
};

const handleIngredientUpdate = async (req, res) => {
    const ingredientId = Number(req.params.id);
    const {
        name,
        unit,
        category,
        category_en,
        category_id,
        subcategory_id,
        current_stock,
        min_stock,
        cost_per_unit,
        supplier,
        description,
        energy_kcal,
        fat,
        saturated_fat,
        carbs,
        sugars,
        protein,
        salt,
        fiber,
        additives,
        allergens,
        potential_allergens,
        official_name,
        origin_country,
        storage_temp_min,
        storage_temp_max,
        haccp_notes,
        traceability_code,
        default_supplier_id,
        name_en,
        notes,
        force,
        validation_reason
    } = req.body;

    if (!ingredientId || !name || !unit) {
        return res.status(400).json({ success: false, error: 'ID, numele și unitatea sunt obligatorii' });
    }

    try {
        const db = await dbPromise;

        // Verifică duplicate doar dacă numele se schimbă
        if (name) {
            const allIngredients = await new Promise((resolve, reject) => {
                db.all('SELECT id, name, category, unit FROM ingredients WHERE id != ?', [ingredientId], (err, rows) => {
                    if (err) reject(err);
                    else resolve(rows || []);
                });
            });

            const duplicateCheck = checkIngredientExists(name, allIngredients);

            if (duplicateCheck.exists && !force) {
                if (duplicateCheck.exact) {
                    return res.status(409).json({
                        error: 'Ingredientul există deja în sistem',
                        duplicate: true,
                        exact: true,
                        existing: duplicateCheck.match,
                        message: `"${duplicateCheck.match.name}" există deja (ID: ${duplicateCheck.match.id})`
                    });
                }

                const analysis = analyzeDifferences(name, duplicateCheck.similar[0].name);
                return res.status(409).json({
                    error: 'Ingrediente similare găsite',
                    duplicate: true,
                    exact: false,
                    similar: duplicateCheck.similar,
                    analysis,
                    message: `Atenție! Găsite ${duplicateCheck.similar.length} ingrediente similare. Sigur vrei să continui cu "${name}"?`,
                    suggestion: `Ai vrut să zici "${duplicateCheck.similar[0].name}"?`,
                    requiresValidation: true,
                    validationPrompt: analysis.hasDifferences
                        ? 'Pare a fi ingredient diferit. Te rog confirmă sau explică diferența:'
                        : 'Ingredientele par identice. Dacă sunt diferite, te rog explică diferența:'
                });
            }
        }

        // Determină categoria și furnizorul
        let resolvedCategory = category;
        let resolvedCategoryEn = category_en;
        if (category_id) {
            const categoryRow = await new Promise((resolve, reject) => {
                db.get('SELECT name_ro, name_en FROM ingredient_categories WHERE id = ?', [category_id], (err, row) => {
                    if (err) reject(err);
                    else resolve(row || null);
                });
            });
            if (categoryRow) {
                resolvedCategory = categoryRow.name_ro || resolvedCategory;
                resolvedCategoryEn = categoryRow.name_en || resolvedCategoryEn;
            }
        }

        let resolvedSupplier = supplier;
        if (default_supplier_id && !supplier) {
            const supplierRow = await new Promise((resolve, reject) => {
                db.get('SELECT company_name AS name FROM suppliers WHERE id = ?', [default_supplier_id], (err, row) => {
                    if (err) reject(err);
                    else resolve(row || null);
                });
            });
            if (supplierRow) {
                resolvedSupplier = supplierRow.name;
            }
        }

        const updates = [];
        const params = [];
        const setField = (column, value, transform = (v) => v) => {
            if (value !== undefined) {
                updates.push(`${column} = ?`);
                params.push(transform(value));
            }
        };

        setField('name', name);
        setField('name_en', name_en);
        setField('official_name', official_name);
        if (resolvedCategory !== undefined) {
            updates.push('category = ?');
            params.push(resolvedCategory || null);
        }
        if (resolvedCategoryEn !== undefined) {
            updates.push('category_en = ?');
            params.push(resolvedCategoryEn || null);
        }
        setField('category_id', category_id);
        setField('subcategory_id', subcategory_id);
        setField('unit', unit);
        setField('current_stock', current_stock, (v) => parseFloat(v ?? 0));
        setField('min_stock', min_stock, (v) => parseFloat(v ?? 0));
        // ✅ SĂPTĂMÂNA 2 - ZIUA 4: Purchase Units
        setField('purchase_unit', req.body.purchase_unit);
        setField('recipe_unit', req.body.recipe_unit);
        setField('inventory_unit', req.body.inventory_unit);
        setField('purchase_to_inventory_factor', req.body.purchase_to_inventory_factor, (v) => v !== null && v !== undefined && v !== '' ? parseFloat(v) : null);
        setField('inventory_to_recipe_factor', req.body.inventory_to_recipe_factor, (v) => v !== null && v !== undefined && v !== '' ? parseFloat(v) : null);
        // ✅ SĂPTĂMÂNA 1 - ZIUA 4: Max Stock & Safety Stock
        setField('max_stock', req.body.max_stock, (v) => v !== null && v !== undefined && v !== '' ? parseFloat(v) : null);
        setField('safety_stock', req.body.safety_stock, (v) => v !== null && v !== undefined && v !== '' ? parseFloat(v) : null);
        setField('reorder_quantity', req.body.reorder_quantity, (v) => v !== null && v !== undefined && v !== '' ? parseFloat(v) : null);
        setField('cost_per_unit', cost_per_unit, (v) => parseFloat(v ?? 0));
        
        // ✅ Validare: min < safety < max (dacă toate sunt setate)
        const maxStockVal = req.body.max_stock !== undefined && req.body.max_stock !== null && req.body.max_stock !== '' ? parseFloat(req.body.max_stock) : null;
        const minStockVal = min_stock !== undefined ? parseFloat(min_stock ?? 0) : null;
        const safetyStockVal = req.body.safety_stock !== undefined && req.body.safety_stock !== null && req.body.safety_stock !== '' ? parseFloat(req.body.safety_stock) : null;
        
        if (maxStockVal !== null && minStockVal !== null && maxStockVal < minStockVal) {
            return res.status(400).json({ 
                success: false, 
                error: 'Stoc maxim trebuie să fie mai mare decât stoc minim' 
            });
        }
        
        if (safetyStockVal !== null && minStockVal !== null && safetyStockVal < minStockVal) {
            return res.status(400).json({ 
                success: false, 
                error: 'Stoc siguranță trebuie să fie >= stoc minim' 
            });
        }
        
        if (safetyStockVal !== null && maxStockVal !== null && safetyStockVal > maxStockVal) {
            return res.status(400).json({ 
                success: false, 
                error: 'Stoc siguranță trebuie să fie <= stoc maxim' 
            });
        }
        if (resolvedSupplier !== undefined) {
            updates.push('supplier = ?');
            params.push(resolvedSupplier || '');
        }
        setField('origin_country', origin_country);
        setField('storage_temp_min', storage_temp_min, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('storage_temp_max', storage_temp_max, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('haccp_notes', haccp_notes);
        setField('traceability_code', traceability_code);
        setField('default_supplier_id', default_supplier_id, (v) => (v ? Number(v) : null));
        setField('description', description);
        setField('energy_kcal', energy_kcal, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('fat', fat, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('saturated_fat', saturated_fat, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('carbs', carbs, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('sugars', sugars, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('protein', protein, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('salt', salt, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        setField('fiber', fiber, (v) => v !== null && v !== '' ? parseFloat(v) : null);
        if (additives !== undefined) {
            updates.push('additives = ?');
            params.push(buildSerializedField(additives));
        }
        if (allergens !== undefined) {
            updates.push('allergens = ?');
            params.push(buildSerializedField(allergens));
        }
        if (potential_allergens !== undefined) {
            updates.push('potential_allergens = ?');
            params.push(buildSerializedField(potential_allergens));
        }
        if (notes !== undefined) {
            updates.push('notes = ?');
            params.push(notes || null);
        }

        if (!updates.length) {
            return res.json({ success: true, message: 'Nu au fost furnizate câmpuri de actualizat' });
        }

        updates.push('last_updated = CURRENT_TIMESTAMP');
        params.push(ingredientId);

        await new Promise((resolve, reject) => {
            db.run(
                `UPDATE ingredients SET ${updates.join(', ')} WHERE id = ?`,
                params,
                function (err) {
                    if (err) reject(err);
                    else resolve(this.changes);
                }
            );
        });

        if (force && validation_reason) {
            db.run(
                'UPDATE ingredients SET notes = COALESCE(notes, "") || ? WHERE id = ?',
                [`\nValidat manual: ${validation_reason}`, ingredientId],
                (err) => {
                    if (err) console.error('Eroare salvare motiv validare (update):', err);
                }
            );
        }

        await invalidateCache(['ingredients'], true);

        console.log(`✅ Ingredient actualizat: ID ${ingredientId} (${name})`);
        res.json({
            success: true,
            message: 'Ingredientul a fost actualizat cu succes'
        });
    } catch (error) {
        console.error('❌ Eroare la actualizarea ingredientului:', error);
        console.error('📦 Payload primit:', req.body);
        res.status(500).json({ error: 'Eroare la actualizarea ingredientului', details: error.message });
    }
};

