app.post('/api/admin/transfers', checkAdminAuth, async (req, res) => {
  const header = req.body?.header ?? {};
  const lines = Array.isArray(req.body?.lines) ? req.body.lines : [];
  const tenantId = DEFAULT_TENANT_ID;

  const number = typeof header.document_number === 'string' ? header.document_number.trim() : '';
  const date = typeof header.document_date === 'string' ? header.document_date.trim() : '';
  const source = typeof header.source_location === 'string' ? header.source_location.trim() : '';
  const target = typeof header.target_location === 'string' ? header.target_location.trim() : '';
  const responsible = typeof header.responsible === 'string' ? header.responsible.trim() : '';
  const notes = typeof header.notes === 'string' && header.notes.trim() ? header.notes.trim() : null;
  const headerId = toPositiveInt(header.id);

  if (!number) return res.status(400).json({ error: 'Numărul documentului este obligatoriu.' });
  if (!date) return res.status(400).json({ error: 'Data documentului este obligatorie.' });
  if (!source) return res.status(400).json({ error: 'Sursa este obligatorie.' });
  if (!target) return res.status(400).json({ error: 'Destinația este obligatorie.' });
  if (source === target) return res.status(400).json({ error: 'Sursa și destinația trebuie să fie diferite.' });
  if (!responsible) return res.status(400).json({ error: 'Responsabilul este obligatoriu.' });
  if (!lines.length) return res.status(400).json({ error: 'Adaugă cel puțin o linie de transfer.' });

  // sanitize lines
  const sanitized = lines.map((l, idx) => {
    const ingredientId = toPositiveInt(l.ingredient_id);
    const quantity = safeNumber(l.quantity, 0);
    const unit = typeof l.unit === 'string' && l.unit.trim() ? l.unit.trim() : null;
    if (!ingredientId) {
      const e = new Error(`Ingredient invalid la linia ${idx + 1}`);
      e.statusCode = 400;
      throw e;
    }
    if (!(quantity > 0)) {
      const e = new Error(`Cantitatea trebuie să fie > 0 la linia ${idx + 1}`);
      e.statusCode = 400;
      throw e;
    }
    return { ingredient_id: ingredientId, quantity, unit };
  });

  try {
    const db = await dbPromise;
    let tx = false;
    try {
      await runAsync(db, 'BEGIN TRANSACTION');
      tx = true;

      let transferId = headerId;
      if (transferId) {
        const exists = await getAsync(
          db,
          `SELECT id FROM transfer_headers WHERE id = ? AND tenant_id = ?`,
          [transferId, tenantId]
        );
        if (!exists) {
          const e = new Error('Transferul nu există.');
          e.statusCode = 404;
          throw e;
        }
        await runAsync(
          db,
          `
            UPDATE transfer_headers
            SET document_number = ?, document_date = ?, source_location = ?, target_location = ?,
                responsible = ?, notes = ?, updated_at = datetime('now')
            WHERE id = ? AND tenant_id = ?
          `,
          [number, date, source, target, responsible, notes, transferId, tenantId]
        );
        await runAsync(db, `DELETE FROM transfer_lines WHERE transfer_id = ? AND tenant_id = ?`, [
          transferId,
          tenantId,
        ]);
        await runAsync(
          db,
          `DELETE FROM stock_moves WHERE tenant_id = ? AND reference_type = 'TRANSFER' AND reference_id = ?`,
          [tenantId, transferId]
        );
      } else {
        const ins = await runAsync(
          db,
          `
            INSERT INTO transfer_headers (
              tenant_id, document_number, document_date,
              source_location, target_location, responsible, notes, created_by
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
          `,
          [tenantId, number, date, source, target, responsible, notes, req.user?.id ?? null]
        );
        transferId = ins.lastID;
      }

      // prefetch ingredient cost/unit
      const ids = [...new Set(sanitized.map((l) => l.ingredient_id))];
      let ingMap = new Map();
      if (ids.length) {
        const placeholders = ids.map(() => '?').join(',');
        const rows = await allAsync(
          db,
          `SELECT id, unit, cost_per_unit FROM ingredients WHERE id IN (${placeholders})`,
          ids
        );
        ingMap = new Map(rows.map((r) => [r.id, r]));
      }

      for (const line of sanitized) {
        const ing = ingMap.get(line.ingredient_id);
        if (!ing) {
          const e = new Error(`Ingredientul cu ID ${line.ingredient_id} nu există.`);
          e.statusCode = 400;
          throw e;
        }
        const costUnit = safeNumber(ing.cost_per_unit, 0);
        const valueTotal = roundNumber(costUnit * line.quantity, 4);
        const unit = line.unit || ing.unit || null;

        await runAsync(
          db,
          `
            INSERT INTO transfer_lines (
              tenant_id, transfer_id, ingredient_id, unit, quantity, cost_unit, value_total, created_at
            ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))
          `,
          [tenantId, transferId, line.ingredient_id, unit, line.quantity, costUnit, valueTotal]
        );

        // Stock updates by locations: maintaining a single stock field; global stock rămâne net zero.
        // OUT from source (audit only)
        await createStockMove({
          tenant_id: tenantId,
          ingredient_id: line.ingredient_id,
          qty: line.quantity,
          direction: 'OUT',
          reason: STOCK_MOVE_REASON.TRANSFER_OUT,
          source: STOCK_MOVE_SOURCE.TRANSFER,
          reference_type: 'TRANSFER',
          reference_id: transferId,
          unit_price: costUnit,
          value: valueTotal,
          tva_percent: 0,
          meta: {
            source_location: source,
            target_location: target,
          },
        });
        // IN into target (audit only)
        await createStockMove({
          tenant_id: tenantId,
          ingredient_id: line.ingredient_id,
          qty: line.quantity,
          direction: 'IN',
          reason: STOCK_MOVE_REASON.TRANSFER_IN,
          source: STOCK_MOVE_SOURCE.TRANSFER,
          reference_type: 'TRANSFER',
          reference_id: transferId,
          unit_price: costUnit,
          value: valueTotal,
          tva_percent: 0,
          meta: {
            source_location: source,
            target_location: target,
          },
        });
      }

      await runAsync(db, 'COMMIT');
      tx = false;
      res.json({ id: transferId });
    } catch (error) {
      if (tx) {
        try {
          await runAsync(db, 'ROLLBACK');
        } catch (rbErr) {
          console.error('⚠️ Eroare rollback transfer:', rbErr);
        }
      }
      if (error.statusCode) {
        return res.status(error.statusCode).json({ error: error.message });
      }
      throw error;
    }
  } catch (error) {
    console.error('❌ Eroare la salvarea transferului:', error);
    res.status(500).json({ error: 'Eroare la salvarea transferului' });
  }
});

