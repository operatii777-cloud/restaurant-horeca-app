// POST /api/admin/pos/pay - înregistrează o plată pentru o comandă
app.post('/api/admin/pos/pay', checkAdminAuth, async (req, res) => {
  const orderId = toPositiveInt(req.body?.orderId);
  const type = (req.body?.type || '').toString().toLowerCase();
  const amount = safeNumber(req.body?.amount, 0);
  const metadata = req.body?.metadata ? JSON.stringify(req.body.metadata) : null;
  if (!orderId) return res.status(400).json({ error: 'ID comandă invalid.' });
  if (!amount || amount <= 0) return res.status(400).json({ error: 'Suma trebuie să fie > 0.' });
  if (!type) return res.status(400).json({ error: 'Tipul plății este obligatoriu.' });
  try {
    const db = await dbPromise;
    let tx = false;
    try {
      await runAsync(db, 'BEGIN TRANSACTION');
      tx = true;

      await runAsync(
        db,
        `INSERT INTO pos_payments (order_id, amount, type, metadata) VALUES (?, ?, ?, ?)`,
        [orderId, amount, type, metadata]
      );

      const sumRow = await getAsync(
        db,
        `SELECT COALESCE(SUM(amount), 0) AS total_paid FROM pos_payments WHERE order_id = ?`,
        [orderId]
      );
      const totalPaid = safeNumber(sumRow?.total_paid, 0);

      const orderRow = await getAsync(db, `SELECT total, is_paid FROM orders WHERE id = ?`, [orderId]);
      const orderTotal = safeNumber(orderRow?.total, 0);

      let markedPaid = false;
      if (!orderRow?.is_paid && totalPaid >= orderTotal && orderTotal > 0) {
        const paidTime = getCurrentUTCTimestamp();
        await runAsync(
          db,
          `UPDATE orders SET is_paid = 1, paid_timestamp = ?, status = 'paid' WHERE id = ?`,
          [paidTime, orderId]
        );
        markedPaid = true;
        try {
          io.emit('orderPaid', { orderId, paidTime });
        } catch {}
      }

      await runAsync(db, 'COMMIT');
      tx = false;
      res.json({ success: true, totalPaid, markedPaid });
    } catch (error) {
      if (tx) {
        try { await runAsync(db, 'ROLLBACK'); } catch {}
      }
      throw error;
    }
  } catch (error) {
    console.error('❌ Eroare la înregistrarea plății POS:', error);
    res.status(500).json({ error: 'Eroare la înregistrarea plății POS' });
  }
});

