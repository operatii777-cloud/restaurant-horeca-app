  // ==================== SUPPLIER ORDERS API ====================
  // IMPORTANT: Această rută trebuie să fie ÎNAINTE de /api/suppliers/:id pentru a evita conflictul de routing
  // GET /api/suppliers/orders - Listă comenzi furnizori
  app.get('/api/suppliers/orders', async (req, res) => {
    try {
      const { supplier_id, status } = req.query;
      
      // Verifică dacă tabela există
      db.get("SELECT name FROM sqlite_master WHERE type='table' AND name='supplier_orders'", (err, table) => {
        if (err) {
          console.error('❌ Error checking supplier_orders table:', err);
          return res.status(500).json({ error: err.message });
        }
        
        if (!table) {
          console.log('⚠️ Tabela supplier_orders nu există încă');
          return res.json({ success: true, data: [] });
        }
        
        // Query pentru comenzi - simplificat pentru a evita probleme cu GROUP BY când nu există date
        let query = `
          SELECT 
            so.*,
            COALESCE(s.company_name, 'Necunoscut') as supplier_name
          FROM supplier_orders so
          LEFT JOIN suppliers s ON so.supplier_id = s.id
          WHERE 1=1
        `;
        const params = [];
        
        if (supplier_id) {
          query += ' AND so.supplier_id = ?';
          params.push(supplier_id);
        }
        
        if (status) {
          query += ' AND so.status = ?';
          params.push(status);
        }
        
        query += ' ORDER BY so.order_date DESC, so.created_at DESC';
        
        // Obține item_count separat pentru fiecare comandă
        db.all(query, params, (err, rows) => {
          if (err) {
            console.error('❌ Error fetching supplier orders:', err);
            return res.status(500).json({ error: err.message });
          }
          
          // Adaugă item_count pentru fiecare comandă
          if (rows.length === 0) {
            console.log(`✅ GET /api/suppliers/orders: 0 comenzi`);
            return res.json({ success: true, data: [] });
          }
          
          let completed = 0;
          const ordersWithCounts = rows.map(order => ({ ...order, item_count: 0 }));
          
          // Verifică dacă tabela supplier_order_items există
          db.get("SELECT name FROM sqlite_master WHERE type='table' AND name='supplier_order_items'", (err, itemsTable) => {
            if (err || !itemsTable) {
              // Dacă tabela nu există, returnează comenzi fără item_count
              console.log(`⚠️ Tabela supplier_order_items nu există - returnez comenzi fără item_count`);
              rows.forEach(order => order.item_count = 0);
              console.log(`✅ GET /api/suppliers/orders: ${rows.length} comenzi`);
              return res.json({ success: true, data: rows });
            }
            
            // Dacă tabela există, obține item_count pentru fiecare comandă
            rows.forEach((order, index) => {
              db.get('SELECT COUNT(*) as count FROM supplier_order_items WHERE order_id = ?', [order.id], (err, row) => {
                if (!err && row) {
                  ordersWithCounts[index].item_count = row.count || 0;
                }
                completed++;
                if (completed === rows.length) {
                  console.log(`✅ GET /api/suppliers/orders: ${ordersWithCounts.length} comenzi`);
                  res.json({ success: true, data: ordersWithCounts });
                }
              });
            });
          });
        });
        return;
        
        db.all(query, params, (err, rows) => {
          if (err) {
            console.error('❌ Error fetching supplier orders:', err);
            return res.status(500).json({ error: err.message });
          }
          
          console.log(`✅ GET /api/suppliers/orders: ${rows.length} comenzi`);
          res.json({ success: true, data: rows || [] });
        });
      });
    } catch (error) {
      console.error('❌ Error in GET /api/suppliers/orders:', error);
      res.status(500).json({ error: error.message });
    }
  });

