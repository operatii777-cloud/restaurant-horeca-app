  // GET /api/admin/dashboard/metrics - Metrici pentru dashboard-ul avansat
  app.get('/api/admin/dashboard/metrics', checkAdminAuth, async (req, res) => {
    try {
      const db = await dbPromise;
      const today = new Date().toISOString().slice(0, 10);
      const yesterday = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
      
      // 1. Venituri astăzi - calculează din items dacă total este NULL
      const todayRevenue = await new Promise((resolve, reject) => {
        db.all(`
          SELECT items, total 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [today], (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          let totalRevenue = 0;
          rows.forEach(order => {
            if (order.total && order.total > 0) {
              // Folosește total-ul din baza de date dacă există
              totalRevenue += order.total;
            } else if (order.items) {
              // Calculează din items dacă total este NULL sau 0
              try {
                const items = safeParseItems(order.items);
                if (Array.isArray(items)) {
                  items.forEach(item => {
                    if (item.finalPrice && item.quantity) {
                      totalRevenue += item.finalPrice * item.quantity;
                    }
                  });
                }
              } catch (parseError) {
                console.warn('⚠️ Eroare la parsarea items pentru comanda:', order.id, parseError.message);
              }
            }
          });
          
          resolve(totalRevenue);
        });
      });
      
      // 2. Venituri ieri pentru comparație - calculează din items dacă total este NULL
      const yesterdayRevenue = await new Promise((resolve, reject) => {
        db.all(`
          SELECT items, total 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [yesterday], (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          let totalRevenue = 0;
          rows.forEach(order => {
            if (order.total && order.total > 0) {
              // Folosește total-ul din baza de date dacă există
              totalRevenue += order.total;
            } else if (order.items) {
              // Calculează din items dacă total este NULL sau 0
              try {
                const items = safeParseItems(order.items);
                if (Array.isArray(items)) {
                  items.forEach(item => {
                    if (item.finalPrice && item.quantity) {
                      totalRevenue += item.finalPrice * item.quantity;
                    }
                  });
                }
              } catch (parseError) {
                console.warn('⚠️ Eroare la parsarea items pentru comanda:', order.id, parseError.message);
              }
            }
          });
          
          resolve(totalRevenue);
        });
      });
      
      // 3. Calculează procentul de schimbare
      const revenueChange = yesterdayRevenue > 0 
        ? ((todayRevenue - yesterdayRevenue) / yesterdayRevenue * 100)
        : 0;
      
      // 4. Alerte stoc (ingrediente sub min_stock)
      const inventoryAlerts = await new Promise((resolve, reject) => {
        db.get(`
          SELECT COUNT(*) as count 
          FROM ingredients 
          WHERE current_stock <= min_stock
        `, (err, row) => {
          if (err) reject(err);
          else resolve(row.count);
        });
      });
      
      // 5. Retenție clienți (clienți care au comandat în ultimele 7 zile și în ultimele 30 zile)
      const customerRetention = await new Promise((resolve, reject) => {
        db.get(`
          SELECT 
            COUNT(DISTINCT CASE WHEN DATE(timestamp) >= date('now', '-7 days') THEN client_identifier END) as recent_customers,
            COUNT(DISTINCT CASE WHEN DATE(timestamp) >= date('now', '-30 days') THEN client_identifier END) as monthly_customers
          FROM orders 
          WHERE is_paid = 1 AND client_identifier IS NOT NULL
        `, (err, row) => {
          if (err) reject(err);
          else {
            const retention = row.monthly_customers > 0 
              ? (row.recent_customers / row.monthly_customers * 100)
              : 0;
            resolve(retention);
          }
        });
      });
      
      // 6. COGS astăzi (Cost of Goods Sold) - calcul simplificat
      const cogsToday = await new Promise((resolve, reject) => {
        db.all(`
          SELECT items 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [today], async (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          let totalCOGS = 0;
          
          for (const order of rows) {
            if (!order.items) continue;
            
            try {
              const items = safeParseItems(order.items);
              if (!Array.isArray(items)) continue;
              
              for (const item of items) {
                if (!item.productId || !item.quantity) continue;
                
                // Găsește rețeta pentru produs
                const recipeRows = await new Promise((resolveRecipe, rejectRecipe) => {
                  db.all(`
                    SELECT r.quantity_needed, i.cost_per_unit
                    FROM recipes r
                    JOIN ingredients i ON r.ingredient_id = i.id
                    WHERE r.product_id = ?
                  `, [item.productId], (err, rows) => {
                    if (err) rejectRecipe(err);
                    else resolveRecipe(rows);
                  });
                });
                
                // Calculează costul ingredientelor pentru această cantitate
                recipeRows.forEach(recipe => {
                  if (recipe.quantity_needed && recipe.cost_per_unit) {
                    const ingredientCost = recipe.quantity_needed * recipe.cost_per_unit;
                    totalCOGS += ingredientCost * item.quantity;
                  }
                });
              }
              
            } catch (parseError) {
              console.warn('⚠️ Eroare la parsarea items pentru comanda:', parseError.message);
            }
          }
          
          resolve(totalCOGS);
        });
      });
      
      res.json({
        todayRevenue: Math.round(todayRevenue * 100) / 100,
        revenueChange: Math.round(revenueChange * 10) / 10,
        inventoryAlerts: inventoryAlerts,
        customerRetention: Math.round(customerRetention * 10) / 10,
        cogsToday: Math.round(cogsToday * 100) / 100
      });
      
    } catch (error) {
      console.error('❌ Error in admin dashboard metrics:', error);
      res.status(500).json({ error: 'Eroare la calcularea metricilor dashboard' });
    }
  });

