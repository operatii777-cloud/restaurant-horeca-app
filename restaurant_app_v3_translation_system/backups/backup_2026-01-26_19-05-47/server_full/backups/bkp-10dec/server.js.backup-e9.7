// PUT /api/recipes/product/:productId - Salvare rețetă (actualizare ingredients)
app.put('/api/recipes/product/:productId', checkAdminAuth, async (req, res) => {
    try {
        const productId = parseInt(req.params.productId);
        const { ingredients } = req.body;
        const db = await dbPromise;

        if (!Array.isArray(ingredients)) {
             return res.status(400).json({ success: false, error: 'Formatul ingredientelor trimise este invalid.' });
        }

        const detectCategory = (name) => {
            if (!name) return 'Diverse';
            const nameLower = name.toLowerCase();
            if (nameLower.match(/mozzarella|parmezan|cașcaval|brânză|unt|smântână|iaurt/)) return 'Lactate';
            if (nameLower.match(/pui|vită|porc|carne|șuncă|bacon|cârnați/)) return 'Carne';
            if (nameLower.match(/roșii|ceapă|usturoi|ardei|salată|morcov|cartofi/)) return 'Legume';
            if (nameLower.match(/oregano|busuioc|sare|piper|condiment/)) return 'Condimente';
            if (nameLower.match(/făină|paste|orez|pâine/)) return 'Panificație';
            if (nameLower.match(/ulei|sos|ketchup|maioneză|ambalaj|cutie|caserolă/)) return 'Ambalaje';
            return 'Diverse';
        };

        const normalizedIngredients = ingredients
            .map((ing) => {
                const name = typeof ing.name === 'string' ? ing.name.trim() : '';
                const quantity = parseFloat(ing.quantity);
                if (!name || !Number.isFinite(quantity) || quantity <= 0) {
                    console.warn(`⚠️ Ingredient invalid pentru produsul #${productId}:`, ing);
                    return null;
                }

                return {
                    original: ing,
                    name,
                    quantity,
                    unit: typeof ing.unit === 'string' && ing.unit.trim() ? ing.unit.trim() : null,
                    waste_percentage: ing.waste_percentage !== undefined ? Number(ing.waste_percentage) || 0 : 0,
                    variable_consumption: typeof ing.variable_consumption === 'string' && ing.variable_consumption.trim() ? ing.variable_consumption.trim() : null,
                    item_type: ing.item_type || (ing.recipe_id ? 'recipe' : 'ingredient'),
                    ingredient_id: Number.isInteger(ing.ingredient_id) ? ing.ingredient_id : null,
                    recipe_id: Number.isInteger(ing.recipe_id) ? ing.recipe_id : null  // ✅ Sub-rețetă
                };
            })
            .filter(Boolean);

        if (normalizedIngredients.length === 0) {
            return res.status(400).json({ success: false, error: 'Nu au fost primite ingrediente valide pentru rețetă.' });
        }

        console.log(`📋 Actualizare rețetă pentru productId=${productId}: ${normalizedIngredients.length} ingrediente validate`);

        // STEP 1: Ștergem rețetele vechi din tabela recipes
        await new Promise((resolve, reject) => {
            db.run('DELETE FROM recipes WHERE product_id = ?', [productId], function(err) {
                if (err) {
                    console.error(`❌ Eroare la ștergerea rețetelor vechi pentru product ${productId}:`, err);
                    reject(err);
                } else {
                    console.log(`✅ Șterse ${this.changes} rețete vechi pentru product ${productId}`);
                    resolve();
                }
            });
        });

        // STEP 2: Inserăm rețetele noi în tabela recipes
        // ✅ MODIFICAT: Suport pentru sub-rețete (recipe_id)
        for (const ing of normalizedIngredients) {
            let finalIngredientId = ing.ingredient_id;
            let finalRecipeId = ing.recipe_id;

            // ✅ Dacă e sub-rețetă (recipe_id), validăm și skip ingredient logic
            if (finalRecipeId) {
                // Validare: nu poate fi folosit ca sub-rețetă pentru el însuși
                if (finalRecipeId === productId) {
                    return res.status(400).json({ 
                        success: false, 
                        error: `Nu poți folosi produsul "${ing.name}" ca sub-rețetă pentru el însuși.` 
                    });
                }
                
                // Validare circular dependency
                const { canUseAsSubRecipe } = require('./helpers/recipe-helpers');
                const validation = await canUseAsSubRecipe(finalRecipeId, productId);
                if (!validation.canUse) {
                    return res.status(400).json({ 
                        success: false, 
                        error: validation.reason || 'Circular dependency detectată' 
                    });
                }
                
                finalIngredientId = null; // Clear ingredient_id când folosim recipe_id
            } else if (!finalIngredientId) {
                // caută ingredient după nume
                const existingIngredient = await new Promise((resolve, reject) => {
                    db.get('SELECT id, unit FROM ingredients WHERE name = ? COLLATE NOCASE', [ing.name], (err, row) => {
                        if (err) reject(err);
                        else resolve(row);
                    });
                });

                if (existingIngredient) {
                    finalIngredientId = existingIngredient.id;
                    if (!ing.unit && existingIngredient.unit) {
                        ing.unit = existingIngredient.unit;
                    }
                } else {
                    // Creează automat ingredientul
                    const created = await new Promise((resolve, reject) => {
                        db.run(
                            `INSERT INTO ingredients (name, category, unit, allergens, cost_per_unit) VALUES (?, ?, ?, NULL, 0)`,
                            [ing.name, detectCategory(ing.name), ing.unit || 'g'],
                            function(err) {
                                if (err) reject(err);
                                else resolve({ id: this.lastID });
                            }
                        );
                    });
                    finalIngredientId = created.id;
                    console.log(`✨ Ingredient nou creat pentru rețetă: ${ing.name} (#${finalIngredientId})`);

                    await new Promise((resolve, reject) => {
                        db.run(
                            `INSERT INTO stocks (ingredient_id, quantity, unit, last_updated) VALUES (?, 0, ?, CURRENT_TIMESTAMP)`,
                            [finalIngredientId, ing.unit || 'g'],
                            (err) => {
                                if (err) {
                                    if ((err.message || '').includes('no such table: stocks')) {
                                        console.warn('⚠️ Tabela stocks nu există în acest context - se ignoră inserția automată.');
                                        resolve();
                                        return;
                                    }
                                    reject(err);
                                } else {
                                    resolve();
                                }
                            }
                        );
                    });
                }
            }

            if (!ing.unit) {
                ing.unit = finalRecipeId ? 'buc' : 'g'; // Default pentru sub-rețete e 'buc'
            }

            await new Promise((resolve, reject) => {
                db.run(
                    `INSERT INTO recipes 
                        (product_id, ingredient_id, recipe_id, quantity_needed, unit, waste_percentage, variable_consumption, item_type, is_semi_finished, created_at)
                     VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP)`,
                    [
                        productId,
                        finalIngredientId,
                        finalRecipeId,
                        ing.quantity,
                        ing.unit,
                        ing.waste_percentage,
                        ing.variable_consumption,
                        ing.item_type
                    ],
                    function(err) {
                        if (err) {
                            console.error(`❌ Eroare la inserarea rețetei (ingredient_id=${finalIngredientId}):`, err);
                            reject(err);
                        } else {
                            resolve();
                        }
                    }
                );
            });

            ing.ingredient_id = finalIngredientId;
        }

        // STEP 3: Actualizăm și JSON-ul din menu.ingredients (pentru compatibilitate backwards)
        const ingredientsJson = JSON.stringify(
            normalizedIngredients.map((ing) => ({
                name: ing.name,
                ingredient_id: ing.ingredient_id,
                quantity: ing.quantity,
                unit: ing.unit,
                waste_percentage: ing.waste_percentage,
                variable_consumption: ing.variable_consumption,
                item_type: ing.item_type
            }))
        );
        await new Promise((resolve, reject) => {
            db.run('UPDATE menu SET ingredients = ? WHERE id = ?', [ingredientsJson, productId], function(err) {
                if (err) reject(err);
                else resolve(this.changes);
            });
        });

        console.log(`✅ Rețetă actualizată complet pentru product ${productId}`);

        // STEP 4: Recalculează alergenii automat pentru produsul actualizat
        let calculatedAllergens = null;
        try {
            calculatedAllergens = await calculateAndUpdateProductAllergens(productId, db);
            console.log(`✅ Alergeni recalculați automat pentru produsul #${productId}: ${calculatedAllergens || 'niciunul'}`);
        } catch (allergenError) {
            console.error(`⚠️ Eroare la calcularea alergenilor (nu blochează salvarea):`, allergenError.message);
        }

        // 🚀 Invalidează cache-ul pentru a reflecta modificările
        invalidateMenuCache();

        res.json({
            success: true,
            message: 'Rețeta a fost actualizată cu succes.',
            calculated_allergens: calculatedAllergens,
            allergens_recalculated: calculatedAllergens !== null
        });
    } catch (error) {
        console.error('❌ Eroare la salvarea rețetei (PUT /api/recipes/product):', error.message);
        res.status(500).json({ success: false, error: 'Eroare la salvarea datelor în baza de date: ' + error.message });
    }
});

