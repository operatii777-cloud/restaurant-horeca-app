    // ==================== ENDPOINT-URI CALENDAR AUTOMAT ====================

    // POST /api/admin/daily-menu/schedule - Creează programare meniul zilei
    // Creează programare meniu zilnic (cu RBAC)
    app.post('/api/admin/daily-menu/schedule', authenticateUser, requirePermission('menu:create'), (req, res) => {
      const { startDate, endDate, soupId, mainCourseId, discount } = req.body;

      if (!startDate || !endDate || !soupId || !mainCourseId) {
        return res.status(400).json({ error: 'All fields are required.' });
      }

      // Verifică suprapunerile
      db.get(`
        SELECT COUNT(*) as count FROM daily_menu_schedule 
        WHERE is_active = 1 AND (
          (start_date <= ? AND end_date >= ?) OR
          (start_date <= ? AND end_date >= ?) OR
          (start_date >= ? AND end_date <= ?)
        )
      `, [startDate, startDate, endDate, endDate, startDate, endDate], (err, row) => {
        if (err) {
          console.error('Error checking overlapping schedules:', err);
          return res.status(500).json({ error: err.message });
        }

        if (row.count > 0) {
          return res.status(400).json({ error: 'Există deja o programare activă pentru această perioadă.' });
        }

        const sql = `
          INSERT INTO daily_menu_schedule (start_date, end_date, soup_id, main_course_id, discount, is_active)
          VALUES (?, ?, ?, ?, ?, 1)
        `;

        db.run(sql, [startDate, endDate, soupId, mainCourseId, discount], function(err) {
          if (err) {
            console.error('Error creating daily menu schedule:', err);
            return res.status(500).json({ error: err.message });
          }

          res.json({ 
            message: 'Programarea meniului zilei a fost creată cu succes.', 
            id: this.lastID
          });
        });
      });
    });

    // GET /api/admin/daily-menu/schedule - Lista programări active
    // Obține programări meniu zilnic (cu RBAC)
    app.get('/api/admin/daily-menu/schedule', authenticateUser, requirePermission('menu:view'), (req, res) => {
      db.all(`
        SELECT s.*, 
               s1.name as soup_name, s1.price as soup_price,
               s2.name as main_course_name, s2.price as main_course_price
        FROM daily_menu_schedule s
        LEFT JOIN menu s1 ON s.soup_id = s1.id
        LEFT JOIN menu s2 ON s.main_course_id = s2.id
        WHERE s.is_active = 1
        ORDER BY s.start_date DESC
      `, [], (err, schedules) => {
        if (err) {
          console.error('Error fetching daily menu schedules:', err);
          return res.status(500).json({ error: err.message });
        }

        res.json({ schedules });
      });
    });

    // DELETE /api/admin/daily-menu/schedule/:id - Anulează programare
    // Șterge programare meniu zilnic (cu RBAC)
    app.delete('/api/admin/daily-menu/schedule/:id', authenticateUser, requirePermission('menu:delete'), (req, res) => {
      const { id } = req.params;
      
      const sql = `UPDATE daily_menu_schedule SET is_active = 0 WHERE id = ?`;
      
      db.run(sql, [id], function(err) {
        if (err) {
          console.error('Error canceling daily menu schedule:', err);
          return res.status(500).json({ error: err.message });
        }

        res.json({ 
          message: 'Programarea a fost anulată cu succes.',
          changes: this.changes
        });
      });
    });

    // ==================== ENDPOINT-URI EXCEPȚII ZILNICE ====================

    // POST /api/admin/daily-menu/exception - Creează excepție pentru o zi specifică
    // Creează excepție meniu zilnic (cu RBAC)
    app.post('/api/admin/daily-menu/exception', authenticateUser, requirePermission('menu:create'), (req, res) => {
      const { date, soupId, mainCourseId, discount } = req.body;

      if (!date || !soupId || !mainCourseId) {
        return res.status(400).json({ error: 'All fields are required.' });
      }

      const sql = `
        INSERT INTO daily_menu_exceptions (date, soup_id, main_course_id, discount, is_active)
        VALUES (?, ?, ?, ?, 1)
        ON CONFLICT(date) DO UPDATE SET
        soup_id = excluded.soup_id,
        main_course_id = excluded.main_course_id,
        discount = excluded.discount,
        is_active = 1
      `;

      db.run(sql, [date, soupId, mainCourseId, discount], function(err) {
        if (err) {
          console.error('Error saving daily menu exception:', err);
          return res.status(500).json({ error: err.message });
        }

        res.json({ 
          message: 'Excepția pentru meniul zilei a fost salvată cu succes.', 
          id: this.lastID,
          changes: this.changes
        });
      });
    });

    // GET /api/admin/daily-menu/exceptions - Lista excepții
    // Obține excepții meniu zilnic (cu RBAC)
    app.get('/api/admin/daily-menu/exceptions', authenticateUser, requirePermission('menu:view'), (req, res) => {
      db.all(`
        SELECT e.*, 
               s1.name as soup_name, s1.price as soup_price,
               s2.name as main_course_name, s2.price as main_course_price
        FROM daily_menu_exceptions e
        LEFT JOIN menu s1 ON e.soup_id = s1.id
        LEFT JOIN menu s2 ON e.main_course_id = s2.id
        WHERE e.is_active = 1
        ORDER BY e.date DESC
      `, [], (err, exceptions) => {
        if (err) {
          console.error('Error fetching daily menu exceptions:', err);
          return res.status(500).json({ error: err.message });
        }

        res.json({ exceptions });
      });
    });

    // DELETE /api/admin/daily-menu/exception/:id - Anulează excepție
    // Șterge excepție meniu zilnic (cu RBAC)
    app.delete('/api/admin/daily-menu/exception/:id', authenticateUser, requirePermission('menu:delete'), (req, res) => {
      const { id } = req.params;
      
      const sql = `UPDATE daily_menu_exceptions SET is_active = 0 WHERE id = ?`;
      
      db.run(sql, [id], function(err) {
        if (err) {
          console.error('Error canceling daily menu exception:', err);
          return res.status(500).json({ error: err.message });
        }

        res.json({ 
          message: 'Excepția a fost anulată cu succes.',
          changes: this.changes
        });
      });
    });

  }).catch(err => {
    console.error('Error initializing database:', err);
  });

  // CSV export for translations: creates files in public/translations
  async function exportTranslationsCSV() {
    try {
      const db = await dbPromise;
      const dir = path.join(__dirname, 'public', 'translations');
      if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });

      db.all('SELECT id, name, description, category, allergens, name_en, description_en, category_en, COALESCE(allergens_en, "") as allergens_en FROM menu ORDER BY id', [], (err, menuRows) => {
        if (!err) {
          const header = 'id;name;description;category;allergens;name_en;description_en;category_en;allergens_en\n';
          const lines = (menuRows || []).map(r => {
            const cells = [r.id, r.name, r.description || '', r.category || '', r.allergens || '', r.name_en || '', r.description_en || '', r.category_en || '', r.allergens_en || ''];
            return cells.map(v => '"' + String(v).replace(/"/g, '""') + '"').join(';');
          });
          fs.writeFileSync(path.join(dir, 'menu_en.csv'), header + lines.join('\n'));
        }
      });

      db.all('SELECT id, menu_item_id, option_name, option_type, extra_price, option_name_en FROM customization_options ORDER BY id', [], (err, optRows) => {
        if (!err) {
          const header = 'id;menu_item_id;option_name;option_type;extra_price;option_name_en\n';
          const lines = (optRows || []).map(r => {
            const cells = [r.id, r.menu_item_id, r.option_name || '', r.option_type || '', r.extra_price || 0, r.option_name_en || ''];
            return cells.map(v => '"' + String(v).replace(/"/g, '""') + '"').join(';');
          });
          fs.writeFileSync(path.join(dir, 'customizations_en.csv'), header + lines.join('\n'));
        }
      });
      console.log('Exported translation CSVs to /public/translations');
    } catch (e) {
      console.error('Failed exporting translation CSVs:', e);
    }
  }

  function parseCSV(content) {
    const lines = content.split(/\r?\n/).filter(l => l.trim().length > 0);
    if (lines.length === 0) return [];
    const headers = lines[0].split(';').map(h => h.replace(/^"|"$/g, ''));
    const rows = [];
    for (let i = 1; i < lines.length; i++) {
      const raw = lines[i];
      const cells = raw.split(';').map(c => c.replace(/^"|"$/g, '').replace(/""/g, '"'));
      const obj = {};
      headers.forEach((h, idx) => { obj[h] = cells[idx] !== undefined ? cells[idx] : ''; });
      rows.push(obj);
    }
    return rows;
  }

  async function importMenuTranslationsCSV(db) {
    const file = path.join(__dirname, 'public', 'translations', 'menu_en.csv');
    if (!fs.existsSync(file)) return false;
    const content = fs.readFileSync(file, 'utf-8');
    const rows = parseCSV(content);
    for (const r of rows) {
      const id = parseInt(r.id, 10);
      if (!id) continue;
      const name_en = (r.name_en || '').trim();
      const description_en = (r.description_en || '').trim();
      const category_en = (r.category_en || '').trim();
      const allergens_en = (r.allergens_en || '').trim();
      if (!name_en && !description_en && !category_en && !allergens_en) continue;
      await new Promise(resolve => {
        db.run('UPDATE menu SET name_en = COALESCE(NULLIF(?, ""), name_en), description_en = COALESCE(NULLIF(?, ""), description_en), category_en = COALESCE(NULLIF(?, ""), category_en), allergens_en = COALESCE(NULLIF(?, ""), allergens_en) WHERE id = ?',
          [name_en, description_en, category_en, allergens_en, id], () => resolve());
      });
    }
    return true;
  }

  async function importCustomizationTranslationsCSV(db) {
    const file = path.join(__dirname, 'public', 'translations', 'customizations_en.csv');
    if (!fs.existsSync(file)) return false;
    const content = fs.readFileSync(file, 'utf-8');
    const rows = parseCSV(content);
    for (const r of rows) {
      const id = parseInt(r.id, 10);
      if (!id) continue;
      const option_name_en = (r.option_name_en || '').trim();
      if (!option_name_en) continue;
      await new Promise(resolve => {
        db.run('UPDATE customization_options SET option_name_en = COALESCE(NULLIF(?, ""), option_name_en) WHERE id = ?',
          [option_name_en, id], () => resolve());
      });
    }
    return true;
  }

  async function importTranslationsCSV() {
    try {
      const db = await dbPromise;
      const dir = path.join(__dirname, 'public', 'translations');
      let anyImported = false;
      if (fs.existsSync(dir)) {
        const a = await importMenuTranslationsCSV(db);
        const b = await importCustomizationTranslationsCSV(db);
        anyImported = a || b;
      }
      if (!anyImported) {
        await exportTranslationsCSV();
      }
    } catch (e) {
      console.error('Import translations failed:', e);
    }
  }
  
