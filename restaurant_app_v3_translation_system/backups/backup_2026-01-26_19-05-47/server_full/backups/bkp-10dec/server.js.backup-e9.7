                            try {
                                items = JSON.parse(cleanedItems);
                            } catch (secondError) {
                                continue; // Sări peste această comandă dacă nu poate fi parsată
                            }
                        }
                        
                        if (!Array.isArray(items)) continue;
                        
                        for (const item of items) {
                            if (!item.productId || !item.quantity) continue;
                            
                            // Găsește rețeta pentru produs folosind map-ul
                            const key = `${item.productId}_${ingredient.id}`;
                            const quantityNeeded = recipeMap.get(key);
                            
                            if (quantityNeeded) {
                                const consumption = quantityNeeded * item.quantity;
                                totalConsumption += consumption;
                            }
                        }
                
                        // Contorizează zilele cu comenzi
                        const orderDate = new Date(order.timestamp || Date.now()).toISOString().slice(0, 10);
                        if (!processedDays.has(orderDate)) {
                            processedDays.add(orderDate);
                            daysWithOrders++;
                        }
                        
                    } catch (parseError) {
                        // Nu mai logăm fiecare eroare pentru a evita spam-ul
                        continue;
                    }
                }
                
                const avgDailyConsumption = daysWithOrders > 0 ? totalConsumption / daysWithOrders : 0;
                
                
                return {
                    ...ingredient,
                    avg_daily_consumption: Math.round(avgDailyConsumption * 100) / 100
                };
                
            } catch (error) {
                console.error(`❌ Eroare la calculul consumului pentru ${ingredient.name}:`, error);
                return {
                    ...ingredient,
                    avg_daily_consumption: 0
                };
            }
        });
        
        const predictions = ingredientsWithConsumption.map(ingredient => {
            const avgDailyConsumption = ingredient.avg_daily_consumption || 0;
            const currentStock = ingredient.current_stock || 0;
            const predictedStock = Math.max(0, currentStock - (avgDailyConsumption * daysAhead));
            
            let daysUntilEmpty = null;
            if (avgDailyConsumption > 0) {
                daysUntilEmpty = Math.floor(currentStock / avgDailyConsumption);
            }
            
            let status = 'ok';
            let recommendedOrder = 0;
            
            if (daysUntilEmpty !== null && daysUntilEmpty <= daysAhead) {
                status = daysUntilEmpty <= 3 ? 'will_be_empty' : 'will_be_low';
                recommendedOrder = Math.max(0, (avgDailyConsumption * 7) - currentStock); // Comandă pentru 7 zile
            }
            
            return {
                ingredient_id: ingredient.id,
                name: ingredient.name,
                unit: ingredient.unit,
                current_stock: currentStock,
                min_stock: ingredient.min_stock,
                avg_daily_consumption: avgDailyConsumption,
                predicted_stock: predictedStock,
                days_until_empty: daysUntilEmpty,
                status: status,
                recommended_order: recommendedOrder
            };
        });
        
        res.json({
            days_ahead: daysAhead,
            analysis_period: '30 days',
            predictions: predictions
        });
        
    } catch (error) {
        console.error('❌ Eroare la generarea predicției stoc:', error);
        res.status(500).json({ error: 'Eroare la generarea predicției stoc' });
    }
});

