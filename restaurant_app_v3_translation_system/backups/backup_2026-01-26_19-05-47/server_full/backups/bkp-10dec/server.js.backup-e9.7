// Servește index.html pentru toate rutele React Router (Admin V4)
// Acest catch-all permite refresh-ul paginilor React Router fără erori 404
if (fs.existsSync(adminViteDistPath)) {
  const adminViteIndexPath = path.join(adminViteDistPath, 'index.html');
  
  // Handle favicon.ico - serve empty response to avoid 404
  app.get('/favicon.ico', (req, res) => {
    res.status(204).end();
  });
  
  // ========================================
  // 🖥️ KIOSK API ROUTES (ÎNAINTE DE CATCH-ALL!)
  // ========================================
  
  // Obține statusul meselor pentru KIOSK
  // Logica simplificată: dacă nu există comandă activă, masa este liberă
  app.get('/api/admin/tables/status', (req, res) => {
    dbPromise.then(db => {
      // Tabelul orders folosește coloana "timestamp" nu "created_at"
      // De asemenea, folosește "table_number" nu "table_id"
      db.all(`
        SELECT 
          o.id as order_id,
          o.table_number as table_id,
          o.status as order_status,
          o.is_paid,
          o.timestamp as created_at,
          (julianday('now') - julianday(o.timestamp)) * 24 * 60 as minutes_elapsed
        FROM orders o
        WHERE o.is_paid = 0 
          AND o.status NOT IN ('cancelled', 'completed')
          AND o.timestamp > datetime('now', '-4 hours')
      `, (err, activeOrders) => {
        if (err) {
          console.error('❌ Eroare la obținerea comenzilor active:', err);
          return res.status(500).json({ success: false, error: err.message });
        }

        // Creează map pentru comenzile active pe fiecare masă
        const ordersByTable = {};
        if (activeOrders && activeOrders.length > 0) {
          activeOrders.forEach(order => {
            const tableNum = parseInt(order.table_id) || order.table_id;
            if (!ordersByTable[tableNum]) {
              ordersByTable[tableNum] = [];
            }
            ordersByTable[tableNum].push(order);
          });
        }

        // Construiește răspunsul cu status pentru toate mesele 1-30
        // Dacă nu există comandă activă pentru o masă, ea este automat "free"
        const tablesStatus = [];
        for (let i = 1; i <= 30; i++) {
          const order = ordersByTable[i]?.[0]; // Prima comandă activă

          let status = 'free';
          let order_id = null;
          let timer = null;

          if (order) {
            status = 'occupied';
            order_id = order.order_id;
            timer = Math.floor(order.minutes_elapsed || 0);
          }

          tablesStatus.push({
            number: i,
            status: status,
            order_id: order_id,
            timer: timer
          });
        }

        res.json({ 
          success: true,
          tables: tablesStatus 
        });
      });
    }).catch(error => {
      console.error('❌ Eroare la obținerea statusului meselor:', error);
      res.status(500).json({ success: false, error: error.message || 'Eroare la obținerea statusului meselor' });
    });
  });
  
  // Catch-all pentru toate rutele React Router (Admin V4)
  // Această rută trebuie să fie ULTIMA înainte de static files și 404 handler
  app.get('*', asyncHandler((req, res, next) => {
    const path = req.path;
    
    // ========================================
    // BEGIN: SAFE FIX — SPA bypass for API and static assets (PHASE 5)
    // ========================================
    // IMPORTANT: Prevent React Router from intercepting API requests and static assets
    // This ensures API endpoints and assets are handled by Express, not React Router
    if (path.startsWith('/api/')) return next();
    if (path.match(/\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|map)$/i)) return next();
    // ========================================
    // END: SAFE FIX — SPA bypass for API and static assets (PHASE 5)
    // ========================================
    
    // Skip pentru API endpoints (legacy check - kept for compatibility)
    if (path.startsWith('/api/')) {
      return next();
    }
    
    // Skip pentru fișiere statice (cu extensie) - dar nu pentru favicon.ico (handled above)
    if (path.match(/\.(js|css|json|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map|webp|txt|xml|pdf)$/i)) {
      return next();
    }
    
    // Skip pentru rute speciale HTML (admin.html, dashboard.html, etc.)
    if (path.match(/\.(html)$/i)) {
      return next();
    }
    
    // Skip pentru rutele deja definite explicit (admin, dashboard, adminv4, kiosk, etc.)
    // Acestea au rute proprii definite mai sus
    if (path === '/admin' || path === '/dashboard' || path === '/adminv4' || 
        path === '/adminv4.html' || path === '/admin-v4.html' ||
        path === '/kiosk' || path === '/kiosk.html') {
      return next();
    }
    
    // Skip pentru rutele publice (comanda.html, etc.)
    if (path.startsWith('/comanda') || path.startsWith('/public')) {
      return next();
    }
    
    // Pentru rutele /admin-vite/* - servește index.html pentru React Router
    // Assets-urile (CSS, JS, imagini) sunt deja servite de express.static('/admin-vite')
    if (path.startsWith('/admin-vite/')) {
      // Verifică dacă este un asset (are extensie de fișier)
      const isAsset = /\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|json|map)$/i.test(path);
      if (isAsset) {
        // Assets-urile sunt servite de express.static, deci continuă
        return next();
      }
      // Pentru rutele React Router (fără extensie), servește index.html
      if (fs.existsSync(adminViteIndexPath)) {
        console.log(`🧩 [React Router] Servește index.html pentru ruta: ${path}`);
        res.setHeader('Cache-Control', 'no-cache, no-store, must-revalidate');
        res.setHeader('Content-Type', 'text/html; charset=utf-8');
        return res.sendFile(adminViteIndexPath);
      } else {
        console.warn(`⚠️ [React Router] index.html nu există la: ${adminViteIndexPath}`);
        return next();
      }
    }
    
    // Servește index.html pentru TOATE celelalte rute (React Router - /menu, /catalog, /recipes, etc.)
    // Aceasta permite refresh-ul fără erori 404
    if (fs.existsSync(adminViteIndexPath)) {
      console.log(`🧩 [React Router] Servește index.html pentru ruta: ${path}`);
      res.setHeader('Cache-Control', 'no-cache, no-store, must-revalidate');
      res.setHeader('Content-Type', 'text/html; charset=utf-8');
      res.sendFile(adminViteIndexPath);
    } else {
      console.warn(`⚠️ [React Router] index.html nu există la: ${adminViteIndexPath}`);
      next();
    }
  }));
}

