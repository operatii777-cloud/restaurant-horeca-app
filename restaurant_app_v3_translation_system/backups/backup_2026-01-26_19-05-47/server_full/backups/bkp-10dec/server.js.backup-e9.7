    try {
      const { username, password, mfaToken } = req.body;
      
      if (!username || !password) {
        return res.status(400).json({ error: 'Username și parola sunt obligatorii' });
      }
      
      const user = await getUserByUsername(username);
      if (!user) {
        return res.status(401).json({ error: 'Credențiale invalide' });
      }
      
      // ✅ SĂPTĂMÂNA 1 - SECURITATE: Verificare parolă cu Argon2id (sau bcrypt fallback)
      const isValid = await verifyPassword(password, user.password_hash);
      if (!isValid) {
        return res.status(401).json({ error: 'Credențiale invalide' });
      }
      
      // ✅ MFA: Verifică dacă utilizatorul are MFA activat
      const mfaInfo = await getUserMfaSecret(user.id);
      if (mfaInfo && mfaInfo.mfa_enabled) {
        // MFA activat - necesită token MFA
        if (!mfaToken) {
          return res.status(200).json({
            success: false,
            requiresMfa: true,
            message: 'Cod MFA necesar'
          });
        }
        
        // Verifică token MFA
        const speakeasy = require('speakeasy');
        const verified = speakeasy.totp.verify({
          secret: mfaInfo.mfa_secret,
          encoding: 'base32',
          token: mfaToken,
          window: 2 // Permite 60 sec înainte/după
        });
        
        if (!verified) {
          return res.status(401).json({ error: 'Cod MFA invalid' });
        }
      }
      
      // Generează token de sesiune
      const sessionToken = require('crypto').randomBytes(32).toString('hex');
      const expiresAt = new Date(Date.now() + 24 * 60 * 60 * 1000); // 24 ore
      
      await createSession(user.id, sessionToken, expiresAt);
      
      // Actualizează ultima autentificare
      const db = await dbPromise;
      db.run('UPDATE users SET last_login = CURRENT_TIMESTAMP WHERE id = ?', [user.id]);
      
      // Log audit pentru login
      await logAuditEvent(
        user.id,
        'LOGIN',
        'user',
        user.id,
        null,
        JSON.stringify({ username: user.username, ip: req.ip }),
        req.ip,
        req.get('User-Agent')
      );
      
      res.json({
        success: true,
        user: {
          id: user.id,
          username: user.username,
          email: user.email,
          role_name: user.role_name,
          role_description: user.role_description
        },
        sessionToken: sessionToken,
        expiresAt: expiresAt
      });
    } catch (error) {
