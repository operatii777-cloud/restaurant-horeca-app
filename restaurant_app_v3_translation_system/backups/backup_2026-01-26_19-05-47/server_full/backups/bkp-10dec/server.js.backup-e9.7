  app.get('/api/orders-completed', (req, res) => {
    const { filter, lang = 'ro' } = req.query; // 'all', 'unpaid', 'paid'
    const currentLang = lang.toLowerCase();
    
    // Include toate comenzile completate și livrate
    let whereClause = 'WHERE (status = "completed" OR status = "delivered")';
    if (filter === 'unpaid') {
      whereClause += ' AND is_paid = 0';
    } else if (filter === 'paid') {
      whereClause += ' AND is_paid = 1';
    }
    
    db.all(`SELECT * FROM orders ${whereClause} ORDER BY completed_timestamp ASC`, (err, rows) => {
      if (err) { return res.status(500).json({ error: err.message }); }
      
      const promises = rows.map(order => {
        return new Promise((resolve, reject) => {
            const items = safeParseItems(order.items);
          const itemPromises = items.map(item => {
            return new Promise((resolveItem, rejectItem) => {
              const sel = currentLang === 'en' ? 'SELECT name_en, name, price FROM menu WHERE id = ?' : 'SELECT name, price FROM menu WHERE id = ?';
              db.get(sel, [item.productId], (itemErr, p) => {
                if (itemErr) return rejectItem(itemErr);
                let productName = 'Produs șters';
                if (p && p.name) {
                  if (currentLang === 'en') {
                    productName = (p.name_en && String(p.name_en).trim()) ? p.name_en : translateRoToEn(p.name);
                  } else {
                    productName = p.name;
                  }
                }
                resolveItem({ ...item, name: productName, price: p ? p.price : 0 });
              });
            });
          });
          Promise.all(itemPromises)
            .then(enriched => resolve(formatOrderTimestamps({ ...order, items: enriched })))
            .catch(reject);
        });
      });
      
      Promise.all(promises).then(orders => {
        // Grupează comenzile după masă și client
        const groups = {};
        orders.forEach(order => {
          const key = `${order.table_number}_${order.client_identifier}`;
          if (!groups[key]) {
            groups[key] = {
              tableNumber: order.table_number,
              clientIdentifier: order.client_identifier,
              orders: [],
              totalAmount: 0,
              totalItems: 0,
              isPaid: order.is_paid,
              status: order.is_paid ? 'paid' : 'unpaid',
              firstOrderTime: order.completed_timestamp,
              lastOrderTime: order.completed_timestamp
            };
          }
          
          groups[key].orders.push(order);
          groups[key].totalAmount += order.items.reduce((sum, item) => sum + (item.finalPrice * item.quantity), 0);
          groups[key].totalItems += order.items.reduce((sum, item) => sum + item.quantity, 0);
          groups[key].isPaid = groups[key].isPaid && order.is_paid;
          groups[key].status = groups[key].isPaid ? 'paid' : 'unpaid';
          
          // Actualizează timpul primului și ultimului ordin
          if (new Date(order.completed_timestamp) < new Date(groups[key].firstOrderTime)) {
            groups[key].firstOrderTime = order.completed_timestamp;
          }
          if (new Date(order.completed_timestamp) > new Date(groups[key].lastOrderTime)) {
            groups[key].lastOrderTime = order.completed_timestamp;
          }
        });
        
        // Convertește obiectul în array și sortează cronologic
        const groupedOrders = Object.values(groups).sort((a, b) => 
          new Date(b.lastOrderTime) - new Date(a.lastOrderTime)
        );
        
        res.json({ groups: groupedOrders, orders: orders });
      }).catch(err => res.status(500).json({ error: err.message }));
    });
  });

