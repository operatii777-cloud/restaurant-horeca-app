                    i.name as ingredient_name
                FROM recipes r
                LEFT JOIN ingredients i ON r.ingredient_id = i.id
                WHERE r.product_id = ? AND r.item_type = 'ingredient'
            `, [productId], (err, rows) => {
                if (err) reject(err);
                else resolve(rows || []);
            });
        });
        
        if (recipes.length === 0) {
            return res.status(404).json({ error: 'Rețeta nu a fost găsită pentru acest produs' });
        }
        
        const scaledIngredients = [];
        
        // Scalează fiecare ingredient
        for (const recipe of recipes) {
            const newQuantity = recipe.quantity_needed * scaleFactor;
            
            // Actualizează în baza de date
            await new Promise((resolve, reject) => {
                db.run(`
                    UPDATE recipes 
                    SET quantity_needed = ?
                    WHERE id = ?
                `, [newQuantity, recipe.id], (err) => {
                    if (err) reject(err);
                    else resolve();
                });
            });
            
            scaledIngredients.push({
                name: recipe.ingredient_name || `Ingredient ${recipe.ingredient_id}`,
                originalQuantity: recipe.quantity_needed,
                originalUnit: recipe.unit,
                scaledQuantity: newQuantity,
                scaledUnit: recipe.unit
            });
        }
        
        // Recalculează costul rețetei
        const { calculateRecipeCostRecursive } = require('./helpers/recipe-helpers');
        const newCost = await calculateRecipeCostRecursive(productId);
        
        // Actualizează cost_price în menu
        await new Promise((resolve, reject) => {
            db.run('UPDATE menu SET cost_price = ? WHERE id = ?', [newCost, productId], (err) => {
                if (err) reject(err);
                else resolve();
            });
        });
        
        res.json({
            success: true,
            message: `Rețeta scalată cu succes cu factorul ${scaleFactor}x`,
            scaledIngredients,
            newCost
        });
        
    } catch (error) {
        console.error('❌ Eroare la scalarea rețetei:', error);
        res.status(500).json({ error: 'Eroare la scalarea rețetei', details: error.message });
    }
});

