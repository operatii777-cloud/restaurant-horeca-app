// POST /api/admin/inventory/import-invoice - Importă factură PDF/XML
app.post('/api/admin/inventory/import-invoice', checkAdminAuth, async (req, res) => {
  try {
    const { invoice_number, supplier_name, invoice_date, total_amount, file_type, parsed_data } = req.body;
    
    if (!invoice_number || !supplier_name || !invoice_date || !total_amount) {
      return res.status(400).json({ 
        success: false, 
        error: 'Lipsește invoice_number, supplier_name, invoice_date sau total_amount' 
      });
    }

    const db = await dbPromise;
    
    // Verificăm dacă factura există deja
    const existingInvoice = await new Promise((resolve, reject) => {
      db.get('SELECT id FROM supplier_invoices WHERE invoice_number = ?', [invoice_number], (err, row) => {
        if (err) reject(err);
        else resolve(row);
      });
    });

    if (existingInvoice) {
      return res.status(400).json({ 
        success: false, 
        error: 'Factura cu acest număr există deja' 
      });
    }

    // Adăugăm factura în baza de date
    const invoiceId = await new Promise((resolve, reject) => {
      db.run(`
        INSERT INTO supplier_invoices (
          invoice_number, supplier_name, invoice_date, total_amount, 
          file_type, parsed_data, status
        ) VALUES (?, ?, ?, ?, ?, ?, 'pending')
      `, [invoice_number, supplier_name, invoice_date, total_amount, file_type, parsed_data], function(err) {
        if (err) reject(err);
        else resolve(this.lastID);
      });
    });

    res.json({
      success: true,
      message: 'Factura a fost importată cu succes',
      invoice_id: invoiceId,
      status: 'pending'
    });
    
  } catch (error) {
    console.error('Eroare la importul facturii:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Eroare la importul facturii' 
    });
  }
});

