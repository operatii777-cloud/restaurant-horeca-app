// POST /api/marketing/auto-segment - Segmentare automată a clienților
app.post('/api/marketing/auto-segment', checkAdminAuth, async (req, res) => {
    try {
        console.log('🔄 Începere segmentare automată clienți...');
        const db = await dbPromise;
        
        // Obține toate comenzile din ultima lună pentru analiză
        const thirtyDaysAgo = new Date();
        thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
        const startDateStr = thirtyDaysAgo.toISOString();
        
        console.log('📅 Analiză pentru perioada:', startDateStr, 'până astăzi');
        
        // Analizează clienții pe baza comenzilor (abordare simplificată)
        const customerAnalysisQuery = `
            SELECT 
                client_identifier as customer_token,
                COUNT(*) as order_count,
                MAX(timestamp) as last_order_date,
                MIN(timestamp) as first_order_date
            FROM orders 
            WHERE client_identifier IS NOT NULL 
            AND client_identifier != ''
            AND timestamp >= datetime('now', '-30 days')
            AND status IN ('completed', 'paid', 'delivered')
            GROUP BY client_identifier
            HAVING order_count > 0
            ORDER BY order_count DESC
        `;
        
        console.log('🔍 Executare query pentru analiza clienților...');
        console.log('📝 Query:', customerAnalysisQuery);
        
        const customers = await new Promise((resolve, reject) => {
            db.all(customerAnalysisQuery, (err, rows) => {
                if (err) {
                    console.error('❌ Eroare la query:', err);
                    reject(err);
                } else {
                    console.log('📊 Rezultat query:', rows);
                    resolve(rows || []);
                }
            });
        });
        
        console.log('👥 Clienți găsiți:', customers.length);
        console.log('🔍 Tipul datelor customers:', typeof customers, Array.isArray(customers));
        console.log('📊 Primul client (dacă există):', customers[0]);
        
        // Asigură-te că customers este un array
        const customersArray = Array.isArray(customers) ? customers : [];
        console.log('👥 Clienți array:', customersArray.length);
        
        if (customersArray.length === 0) {
            console.log('⚠️ Nu au fost găsiți clienți pentru segmentare');
            return res.json({
                success: true,
                message: 'Nu au fost găsiți clienți pentru segmentare',
                segments: []
            });
        }
        
        // Calculează pragurile pentru segmentare bazate pe numărul de comenzi
        const avgOrders = customersArray.reduce((sum, c) => sum + c.order_count, 0) / customersArray.length;
        console.log('📊 Media comenzilor per client:', avgOrders.toFixed(2));
        
        // Definește segmentele bazate pe numărul de comenzi
        const segments = {
            vip: {
                name: 'VIP Customers',
                description: 'Clienți cu multe comenzi și fidelitate ridicată',
                criteria: { min_orders: Math.max(3, Math.ceil(avgOrders * 2)) },
                customers: []
            },
            regular: {
                name: 'Regular Customers',
                description: 'Clienți obișnuiți cu activitate moderată',
                criteria: { min_orders: Math.max(2, Math.ceil(avgOrders * 0.5)), max_orders: Math.ceil(avgOrders * 2) },
                customers: []
            },
            new: {
                name: 'New Customers',
                description: 'Clienți noi sau cu activitate redusă',
                criteria: { max_orders: Math.max(1, Math.ceil(avgOrders * 0.5)) },
                customers: []
            }
        };
        
        console.log('🎯 Criterii segmentare:', {
            vip_min: segments.vip.criteria.min_orders,
            regular_min: segments.regular.criteria.min_orders,
            regular_max: segments.regular.criteria.max_orders,
            new_max: segments.new.criteria.max_orders
        });
        
        // Clasifică clienții în segmente
        customersArray.forEach(customer => {
            const customerData = {
                customer_token: customer.customer_token,
                order_count: customer.order_count,
                last_order_date: customer.last_order_date,
                first_order_date: customer.first_order_date
            };
            
            if (customer.order_count >= segments.vip.criteria.min_orders) {
                segments.vip.customers.push(customerData);
            } else if (customer.order_count >= segments.regular.criteria.min_orders && 
                       customer.order_count < segments.regular.criteria.max_orders) {
                segments.regular.customers.push(customerData);
            } else {
                segments.new.customers.push(customerData);
            }
        });
        
        console.log('📈 Rezultate segmentare:', {
            vip: segments.vip.customers.length,
            regular: segments.regular.customers.length,
            new: segments.new.customers.length
        });
        
        // Salvează segmentele în baza de date
        console.log('💾 Salvare segmente în baza de date...');
        for (const [segmentKey, segment] of Object.entries(segments)) {
            const criteriaJson = JSON.stringify(segment.criteria);
            const customersJson = JSON.stringify(segment.customers.map(c => c.customer_token));
            
            await db.run(`
                INSERT OR REPLACE INTO customer_segments 
                (name, description, criteria_json, customer_tokens_json, last_calculated)
                VALUES (?, ?, ?, ?, CURRENT_TIMESTAMP)
            `, [segment.name, segment.description, criteriaJson, customersJson]);
        }
        
        console.log('✅ Segmentarea automată completată cu succes');
        
        res.json({
            success: true,
            message: 'Segmentarea automată a fost completată cu succes',
            analysis_period: '30 days',
            total_customers: customersArray.length,
            segments: {
                vip_count: segments.vip.customers.length,
                regular_count: segments.regular.customers.length,
                new_count: segments.new.customers.length
            },
            avg_orders: avgOrders.toFixed(2)
        });
        
    } catch (error) {
        console.error('❌ Eroare la segmentarea automată:', error);
        console.error('❌ Stack trace:', error.stack);
        res.status(500).json({ error: 'Eroare la segmentarea automată: ' + error.message });
    }
});

