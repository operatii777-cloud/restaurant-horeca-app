// POST /api/admin/prices/bulk-update/preview - Preview actualizare în masă
app.post('/api/admin/prices/bulk-update/preview', checkAdminAuth, asyncHandler(async (req, res) => {
  try {
    const db = await dbPromise;
    const { type, value, product_ids, filter } = req.body;
    
    // Obține produsele
    let productsQuery = 'SELECT id, name, price FROM menu WHERE 1=1';
    const productsParams = [];
    
    if (product_ids && Array.isArray(product_ids) && product_ids.length > 0) {
      const placeholders = product_ids.map(() => '?').join(',');
      productsQuery += ` AND id IN (${placeholders})`;
      productsParams.push(...product_ids);
    } else if (filter) {
      productsQuery += ' AND name LIKE ?';
      productsParams.push(`%${filter}%`);
    }
    
    const products = await allAsync(db, productsQuery, productsParams);
    
    // Calculează prețurile noi
    const preview = products.map((product) => {
      let newPrice = product.price;
      let change = 0;
      
      if (type === 'percentage') {
        const percent = parseFloat(value) || 0;
        change = product.price * (percent / 100);
        newPrice = product.price + change;
      } else if (type === 'fixed') {
        change = parseFloat(value) || 0;
        newPrice = product.price + change;
      } else if (type === 'formula') {
        // Pentru formulă, folosim un multiplicator simplu pentru moment
        // În viitor, poate fi implementat un parser de formule
        const multiplier = parseFloat(value.replace(/[^0-9.]/g, '')) || 2.5;
        // Presupunem că avem cost_price în produs (dacă există)
        const costPrice = product.cost_price || product.price / 2;
        newPrice = costPrice * multiplier;
        change = newPrice - product.price;
      }
      
      const changePercent = product.price > 0 ? (change / product.price) * 100 : 0;
      
      return {
        product_id: product.id,
        product_name: product.name,
        current_price: product.price,
        new_price: Math.max(0, newPrice),
        change: change,
        change_percent: changePercent,
      };
    });
    
    res.json({ success: true, data: preview });
  } catch (error) {
    console.error('❌ Eroare la preview actualizare:', error);
    console.error('📚 Stack Trace:', error.stack);
    res.status(500).json({ error: error.message || 'Eroare la preview' });
  }
}));

// POST /api/admin/prices/bulk-update - Aplicare actualizare în masă
app.post('/api/admin/prices/bulk-update', checkAdminAuth, asyncHandler(async (req, res) => {
  try {
    const db = await dbPromise;
    const { updates } = req.body;
    
    if (!Array.isArray(updates) || updates.length === 0) {
      return res.status(400).json({ error: 'Lista de actualizări este goală' });
    }
    
    await runAsync(db, 'BEGIN TRANSACTION');
    
    let successCount = 0;
    const errors = [];
    
    for (const update of updates) {
      try {
        const { product_id, new_price, reason } = update;
        
        if (!product_id || new_price === undefined) {
          errors.push(`Actualizare invalidă pentru produs ${product_id}`);
          continue;
        }
        
        // Obține prețul vechi
        const product = await getAsync(db, 'SELECT id, name, price FROM menu WHERE id = ?', [product_id]);
        
        if (!product) {
          errors.push(`Produs ${product_id} nu există`);
          continue;
        }
        
        const oldPrice = product.price;
        
        // Actualizează prețul
        await runAsync(
          db,
          'UPDATE menu SET price = ?, updated_at = datetime("now", "localtime") WHERE id = ?',
          [new_price, product_id]
        );
        
        // Salvează în istoric
        await runAsync(
          db,
          `INSERT INTO price_history (product_id, old_price, new_price, change_reason, change_type, changed_by)
           VALUES (?, ?, ?, ?, 'bulk_update', ?)`,
          [product_id, oldPrice, new_price, reason || 'Actualizare în masă', req.user?.username || 'Admin']
        );
        
        successCount++;
      } catch (err) {
        errors.push(`Eroare la produs ${update.product_id}: ${err.message || err}`);
      }
    }
    
    await runAsync(db, 'COMMIT');
    
    res.json({
      success: true,
      updated: successCount,
      errors: errors.length > 0 ? errors : undefined,
    });
  } catch (error) {
    await runAsync(db, 'ROLLBACK').catch(() => {});
    console.error('❌ Eroare la actualizare în masă:', error);
    console.error('📚 Stack Trace:', error.stack);
    res.status(500).json({ error: error.message || 'Eroare la actualizare în masă' });
  }
}));

