app.post('/api/admin/nir', checkAdminAuth, async (req, res) => {
  const { supplier_id, document_number, document_date, notes, lines } = req.body || {};

  const normalizedDocumentNumber =
    typeof document_number === 'string' ? document_number.trim() : '';
  const normalizedDocumentDate =
    typeof document_date === 'string' ? document_date.trim() : '';

  if (!normalizedDocumentNumber) {
    return res.status(400).json({ error: 'Numărul documentului este obligatoriu.' });
  }
  if (!normalizedDocumentDate) {
    return res.status(400).json({ error: 'Data documentului este obligatorie.' });
  }

  let sanitizedLines;
  try {
    sanitizedLines = sanitizeNirLinesPayload(lines);
  } catch (payloadError) {
    console.error('❌ Payload invalid pentru NIR:', payloadError.message);
    return res
      .status(payloadError.statusCode || 400)
      .json({ error: payloadError.message });
  }

  const totals = sanitizedLines.reduce(
    (acc, line) => {
      acc.value += line.total_line;
      acc.tva += line.total_tva_line;
      return acc;
    },
    { value: 0, tva: 0 }
  );

  const totalValue = roundNumber(totals.value, 2);
  const totalTva = roundNumber(totals.tva, 2);
  const supplierIdValue = supplier_id ? toPositiveInt(supplier_id) : null;
  const normalizedNotes = typeof notes === 'string' && notes.trim() ? notes.trim() : null;

  try {
    const db = await dbPromise;
    let transactionActive = false;

    try {
      await runAsync(db, 'BEGIN TRANSACTION');
      transactionActive = true;

      const headerResult = await runAsync(
        db,
        `
          INSERT INTO nir_headers (
            supplier_id,
            document_number,
            document_date,
            total_value,
            total_tva,
            notes
          ) VALUES (?, ?, ?, ?, ?, ?)
        `,
        [
          supplierIdValue,
          normalizedDocumentNumber,
          normalizedDocumentDate,
          totalValue,
          totalTva,
          normalizedNotes,
        ]
      );

      const nirId = headerResult.lastID;

      for (const line of sanitizedLines) {
        const generatedLot =
          line.lot_number || `NIR-${nirId}-${line.ingredient_id}-${line.line_index + 1}`;

        await runAsync(
          db,
          `
            INSERT INTO nir_lines (
              nir_id,
              ingredient_id,
              quantity,
              unit_price,
              tva_percent,
              total_line,
              total_tva_line,
              lot_number
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
          `,
          [
            nirId,
            line.ingredient_id,
            line.quantity,
            line.unit_price,
            line.tva_percent,
            line.total_line,
            line.total_tva_line,
            generatedLot,
          ]
        );

        await runAsync(
          db,
          `UPDATE ingredients SET current_stock = COALESCE(current_stock, 0) + ? WHERE id = ?`,
          [line.quantity, line.ingredient_id]
        );

        await createStockMove({
          tenant_id: DEFAULT_TENANT_ID,
          ingredient_id: line.ingredient_id,
          qty: line.quantity,
          direction: 'IN',
          reason: STOCK_MOVE_REASON.NIR_IN,
          source: STOCK_MOVE_SOURCE.NIR,
          reference_type: 'NIR',
          reference_id: nirId,
          unit_price: line.unit_price,
          value: line.total_line,
          tva_percent: line.tva_percent,
          meta: {
            document_number: normalizedDocumentNumber,
            document_date: normalizedDocumentDate,
          },
        });

        await runAsync(
          db,
          `
            INSERT INTO stock_lots (
              ingredient_id,
              lot_number,
              quantity_remaining,
              unit_price,
              tva_percent
            ) VALUES (?, ?, ?, ?, ?)
          `,
          [line.ingredient_id, generatedLot, line.quantity, line.unit_price, line.tva_percent]
        );
      }

      await runAsync(db, 'COMMIT');
      transactionActive = false;

      res.json({
        success: true,
        nir_id: nirId,
        total_value: totalValue,
        total_tva: totalTva,
      });
    } catch (error) {
      if (transactionActive) {
        try {
          await runAsync(db, 'ROLLBACK');
        } catch (rollbackError) {
          console.error('⚠️ Eroare la rollback NIR:', rollbackError);
        }
      }
      throw error;
    }
  } catch (error) {
    console.error('❌ Eroare la salvarea NIR-ului (admin):', error);
    res.status(500).json({ error: 'Eroare la salvarea NIR-ului' });
  }
});

