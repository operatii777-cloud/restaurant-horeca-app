  // POST /api/suppliers/orders - Creare comandă furnizor nouă
  // Creează comandă furnizor (cu RBAC)
  app.post('/api/suppliers/orders', authenticateUser, requirePermission('inventory:edit'), async (req, res) => {
    try {
      const { supplier_id, order_number, order_date, expected_delivery_date, notes, items } = req.body;
      
      if (!supplier_id || !order_number || !order_date) {
        return res.status(400).json({ error: 'supplier_id, order_number și order_date sunt obligatorii' });
      }
      
      db.run(
        `INSERT INTO supplier_orders (supplier_id, order_number, order_date, expected_delivery_date, notes, created_by)
         VALUES (?, ?, ?, ?, ?, ?)`,
        [supplier_id, order_number, order_date, expected_delivery_date || null, notes || null, req.user?.id || null],
        function(err) {
          if (err) {
            console.error('❌ Error creating supplier order:', err);
            if (err.message.includes('UNIQUE constraint')) {
              return res.status(400).json({ error: 'Număr comandă deja există' });
            }
            return res.status(500).json({ error: err.message });
          }
          
          const orderId = this.lastID;
          
          // Adaugă itemii dacă există
          if (items && items.length > 0) {
            let completed = 0;
            let totalAmount = 0;
            
            items.forEach((item, index) => {
              const totalPrice = (item.quantity || 0) * (item.unit_price || 0);
              totalAmount += totalPrice;
              
              db.run(
                `INSERT INTO supplier_order_items (order_id, ingredient_id, item_name, quantity, unit, unit_price, total_price, notes)
                 VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,
                [orderId, item.ingredient_id || null, item.item_name, item.quantity, item.unit, item.unit_price, totalPrice, item.notes || null],
                (itemErr) => {
                  if (itemErr) {
                    console.error(`❌ Error adding item ${index} to order:`, itemErr);
                  }
                  
                  completed++;
                  if (completed === items.length) {
                    // Actualizează total_amount
                    db.run('UPDATE supplier_orders SET total_amount = ? WHERE id = ?', [totalAmount, orderId], () => {
                      console.log(`✅ Comandă furnizor creată: ${order_number} - ID: ${orderId}`);
                      res.json({ success: true, message: 'Comandă creată cu succes', id: orderId });
                    });
                  }
                }
              );
            });
          } else {
            console.log(`✅ Comandă furnizor creată: ${order_number} - ID: ${orderId}`);
            res.json({ success: true, message: 'Comandă creată cu succes', id: orderId });
          }
        }
      );
    } catch (error) {
      console.error('❌ Error in POST /api/suppliers/orders:', error);
      res.status(500).json({ error: error.message });
    }
  });

