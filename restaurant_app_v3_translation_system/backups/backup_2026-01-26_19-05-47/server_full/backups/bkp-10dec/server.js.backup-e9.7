  function buildBackupProgress(jobId) {
    const details = getBackupDetails();
    const match = details.find(
      (item) => item.jobId === jobId || item.fileName === jobId || path.basename(item.fileName) === jobId,
    );
    const nowIso = new Date().toISOString();
    if (!match) {
      return {
        jobId,
        status: 'error',
        percent: null,
        step: 'not-found',
        stepLabel: 'Job inexistent',
        message: 'Job-ul de backup nu a fost găsit.',
        startedAt: null,
        finishedAt: null,
        estimatedSecondsRemaining: null,
        updatedAt: nowIso,
      };
    }
    return {
      jobId: match.jobId || match.fileName,
      status: 'success',
      percent: 100,
      step: 'completed',
      stepLabel: 'Backup finalizat',
      message: `Backup disponibil: ${match.fileName}`,
      startedAt: match.createdAt ?? null,
      finishedAt: match.createdAt ?? null,
      estimatedSecondsRemaining: 0,
      updatedAt: nowIso,
    };
  }

