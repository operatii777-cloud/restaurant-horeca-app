const sanitizeInventoryLinesPayload = (lines) => {
  if (!Array.isArray(lines) || lines.length === 0) {
    const error = new Error('Trebuie să adaugi cel puțin o linie în inventar.');
    error.statusCode = 400;
    throw error;
  }

  return lines.map((line, index) => {
    const ingredientId = toPositiveInt(line.ingredient_id);
    const stockSystem = safeNumber(line.stock_system, 0);
    const stockCounted = safeNumber(line.stock_counted, 0);
    const explicitDiff = typeof line.diff === 'number' ? line.diff : undefined;
    const diffQty = roundNumber(
      Number.isFinite(explicitDiff) ? explicitDiff : stockCounted - stockSystem,
      4
    );
    const unit =
      typeof line.unit === 'string' && line.unit.trim() ? line.unit.trim() : null;

    if (!ingredientId) {
      const error = new Error(`Ingredient ID invalid la linia ${index + 1}.`);
      error.statusCode = 400;
      throw error;
    }
    if (stockSystem < 0) {
      const error = new Error(`Stocul scriptic trebuie să fie >= 0 la linia ${index + 1}.`);
      error.statusCode = 400;
      throw error;
    }
    if (stockCounted < 0) {
      const error = new Error(`Stocul faptic trebuie să fie >= 0 la linia ${index + 1}.`);
      error.statusCode = 400;
      throw error;
    }

    return {
      ingredient_id: ingredientId,
      unit,
      stock_system: stockSystem,
      stock_counted: stockCounted,
      diff_qty: diffQty,
    };
  });
};

