      res.status(500).json({ error: 'Eroare la salvarea poziției' });
    }
  });

  // POST /api/admin/tables/positions/batch - Salvează pozițiile multiple mese
  app.post('/api/admin/tables/positions/batch', checkAdminAuth, async (req, res) => {
    try {
      const { positions } = req.body;
      
      if (!Array.isArray(positions)) {
        return res.status(400).json({ error: 'positions trebuie să fie un array' });
      }

      const db = await dbPromise;
      const currentTime = getCurrentUTCTimestamp();

      // Folosim transaction pentru batch insert
      db.serialize(() => {
        db.run('BEGIN TRANSACTION');
        
        const stmt = db.prepare(`
          INSERT INTO tables_positions (table_id, x, y, updated_at)
          VALUES (?, ?, ?, ?)
          ON CONFLICT(table_id) DO UPDATE SET
            x = excluded.x,
            y = excluded.y,
            updated_at = excluded.updated_at
        `);

        positions.forEach((pos) => {
          if (pos.table_id && pos.x !== undefined && pos.y !== undefined) {
            stmt.run([pos.table_id, pos.x, pos.y, currentTime]);
          }
        });

        stmt.finalize((err) => {
          if (err) {
            db.run('ROLLBACK');
            console.error('❌ Eroare la salvarea batch poziții:', err);
            return res.status(500).json({ error: err.message });
          }
          
          db.run('COMMIT', (err) => {
            if (err) {
              console.error('❌ Eroare la commit batch poziții:', err);
              return res.status(500).json({ error: err.message });
            }
            
            res.json({ 
              success: true, 
              saved: positions.length,
              message: `${positions.length} poziții salvate`
            });
          });
        });
      });
    } catch (error) {
      console.error('❌ Eroare la salvarea batch poziții:', error);
      res.status(500).json({ error: 'Eroare la salvarea pozițiilor' });
    }
  });

