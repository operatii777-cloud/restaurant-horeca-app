        await runIgnoringMissingTable(db, sql, params);
      }

      await runAsync(db, 'DELETE FROM menu WHERE id = ?', [productId]);

      await runAsync(db, 'COMMIT');

      invalidateMenuCache();

      res.json({ message: 'Produs șters cu succes' });
    } catch (error) {
      try {
        await runAsync(db, 'ROLLBACK');
