            } else {
              console.warn(`⚠️ Nu s-a găsit produsul pentru ambalaj: ${packagingName}`);
            }
          }
          
          console.log(`📦 Ambalaje adăugate cu succes la comanda ${type}!`);
        } catch (error) {
          console.error('❌ Eroare la adăugarea ambalajelor:', error);
          // Nu blocăm comanda dacă nu se pot adăuga ambalajele
        }
      }
      
      const itemsJson = JSON.stringify(finalItems);
      
      // Calculează totalul comenzii pentru puncte de loialitate (ignoră produsele gratuite și reducerile Happy Hour)
      const orderTotal = finalItems.reduce((total, item) => {
        if (item.isFree) return total; // Ignoră produsele gratuite
        return total + (item.finalPrice * item.quantity);
      }, 0);
      
      // Salvează comanda în baza de date
      const storedTotal = Number.isFinite(orderTotal) ? Number(orderTotal.toFixed(2)) : 0;
      
      db.run('INSERT INTO orders (type, isTogether, items, status, timestamp, table_number, client_identifier, food_notes, drink_notes, general_notes, total) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
        [type, isTogether ? 1 : 0, itemsJson, 'pending', currentTime, tableNumber || null, clientIdentifier || null, food_notes || null, drink_notes || null, general_notes || null, storedTotal], function(err) {
      if (err) { 
        if (!res.headersSent) {
          return res.status(500).json({ error: err.message }); 
        }
        return;
      }
      
        const orderId = this.lastID;
        
        // RĂSPUNS INSTANT - clientul primește confirmarea imediat
        if (!res.headersSent) {
          res.status(201).json({ message: 'Comanda a fost înregistrată.', orderId: orderId });
        }
        
        console.log(`🎯 [Comanda #${orderId}] Comandă plasată cu succes! Articole: ${finalItems.length}`);
        if (happyHourDiscount > 0) {
          console.log(`🎉 [Comanda #${orderId}] Happy Hour aplicat! Reducere: ${happyHourDiscount.toFixed(2)} RON`);
        }
        console.log(`🔄 [Comanda #${orderId}] Programare actualizare stocuri în background...`);
        
        // OPERAȚIUNI ÎN BACKGROUND - nu blochează răspunsul
        (async () => {
          console.log(`🔵 [Comanda #${orderId}] ===== BACKGROUND PROCESSING ÎNCEPUT =====`);
          try {
            console.log(`📦 [Comanda #${orderId}] ➡️ ÎNCEPE actualizarea stocurilor DIRECT (fără fetch)...`);
            console.log(`📋 [Comanda #${orderId}] Produse în comandă: ${finalItems.length} total`);
            console.log(`📋 [Comanda #${orderId}] Primele 3 produse: ${finalItems.slice(0, 3).map(i => i.name).join(', ')}`);
            
            console.log(`🔵 [Comanda #${orderId}] Obțin dbPromise...`);
            const db = await dbPromise;
            console.log(`✅ [Comanda #${orderId}] dbPromise obținut!`);
            const ingredientsMap = new Map();
            
            // PASUL 1: Colectează toate ingredientele și ambalajele necesare din rețete
            for (const item of finalItems) {
              // Determină ce tip de ambalaje să folosească (restaurant vs delivery)
              const packagingType = type === 'restaurant' ? 'packaging_restaurant' : 'packaging_delivery';
              
              const recipes = await new Promise((resolve, reject) => {
                db.all(`
                  SELECT ingredient_id, quantity_needed, item_type, unit, waste_percentage, variable_consumption 
                  FROM recipes 
                  WHERE product_id = ? AND (item_type = 'ingredient' OR item_type = ? OR item_type = 'packaging_delivery')
                `, [item.productId, packagingType], (err, rows) => {
                  if (err) reject(err);
                  else resolve(rows || []);
                });
              });
              
              if (!recipes || recipes.length === 0) {
                console.warn(`⚠️ [Comanda #${orderId}] Produsul ${item.name} (ID: ${item.productId}) nu are rețetă definită`);
                continue;
              }
              
              // Adaugă ingredientele și ambalajele necesare
              recipes.forEach(recipe => {
                // Filtrare ambalaje: pentru restaurant nu includem packaging_delivery (doar packaging_restaurant)
                if (type === 'restaurant' && recipe.item_type === 'packaging_delivery') {
                  return; // skip ambalaje delivery pentru comenzi restaurant
                }
                
                // CALCUL CORECT: Aplică waste_percentage și variable_consumption
                const grossQuantity = calculateGrossQuantity(recipe, type, item.customizations || []);
                const totalNeeded = grossQuantity * item.quantity;
                
                if (ingredientsMap.has(recipe.ingredient_id)) {
                  ingredientsMap.set(recipe.ingredient_id, ingredientsMap.get(recipe.ingredient_id) + totalNeeded);
                } else {
                  ingredientsMap.set(recipe.ingredient_id, totalNeeded);
                }
                
                console.log(`📊 [Comanda #${orderId}] ${recipe.item_type === 'ingredient' ? '🥬' : '📦'} Ingredient ID ${recipe.ingredient_id}: ${recipe.quantity_needed}${recipe.unit} net → ${grossQuantity.toFixed(2)}${recipe.unit} brut (deșeu: ${recipe.waste_percentage || 0}%)`);
              });
            }
            
            // ========================================
            // 🔴 LEGACY STOCK CONSUMPTION – DISABLED (moved to consumeStockForOrder)
            // ========================================
            // ❌ ELIMINAT: await decreaseIngredientStock(ingredientsToDecrease, orderId);
            // 
            // MOTIV: decreaseIngredientStock modifica ingredients.current_stock direct (legacy)
            //        și cauza dublu-consum când era apelat împreună cu consumeStockForOrder.
            // 
            // ✅ NOU FLUX: Folosim doar consumeStockForOrder care:
            //        - Generează stock_moves SALE_OUT (singura sursă de adevăr pentru vânzări)
            //        - NU modifică ingredients.current_stock (legacy rămâne pentru compatibilitate)
            //        - Este idempotent (verifică dacă există deja stock_moves pentru comandă)
            // ========================================
            
            // Calculează ingredientele pentru logging (nu mai sunt folosite pentru decreaseIngredientStock)
            const ingredientsToDecrease = Array.from(ingredientsMap.entries()).map(([id, quantity]) => ({
              ingredient_id: parseInt(id),
              quantity: quantity
            }));
            
            if (ingredientsToDecrease.length === 0) {
              console.log(`⚠️ [Comanda #${orderId}] Niciun ingredient de actualizat (produse fără rețete)`);
              return;
            }
            
            console.log(`🔵 [Comanda #${orderId}] Ingrediente calculate: ${ingredientsToDecrease.length}`);
            console.log(`🔵 [Comanda #${orderId}] Primele 3 ingrediente:`, ingredientsToDecrease.slice(0, 3));
            
            // PASUL 3: Apelează funcția tranzacțională (prin QUEUE pentru serializare și prevenirea pierderii comenzilor)
            if (stockQueue) {
              console.log(`🔵 [Comanda #${orderId}] 🚀 ENQUEUE job stoc în Queue (fix nested transactions)...`);
              await stockQueue.add({
                orderId: orderId,
                finalItems: finalItems,
                orderType: type
              }, {
                jobId: `order_${orderId}`,
                priority: 1 // comenzi noi au prioritate
              });
              console.log(`✅ [Comanda #${orderId}] Job de stoc adăugat în queue - va fi procesat de worker în <1s`);
            } else {
              // Fallback: Queue indisponibil - folosim direct consumeStockForOrder (fără decreaseIngredientStock)
              console.log(`🔵 [Comanda #${orderId}] ⚠️ Queue indisponibil - folosim consumeStockForOrder direct...`);
              
              // ✅ ELIMINAT decreaseIngredientStock - folosim doar consumeStockForOrder pentru unificare
              // consumeStockForOrder generează stock_moves SALE_OUT fără a modifica ingredients.current_stock
              
              try {
                const tenantId = DEFAULT_TENANT_ID;
                // Determină sursa comenzii
                const typeStr = (type || '').toLowerCase();
                let source = ORDER_SOURCE.QR; // default
                
                if (typeStr === 'delivery') {
                  source = ORDER_SOURCE.DELIVERY;
                } else if (typeStr.includes('supervisor')) {
                  source = ORDER_SOURCE.SUPERVISOR;
                } else if (typeStr.includes('kiosk')) {
                  source = ORDER_SOURCE.KIOSK;
                }
                
                const result = await consumeStockForOrder(tenantId, orderId, source);
                console.log(`✅ [Comanda #${orderId}] consumeStockForOrder (fallback, ${source}):`, result);
                if (result.skipped) {
                  console.log(`ℹ️ [Comanda #${orderId}] Stock moves deja generate anterior - skip`);
                } else {
                  console.log(`✅ [Comanda #${orderId}] ${result.consumedLines} linii stock_moves generate`);
                }
              } catch (err) {
                console.error(`❌ [Comanda #${orderId}] ⚠️ Eroare la consumeStockForOrder (fallback):`, err);
                // Nu aruncăm eroare - logăm doar pentru debugging
              }
            }
            
            console.log(`✅ [Comanda #${orderId}] Stocuri actualizate cu succes! Ingrediente procesate: ${ingredientsToDecrease.length}`);
            
            // Adaugă puncte de loialitate dacă există clientToken
            if (clientIdentifier && tableNumber) {
            // Găsește clientToken-ul pentru acest clientIdentifier
            const tableSession = clientSessions.get(tableNumber);
            if (tableSession) {
              for (const [token, identifier] of tableSession.clients.entries()) {
                if (identifier === clientIdentifier) {
                  // Adaugă puncte pentru comandă
                  fetch(`${req.protocol}://${req.get('host')}/api/loyalty/add-points`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      clientToken: token,
                      orderId: orderId,
                      orderAmount: orderTotal
                    })
                  }).catch(err => console.error('Eroare la adăugarea punctelor:', err));
                  break;
                }
              }
            }
          }

          // Înregistrează utilizarea Happy Hour dacă s-a aplicat o reducere
          if (happyHourDiscount > 0 && happyHourSettings.length > 0) {
            try {
              const originalTotal = enriched.reduce((total, item) => {
                if (item.isFree) return total;
                return total + (item.finalPrice * item.quantity);
              }, 0);
              
              await recordHappyHourUsage(orderId, happyHourSettings[0].id, originalTotal, happyHourDiscount, orderTotal);
              console.log(`📊 [Comanda #${orderId}] Happy Hour usage înregistrat: ${happyHourDiscount.toFixed(2)} RON reducere`);
            } catch (error) {
              console.error('❌ Eroare la înregistrarea Happy Hour usage:', error);
            }
          }

            broadcastUpdate('newOrder', { orderId: orderId });
            
            // Emit dashboard update
            emitDashboardUpdate();
            
            console.log(`🔵 [Comanda #${orderId}] ===== BACKGROUND PROCESSING FINALIZAT =====`);
          } catch (error) {
            console.error(`🔴🔴🔴 [Comanda #${orderId}] EROARE CRITICĂ ÎN ASYNC BACKGROUND:`, error);
            console.error(`Stack:`, error.stack);
          }
        })();
      });
    }).catch(e => {
        console.error("Eroare la procesarea produselor comenzii:", e);
        if (!res.headersSent) {
          res.status(500).json({ error: "Eroare la procesarea produselor: " + e.message });
        }
    });
  });

  // ==================== MARCARE PLATĂ PENTRU COMENZI ====================
  
  // Marchează o comandă ca platită (pentru ospătari)
  // Marchează comandă ca plătită (cu RBAC + validation)
  const { idParamValidation } = require('./validation-schemas');
  app.put('/api/orders/:id/mark-paid', authenticateUser, requirePermission('orders:edit'), idParamValidation, (req, res) => {
    const orderId = req.params.id;
    const paidTime = getCurrentUTCTimestamp();
    
    console.log(`[MARK-PAID] Marcând comanda ${orderId} ca achitată la ${paidTime}`);
    
    // Mai întâi găsește detaliile comenzii pentru a închide sesiunea clientului
    db.get('SELECT table_number, client_identifier FROM orders WHERE id = ?', [orderId], (err, order) => {
      if (err) {
        console.error(`[MARK-PAID] Eroare la găsirea comenzii ${orderId}:`, err);
        return res.status(500).json({ error: err.message });
      }
      
      if (!order) {
        console.log(`[MARK-PAID] Comanda ${orderId} nu a fost găsită`);
        return res.status(404).json({ message: 'Comanda nu a fost găsită.' });
      }
      
      // Marchează comanda ca plătită
      db.run('UPDATE orders SET is_paid = 1, paid_timestamp = ?, status = ? WHERE id = ?', [paidTime, 'paid', orderId], function(err) {
        if (err) { 
          console.error(`[MARK-PAID] Eroare la marcarea comenzii ${orderId}:`, err);
          return res.status(500).json({ error: err.message }); 
        }
        if (this.changes === 0) { 
          console.log(`[MARK-PAID] Comanda ${orderId} nu a fost găsită`);
          return res.status(404).json({ message: 'Comanda nu a fost găsită.' }); 
        }
        
        console.log(`[MARK-PAID] Comanda ${orderId} marcată cu succes ca achitată (${this.changes} rânduri actualizate)`);
        
        // ÎNCHIDE SESIUNEA CLIENTULUI - aceasta era problema!
        const tableNumber = order.table_number;
        const clientId = order.client_identifier || '';
        
        console.log(`[MARK-PAID] Închid sesiunea pentru masa ${tableNumber}, client ${clientId}`);
        
        // Șterge sesiunea clientului din memorie
        if (clientSessions.has(tableNumber)) {
          const tableSession = clientSessions.get(tableNumber);
          // Găsește și șterge clientToken-ul pentru acest clientIdentifier
          for (const [token, identifier] of tableSession.clients.entries()) {
            if (identifier === clientId) {
              tableSession.clients.delete(token);
              console.log(`[MARK-PAID] Șters client token pentru ${clientId}`);
              break;
            }
          }
        }
        
        // Șterge din activeClientSessions
        if(activeClientSessions[tableNumber]) {
          activeClientSessions[tableNumber] = activeClientSessions[tableNumber].filter(s => s.identifier !== clientId);
          console.log(`[MARK-PAID] Șters din activeClientSessions pentru ${clientId}`);
        }
        
        // Trimite notificare WebSocket
        io.emit('orderPaid', { orderId: orderId, paidTime: paidTime });
        io.emit('visitClosed', { 
          tableNumber: tableNumber, 
          clientIdentifier: clientId,
          timestamp: new Date().toISOString()
        });

        notifyOrdersUpdated('order-mark-paid', {
          orderId,
          tableNumber,
          clientIdentifier: clientId
        });
        
        res.json({ 
          success: true,
          message: `Comanda ${orderId} a fost marcată ca platită și sesiunea clientului a fost închisă.`,
          orderId: orderId,
          paidTime: paidTime
        });
      });
    });
  });

