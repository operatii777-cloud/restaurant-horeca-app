  // Partial completion: complete specific items in an order
  app.put('/api/orders/:id/complete-items', (req, res) => {
    const orderId = req.params.id;
    const { itemIds } = req.body || {};
    if (!Array.isArray(itemIds) || itemIds.length === 0) {
      return res.status(400).json({ error: 'Lipsesc itemIds.' });
    }
    db.get('SELECT * FROM orders WHERE id = ?', [orderId], (err, order) => {
      if (err) return res.status(500).json({ error: err.message });
      if (!order) return res.status(404).json({ error: 'Comanda nu a fost găsită.' });
      let items = [];
      items = safeParseItems(order.items) || [];
      let changed = false;
      const changedIdsSet = new Set(itemIds);
      const changedBefore = items.filter(it => changedIdsSet.has(it.itemId));
      items = items.map(it => {
        if (itemIds.includes(it.itemId) && it.status !== 'completed') {
          changed = true;
          return { ...it, status: 'completed' };
        }
        return it;
      });
      if (!changed) {
        return res.json({ message: 'Nicio modificare.' });
      }
      // Verifică dacă toate produsele au fost marcate ca gata din stațiile lor specifice
      // Un produs este considerat "gata" doar dacă a fost marcat ca completed din stația sa
      const allCompleted = items.length > 0 && items.every(it => it.status === 'completed');
      
      // IMPORTANT: Nu marchem comanda ca "completed" automat când toate produsele sunt completed
      // Comanda va fi marcată ca "completed" doar când toate produsele sunt efectiv gata din stațiile lor
      // Aceasta previne problema unde produsele de bucătărie sunt marcate automat ca gata
      // când produsele de bar sunt marcate ca gata
      
      const updatedItemsJson = JSON.stringify(items);
      
      // Actualizează doar items-urile, fără să marcheze comanda ca completed automat
      db.run('UPDATE orders SET items = ? WHERE id = ?', [updatedItemsJson, orderId], function(updErr) {
        if (updErr) return res.status(500).json({ error: updErr.message });
        io.emit('orderUpdated', { orderId });

        // Station-specific ready notifications for items just completed
        try {
          const stations = Array.from(new Set((changedBefore || []).map(it => it.station).filter(Boolean)));
          const tableNo = order.table_number || '';
          stations.forEach(st => {
            const type = st === 'bar' ? 'barReady' : 'kitchenReady';
            const title = st === 'bar' ? 'Gata la Bar' : 'Gata la Bucătărie';
            const titleEn = st === 'bar' ? 'Ready at Bar' : 'Ready at Kitchen';
            
            // Construiește lista produselor gata pentru această stație
            const readyItems = changedBefore.filter(it => it.station === st);
            const itemsList = readyItems.map(it => `${it.quantity}x ${it.name}`).join(', ');
            
            // Adaugă informații despre tipul comenzii
            let orderTypeInfo = '';
            if (order.type === 'takeout') {
              orderTypeInfo = ' (pentru acasă)';
            } else if (order.isTogether) {
              orderTypeInfo = ' (împreună)';
            } else {
              orderTypeInfo = ' (separat)';
            }
            
            let orderTypeInfoEn = '';
            if (order.type === 'takeout') {
              orderTypeInfoEn = ' (takeout)';
            } else if (order.isTogether) {
              orderTypeInfoEn = ' (together)';
            } else {
              orderTypeInfoEn = ' (separate)';
            }
            
            const message = `Comanda #${orderId} - Masa ${tableNo || 'N/A'}${orderTypeInfo}\nProduse gata: ${itemsList}`;
            const messageEn = `Order #${orderId} - Table ${tableNo || 'N/A'}${orderTypeInfoEn}\nReady items: ${itemsList}`;
            
            db.run(
              'INSERT INTO notifications (type, table_number, order_id, title, message, status, title_en, message_en) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
              [type, String(tableNo), Number(orderId), title, message, 'unread', titleEn, messageEn],
              function(nErr) {
                if (!nErr) {
                  io.emit('notification:new', {
                    id: this.lastID,
                    type,
                    table_number: String(tableNo),
                    order_id: Number(orderId),
                    title,
                    message,
                    status: 'unread',
                    created_at: new Date().toISOString(),
                  });
                }
              }
            );
          });
        } catch(e) {
          console.error('Eroare notificare stationReady:', e);
        }
        
        // ELIMINAT: Nu mai marchem comanda ca completed automat
        // Comanda va fi marcată ca completed doar manual de către supervisor/manager
        // Aceasta previne problema cu marcarea automată a produselor de bucătărie
        
        res.json({ message: 'Produsele selectate au fost marcate ca gata.' });
      });
    });
  });

  // Items ready for pickup (completed but not yet delivered), grouped by order
  app.get('/api/orders-ready', (req, res) => {
    const lang = (req.query.lang || 'ro').toLowerCase();
    db.all('SELECT * FROM orders WHERE status IN ("pending","completed") ORDER BY completed_timestamp IS NULL, completed_timestamp ASC', (err, rows) => {
      if (err) { return res.status(500).json({ error: err.message }); }
      const result = [];
      (rows || []).forEach(order => {
        let items = [];
        items = safeParseItems(order.items) || [];
        const ready = items.filter(it => it && it.status === 'completed');
        if (ready.length === 0) return;
        const base = formatOrderTimestamps({
          id: order.id,
          table_number: order.table_number,
          type: order.type,
          timestamp: order.timestamp,
          food_notes: order.food_notes,
          drink_notes: order.drink_notes,
          general_notes: order.general_notes,
          items: ready.map(it => ({ itemId: it.itemId, productId: it.productId, name: it.name || 'Produs', quantity: it.quantity, customizations: it.customizations || [], station: it.station }))
        });
        result.push(formatOrderTimestampsLang(base, lang));
      });
      if (lang === 'en' && result.length) {
        const ids = new Set();
        result.forEach(o => o.items.forEach(it => ids.add(it.productId)));
        const placeholders = Array.from(ids).map(() => '?').join(',');
        const sql = `SELECT id, name_en, name AS name_ro FROM menu WHERE id IN (${placeholders})`;
        db.all(sql, Array.from(ids), (e2, rows2) => {
          const nameMap = new Map((rows2||[]).map(r => [r.id, { name_en: r.name_en, name_ro: r.name_ro }]));
          result.forEach(o => o.items.forEach(it => {
            // Dacă produsul are deja numele setat (pentru meniul zilei), nu-l suprascrie
            if (it.name && it.name !== 'Produs' && it.name.trim() !== '') {
              delete it.productId;
              return; // Păstrează numele existent
            }
            
            if (nameMap.has(it.productId)) {
              const rec = nameMap.get(it.productId);
              const enName = rec.name_en && String(rec.name_en).trim() ? rec.name_en : translateRoToEn(rec.name_ro || '');
              it.name = enName || it.name;
            }
            delete it.productId;
          }));
          return res.json({ orders: result });
        });
      } else {
        result.forEach(o => o.items.forEach(it => { delete it.productId; }));
        return res.json({ orders: result });
      }
    });
  });

  // Endpoint Admin V4 - returnează comenzile cu filtre pentru UI-ul de gestionare
  app.get('/api/orders-delivery', async (req, res) => {
    try {
      const db = await dbPromise;
      const {
        status: rawStatus = 'all',
        startDate,
        endDate,
        limit: rawLimit
      } = req.query;

      const status = String(rawStatus || 'all').toLowerCase();
      const filters = [];
      const params = [];
      const allowedStatuses = ['pending', 'preparing', 'completed', 'delivered', 'paid', 'cancelled'];

      if (status === 'paid') {
        filters.push('is_paid = 1');
        filters.push("status != 'cancelled'");
      } else if (status === 'unpaid') {
        filters.push('is_paid = 0');
        filters.push("status != 'cancelled'");
      } else if (status === 'cancelled') {
        filters.push("status = 'cancelled'");
      } else if (status !== 'all' && allowedStatuses.includes(status)) {
        filters.push('status = ?');
        params.push(status);
      } else {
        filters.push(`status IN (${allowedStatuses.map(() => '?').join(',')})`);
        params.push(...allowedStatuses);
      }

      if (startDate) {
        filters.push('DATE(timestamp) >= DATE(?)');
        params.push(startDate);
      }
      if (endDate) {
        filters.push('DATE(timestamp) <= DATE(?)');
        params.push(endDate);
      }

      // === EXCLUDE DRIVE-THRU din livrare1-10.html (05 Dec 2025) ===
      // Drive-Thru se gestionează doar în POS Drive-Thru, nu în livrare.html
      filters.push("(order_source IS NULL OR order_source != 'DRIVE_THRU')");
      
      const whereClause = filters.length ? `WHERE ${filters.join(' AND ')}` : '';
      const limit = Number(rawLimit || 1000);

      const sql = `
        SELECT
          id,
          table_number,
          client_identifier,
          type,
          order_source,
          platform,
          delivery_address,
          customer_name,
          customer_phone,
          delivery_pickup_code,
          timestamp,
          status,
          is_paid,
          paid_timestamp,
          completed_timestamp,
          delivered_timestamp,
          cancelled_timestamp,
          cancelled_reason,
          total,
          items,
          food_notes,
          drink_notes,
          general_notes
        FROM orders
        ${whereClause}
        ORDER BY timestamp DESC
        LIMIT ?
      `;

      const rows = await new Promise((resolve, reject) => {
        db.all(sql, [...params, limit], (err, result) => {
          if (err) {
            reject(err);
          } else {
            resolve(result || []);
          }
        });
      });

      const menuIds = new Set();
      const orders = rows.map((row) => {
        const rawItems = safeParseItems(row.items) || [];
        const items = rawItems.map((item, index) => {
          const productId =
            item && item.productId !== undefined && item.productId !== null
              ? Number(item.productId)
              : null;
          if (productId) {
            menuIds.add(productId);
          }
          const quantity = Number(item?.quantity ?? 0) || 0;
          const price = Number(item?.price ?? 0) || 0;
          const finalPrice = Number(item?.finalPrice ?? item?.price ?? 0) || 0;

          return {
            itemId: item?.itemId ?? `${row.id}-${index}`,
            productId,
            name: item?.name || null,
            quantity,
            price,
            finalPrice,
            isFree: Boolean(item?.isFree),
            status: item?.status || row.status,
            station: item?.station || null,
            isDailyMenu: Boolean(item?.isDailyMenu),
            isPackaging: Boolean(item?.isPackaging),
            customizations: Array.isArray(item?.customizations)
              ? item.customizations.map((custom, customIndex) => ({
                  id: custom?.id ?? `${row.id}-${index}-${customIndex}`,
                  option_name: custom?.option_name ?? custom?.name ?? 'Opțiune',
                  option_name_en: custom?.option_name_en ?? null,
                  extra_price: Number(custom?.extra_price ?? custom?.price ?? 0) || 0,
                }))
              : [],
          };
        });

        return {
          id: row.id,
          table_number: row.table_number,
          client_identifier: row.client_identifier,
          type: row.type,
          order_source: row.order_source || null, // DELIVERY, DRIVE_THRU, etc. (05 Dec 2025)
          platform: row.platform || null, // glovo, wolt, friendsride, etc.
          delivery_address: row.delivery_address || null,
          customer_name: row.customer_name || null,
          customer_phone: row.customer_phone || null,
          delivery_pickup_code: row.delivery_pickup_code || null,
          timestamp: row.timestamp,
          status: row.status,
          is_paid: Number(row.is_paid ?? 0),
          paid_timestamp: row.paid_timestamp,
          completed_timestamp: row.completed_timestamp,
          delivered_timestamp: row.delivered_timestamp,
          cancelled_timestamp: row.cancelled_timestamp,
          cancelled_reason: row.cancelled_reason,
          total: Number(row.total ?? 0),
          food_notes: row.food_notes,
          drink_notes: row.drink_notes,
          general_notes: row.general_notes,
          items,
        };
      });

      if (menuIds.size > 0) {
        const placeholders = Array.from(menuIds)
          .map(() => '?')
          .join(',');
        const nameRows = await new Promise((resolve, reject) => {
          db.all(
            `SELECT id, name AS name_ro, name_en FROM menu WHERE id IN (${placeholders})`,
            Array.from(menuIds),
            (err, result) => {
              if (err) {
                reject(err);
              } else {
                resolve(result || []);
              }
            }
          );
        });

        const nameMap = new Map(
          (nameRows || []).map((row) => [
            Number(row.id),
            {
              ro: row.name_ro,
              en: row.name_en,
            },
          ])
        );

        orders.forEach((order) => {
          order.items.forEach((item) => {
            if (!item.name && item.productId && nameMap.has(item.productId)) {
              const entry = nameMap.get(item.productId);
              item.name = entry?.ro || entry?.en || 'Produs';
            }
          });
        });
      }

      res.json({ data: orders });
    } catch (error) {
      console.error('❌ Eroare la GET /api/orders-delivery:', error);
      res.status(500).json({ error: 'Nu s-a putut încărca lista comenzilor.' });
    }
  });

  // Deliver specific items; if all delivered, close the order
  app.put('/api/orders/:id/deliver-items', (req, res) => {
    const orderId = req.params.id;
    const { itemIds } = req.body || {};
    if (!Array.isArray(itemIds) || itemIds.length === 0) {
      return res.status(400).json({ error: 'Lipsesc itemIds.' });
    }
    db.get('SELECT * FROM orders WHERE id = ?', [orderId], (err, order) => {
      if (err) return res.status(500).json({ error: err.message });
      if (!order) return res.status(404).json({ error: 'Comanda nu a fost găsită.' });
      let items = [];
      items = safeParseItems(order.items) || [];
      
      // Verifică dacă produsele specificate sunt marcate ca completed înainte de livrare
      const itemsToDeliver = items.filter(it => itemIds.includes(it.itemId));
      const notCompletedItems = itemsToDeliver.filter(it => it.status !== 'completed');
      
      if (notCompletedItems.length > 0) {
        const notCompletedNames = notCompletedItems.map(item => `${item.quantity}x ${item.name}`).join(', ');
        return res.status(400).json({ 
          error: 'Nu se pot livra produsele!',
          message: `Următoarele produse nu au fost marcate ca gata: ${notCompletedNames}`,
          notCompletedItems: notCompletedItems.map(item => ({
            name: item.name,
            station: item.station,
            status: item.status
          }))
        });
      }
      
      let changed = false;
      items = items.map(it => {
        if (itemIds.includes(it.itemId) && it.status === 'completed') {
          changed = true;
          return { ...it, status: 'delivered' };
        }
        return it;
      });
      if (!changed) {
        return res.json({ message: 'Nicio modificare.' });
      }
      
      // Verifică dacă toate produsele din comandă sunt acum delivered
      const allDelivered = items.length > 0 && items.every(it => it.status === 'delivered');
      const updatedItemsJson = JSON.stringify(items);
      const deliveredTime = getCurrentUTCTimestamp();
      const sql = allDelivered
        ? 'UPDATE orders SET items = ?, status = "delivered", delivered_timestamp = ? WHERE id = ?'
        : 'UPDATE orders SET items = ? WHERE id = ?';
      const params = allDelivered ? [updatedItemsJson, deliveredTime, orderId] : [updatedItemsJson, orderId];
      db.run(sql, params, function(updErr) {
        if (updErr) return res.status(500).json({ error: updErr.message });
        io.emit('orderUpdated', { orderId });
        if (allDelivered) {
          broadcastUpdate('orderDelivered', { orderId });
        }
        notifyOrdersUpdated('order-deliver-items', {
          orderId,
          itemsUpdated: itemIds.length,
          allDelivered
        });
        res.json({ message: allDelivered ? 'Toate produsele au fost livrate.' : 'Produsele selectate au fost livrate.' });
      });
    });
  });

  app.put('/api/orders/:id/deliver', (req, res) => {
    const orderId = req.params.id;
    
    // Verifică mai întâi dacă comanda există și obține detaliile
    db.get('SELECT * FROM orders WHERE id = ?', [orderId], (err, order) => {
      if (err) { 
        return res.status(500).json({ error: err.message }); 
      }
      if (!order) { 
        return res.status(404).json({ message: 'Comanda nu a fost găsită.' }); 
      }
      
      // Parsează produsele din comandă
      let items = [];
      items = safeParseItems(order.items) || [];
      
      // Verifică dacă toate produsele au fost marcate ca gata (completed)
      const allItemsReady = items.length > 0 && items.every(item => item.status === 'completed');
      
      if (!allItemsReady) {
        const pendingItems = items.filter(item => item.status !== 'completed');
        const pendingItemsNames = pendingItems.map(item => `${item.quantity}x ${item.name}`).join(', ');
        
        return res.status(400).json({ 
          error: 'Nu se poate livra comanda!',
          message: `Următoarele produse nu au fost marcate ca gata: ${pendingItemsNames}`,
          pendingItems: pendingItems.map(item => ({
            name: item.name,
            station: item.station,
            status: item.status
          }))
        });
      }
      
      // Dacă toate produsele sunt gata, marchează comanda ca livrată
      const deliveredTime = getCurrentUTCTimestamp();
      db.run('UPDATE orders SET status = "delivered", delivered_timestamp = ? WHERE id = ?', [deliveredTime, orderId], function(err) {
        if (err) { 
          return res.status(500).json({ error: err.message }); 
        }
        if (this.changes === 0) { 
          return res.status(404).json({ message: 'Comanda nu a fost găsită.' }); 
        }
        
        broadcastUpdate('orderDelivered', { orderId: orderId });
        
        // Emit dashboard update
        emitDashboardUpdate();

        notifyOrdersUpdated('order-delivered', {
          orderId,
          deliveredTimestamp: deliveredTime
        });
        
        res.json({ message: `Comanda ${orderId} a fost livrată cu succes.` });
      });
    });
  });

  // ==================== ANULARE COMANDA ====================
  
  // Anulează o comandă (pentru clienți)
  app.post('/api/orders/:id/cancel', async (req, res) => {
    const orderId = req.params.id;
    const { reason, tableNumber, clientIdentifier } = req.body;
    
    console.log(`[CANCEL-ORDER] Cerere de anulare pentru comanda ${orderId} de la masa ${tableNumber}, client ${clientIdentifier}`);
    
    if (!orderId) {
      return res.status(400).json({ error: 'ID-ul comenzii este obligatoriu.' });
    }
    
    try {
      const db = await dbPromise;
      
      // Verifică dacă comanda există și poate fi anulată (doar pending sau preparing)
      const order = await new Promise((resolve, reject) => {
        db.get('SELECT * FROM orders WHERE id = ? AND status IN ("pending", "preparing")', [orderId], (err, row) => {
          if (err) reject(err);
          else resolve(row);
        });
      });
      
      if (!order) {
        console.log(`[CANCEL-ORDER] Comanda ${orderId} nu a fost găsită sau nu poate fi anulată`);
        return res.status(404).json({ 
          error: 'Ne pare rău, comanda dumneavoastră a fost deja procesată și nu mai poate fi anulată. Vă mulțumim pentru înțelegere.',
          error_en: 'We apologize, your order has already been processed and can no longer be cancelled. Thank you for your understanding.',
          code: 'ORDER_ALREADY_PROCESSED'
        });
      }
      
      // Verifică dacă comanda aparține clientului care încearcă să o anuleze
      if (tableNumber && clientIdentifier) {
        if (order.table_number != tableNumber || order.client_identifier != clientIdentifier) {
          console.log(`[CANCEL-ORDER] Client neautorizat: masa ${order.table_number} vs ${tableNumber}, client ${order.client_identifier} vs ${clientIdentifier}`);
          return res.status(403).json({ error: 'Nu aveți permisiunea să anulați această comandă.' });
        }
      }
      
      const cancelTime = getCurrentUTCTimestamp();
      const cancelReason = reason || 'Anulată de client';
      
      // Actualizează statusul comenzii la "cancelled"
      const updateResult = await new Promise((resolve, reject) => {
        db.run('UPDATE orders SET status = "cancelled", cancelled_timestamp = ?, cancelled_reason = ? WHERE id = ?', 
          [cancelTime, cancelReason, orderId], function(err) {
          if (err) reject(err);
          else resolve({ changes: this.changes });
        });
      });
      
      if (updateResult.changes === 0) {
        return res.status(404).json({ error: 'Comanda nu a fost găsită.' });
      }
      
      console.log(`[CANCEL-ORDER] Comanda ${orderId} anulată cu succes`);
      
      // Obține detaliile comenzii pentru notificări
      const cancelledOrder = await new Promise((resolve, reject) => {
        db.get('SELECT * FROM orders WHERE id = ?', [orderId], (err, row) => {
          if (err) reject(err);
          else resolve(row);
        });
      });
      
      // 🔄 RESTAURARE STOC: Returnează ingredientele în stoc când comanda este anulată
      if (cancelledOrder && cancelledOrder.items) {
        try {
          const orderItems = safeParseItems(cancelledOrder.items || '[]');
          
          // Calculează ingredientele care trebuie redate în stoc
          const ingredientsMap = new Map();
          
          const recipePromises = orderItems.map(item => {
            return new Promise((resolve, reject) => {
              if (!item.productId) {
                console.warn('⚠️ Item fără productId în comanda anulată');
                return resolve();
              }
              
              const recipeQuery = `
                SELECT 
                  r.quantity_needed,
                  r.ingredient_id,
                  i.name as ingredient_name
                FROM recipes r
                JOIN ingredients i ON r.ingredient_id = i.id
                WHERE r.product_id = ?
              `;
              
              db.all(recipeQuery, [item.productId], (err, recipeRows) => {
                if (err) {
                  console.error(`❌ Eroare la obținerea rețetei pentru produsul ${item.productId}:`, err);
                  return resolve(); // Nu blocăm anularea pentru erori de rețetă
                }
                
                if (!recipeRows || recipeRows.length === 0) {
                  console.warn(`⚠️ Produsul ${item.productId} nu are rețetă - stocul NU va fi restaurat`);
                }
                
                recipeRows.forEach(recipe => {
                  const neededQuantity = recipe.quantity_needed * (item.quantity || 1);
                  
                  if (ingredientsMap.has(recipe.ingredient_id)) {
                    const existing = ingredientsMap.get(recipe.ingredient_id);
                    existing.quantity += neededQuantity;
                  } else {
                    ingredientsMap.set(recipe.ingredient_id, {
                      quantity: neededQuantity,
                      name: recipe.ingredient_name
                    });
                  }
                });
                
                resolve();
              });
            });
          });
          
          await Promise.all(recipePromises);
          
          const ingredientsToIncrease = Array.from(ingredientsMap.entries()).map(([id, data]) => ({
            ingredient_id: parseInt(id),
            quantity: data.quantity
          }));
          
          if (ingredientsToIncrease.length > 0) {
            console.log(`🔄 Comanda #${orderId} anulată: Se restituie ${ingredientsToIncrease.length} ingrediente în stoc`);
            await increaseIngredientStock(ingredientsToIncrease);
            
            // Adaugă în istoric
            const historyPromises = ingredientsToIncrease.map(ing => {
              return new Promise((resolve) => {
                db.run(`INSERT INTO stock_history 
                  (ingredient_id, change_type, quantity_change, previous_stock, new_stock, reason, order_id)
                  VALUES (?, 'cancellation', ?, ?, ?, 'Comandă anulată - stoc restituit', ?)`,
                  [ing.ingredient_id, ing.quantity, 0, 0, orderId], 
                  function(err) {
                    if (err) {
                      console.error('❌ Eroare la adăugarea în istoric (anulare):', err);
                    }
                    resolve();
                  });
              });
            });
            
            await Promise.all(historyPromises);
            console.log(`✅ Stoc restituit cu succes pentru comanda anulată #${orderId}`);
          } else {
            console.log(`⚠️ Comanda #${orderId} nu conține produse cu rețete - niciun stoc restituit`);
          }
          
        } catch (stockRestoreError) {
          console.error(`❌ Eroare la restituirea stocului pentru comanda anulată ${orderId}:`, stockRestoreError);
          // Nu blocăm anularea pentru erori de restaurare stoc
        }
      }
      
      if (cancelledOrder) {
        try {
          // Determină departamentele afectate
          const affectedDepartments = [];
          let orderItems = [];
          
          try {
            orderItems = safeParseItems(cancelledOrder.items || '[]');
          } catch (parseError) {
            console.error('Eroare la parsarea items-urilor:', parseError);
            orderItems = [];
          }
          
          // Verifică dacă există produse de bar
          const hasBarItems = orderItems.some(item => item.station === 'bar');
          
          // Verifică dacă există produse de bucătărie
          const hasKitchenItems = orderItems.some(item => item.station === 'kitchen');
          
          if (hasBarItems) affectedDepartments.push('bar');
          if (hasKitchenItems) affectedDepartments.push('kitchen');
          
          // Trimite notificări către departamentele afectate
          affectedDepartments.forEach(dept => {
            const deptItems = orderItems.filter(item => item.station === dept);
            
            io.emit('orderCancelled', {
              orderId: orderId,
              tableNumber: cancelledOrder.table_number,
              clientIdentifier: cancelledOrder.client_identifier,
              reason: cancelReason,
              department: dept,
              timestamp: cancelTime,
              items: deptItems
            });
          });
          
          // Trimite notificare către ospătarul responsabil
          const waiterId = await getWaiterIdForTableAsync(cancelledOrder.table_number);
          if (waiterId) {
            io.emit('orderCancelled', {
              orderId: orderId,
              tableNumber: cancelledOrder.table_number,
              clientIdentifier: cancelledOrder.client_identifier,
              reason: cancelReason,
              department: 'waiter',
              waiterId: waiterId,
              timestamp: cancelTime,
              items: orderItems
            });
          }
          
          // Salvează notificarea în baza de date
          await new Promise((resolve, reject) => {
            const type = 'cancellation';
            const title = 'Comandă Anulată';
            
            // Adaugă informații despre tipul comenzii
            let orderTypeInfo = '';
            if (cancelledOrder.type === 'takeout') {
              orderTypeInfo = ' (pentru acasă)';
            } else if (cancelledOrder.isTogether) {
              orderTypeInfo = ' (împreună)';
            } else {
              orderTypeInfo = ' (separat)';
            }
            
            const message = `Comanda #${orderId} - Masa ${cancelledOrder.table_number} - Client ${cancelledOrder.client_identifier || 'N/A'}${orderTypeInfo} a fost anulată. Motiv: ${cancelReason}`;
            
            db.run(
              'INSERT INTO notifications (type, table_number, order_id, title, message, status) VALUES (?, ?, ?, ?, ?, ?)',
              [type, String(cancelledOrder.table_number || ''), orderId, title, message, 'unread'],
              function(err) {
                if (err) {
                  console.error('Eroare la inserarea notificării:', err);
                  reject(err);
                } else {
                  // Emit notificare WebSocket
                  io.emit('notification:new', {
                    id: this.lastID,
                    type,
                    table_number: String(cancelledOrder.table_number || ''),
                    order_id: orderId,
                    title,
                    message,
                    status: 'unread',
                    created_at: cancelTime,
                  });
                  resolve();
                }
              }
            );
          });
          
        } catch (notificationError) {
          console.error('Eroare la trimiterea notificărilor:', notificationError);
          // Nu oprește procesul de anulare pentru o eroare de notificare
        }
      }
      
      // Emit update pentru toate interfețele
      io.emit('orderUpdated', { orderId });
      broadcastUpdate('orderCancelled', { 
        orderId, 
        tableNumber: cancelledOrder?.table_number,
        clientIdentifier: cancelledOrder?.client_identifier,
        reason: cancelReason
      });
      emitDashboardUpdate();

      notifyOrdersUpdated('order-cancelled', {
        orderId,
        tableNumber: cancelledOrder?.table_number ?? null,
        clientIdentifier: cancelledOrder?.client_identifier ?? null,
        reason: cancelReason
      });
      
      res.json({ 
        success: true,
        message: 'Comanda a fost anulată cu succes.',
        orderId: orderId,
        cancelledAt: cancelTime,
        reason: cancelReason
      });
      
    } catch (error) {
      console.error(`[CANCEL-ORDER] Eroare la anularea comenzii ${orderId}:`, error);
      res.status(500).json({ 
        error: 'Eroare internă la anularea comenzii.',
        details: process.env.NODE_ENV === 'development' ? error.message : undefined
      });
    }
  });

