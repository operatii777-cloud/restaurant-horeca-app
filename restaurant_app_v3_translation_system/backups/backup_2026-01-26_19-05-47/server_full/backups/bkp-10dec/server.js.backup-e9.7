                    if (item.finalPrice && item.quantity) {
                      totalRevenue += item.finalPrice * item.quantity;
                    }
                  });
                }
              } catch (parseError) {
                console.warn('⚠️ Eroare la parsarea items:', parseError.message);
              }
            }
          });
          resolve(totalRevenue);
        });
      });
      
      const revenueChange = yesterdayRevenue > 0 
        ? ((todayRevenue - yesterdayRevenue) / yesterdayRevenue * 100)
        : 0;
      const revenueChangeText = revenueChange >= 0 
        ? `+${revenueChange.toFixed(1)}% față de ieri`
        : `${revenueChange.toFixed(1)}% față de ieri`;
      
      // 3. Comenzi astăzi
      const todayOrders = await new Promise((resolve, reject) => {
        db.get(`
          SELECT COUNT(*) as count 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [today], (err, row) => {
          if (err) reject(err);
          else resolve(row.count);
        });
      });
      
      // 4. Comenzi ieri pentru comparație
      const yesterdayOrders = await new Promise((resolve, reject) => {
        db.get(`
          SELECT COUNT(*) as count 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [yesterday], (err, row) => {
          if (err) reject(err);
          else resolve(row.count);
        });
      });
      
      const ordersChange = yesterdayOrders > 0 
        ? ((todayOrders - yesterdayOrders) / yesterdayOrders * 100)
        : 0;
      const ordersChangeText = ordersChange >= 0 
        ? `+${ordersChange.toFixed(1)}% față de ieri`
        : `${ordersChange.toFixed(1)}% față de ieri`;
      
      // 5. COGS astăzi
      const cogsToday = await new Promise((resolve, reject) => {
        db.all(`
          SELECT items 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [today], async (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          let totalCOGS = 0;
          
          for (const order of rows) {
            if (!order.items) continue;
            
            try {
              const items = safeParseItems(order.items);
              if (!Array.isArray(items)) continue;
              
              for (const item of items) {
                if (!item.productId || !item.quantity) continue;
                
                const recipeRows = await new Promise((resolveRecipe, rejectRecipe) => {
                  db.all(`
                    SELECT r.quantity_needed, i.cost_per_unit
                    FROM recipes r
                    JOIN ingredients i ON r.ingredient_id = i.id
                    WHERE r.product_id = ?
                  `, [item.productId], (err, rows) => {
                    if (err) rejectRecipe(err);
                    else resolveRecipe(rows);
                  });
                });
                
                recipeRows.forEach(recipe => {
                  if (recipe.quantity_needed && recipe.cost_per_unit) {
                    const ingredientCost = recipe.quantity_needed * recipe.cost_per_unit;
                    totalCOGS += ingredientCost * item.quantity;
                  }
                });
              }
              
            } catch (parseError) {
              console.warn('⚠️ Eroare la parsarea items:', parseError.message);
            }
          }
          
          resolve(totalCOGS);
        });
      });
      
      // 6. Profit și marjă
      const todayProfit = todayRevenue - cogsToday;
      const profitMargin = todayRevenue > 0 ? (todayProfit / todayRevenue * 100) : 0;
      
      // 7. Alerte stoc
      const inventoryAlerts = await new Promise((resolve, reject) => {
        db.get(`
          SELECT COUNT(*) as count 
          FROM ingredients 
          WHERE current_stock <= min_stock
        `, (err, row) => {
          if (err) reject(err);
          else resolve(row.count);
        });
      });
      
      // 8. Retenție clienți
      const customerRetention = await new Promise((resolve, reject) => {
        db.get(`
          SELECT 
            COUNT(DISTINCT CASE WHEN DATE(timestamp) >= date('now', '-7 days') THEN client_identifier END) as recent_customers,
            COUNT(DISTINCT CASE WHEN DATE(timestamp) >= date('now', '-30 days') THEN client_identifier END) as monthly_customers
          FROM orders 
          WHERE is_paid = 1 AND client_identifier IS NOT NULL
        `, (err, row) => {
          if (err) reject(err);
          else {
            const retention = row.monthly_customers > 0 
              ? (row.recent_customers / row.monthly_customers * 100)
              : 0;
            resolve(Math.round(retention));
          }
        });
      });
      
      // 9. Table Turnover și Utilization (simplificat)
      const tableStats = await new Promise((resolve, reject) => {
        db.get(`
          SELECT 
            COUNT(DISTINCT table_id) as occupied_tables,
            COUNT(*) as total_orders
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1 AND table_id IS NOT NULL
        `, [today], (err, row) => {
          if (err) reject(err);
          else {
            // Simplificat: turnover = total_orders / occupied_tables
            const turnover = row.occupied_tables > 0 ? (row.total_orders / row.occupied_tables).toFixed(1) : '0.0';
            // Utilization: presupunem 200 mese totale
            const totalTables = 200;
            const utilization = `${row.occupied_tables}/${totalTables}`;
            resolve({ turnover: `${turnover}x`, utilization });
          }
        });
      });
      
      // 10. Rating-uri și feedback
      const feedbackStats = await new Promise((resolve, reject) => {
        db.all(`
          SELECT 
            rating,
            COUNT(*) as count
          FROM feedback 
          WHERE timestamp >= date('now', '-30 days')
          GROUP BY rating
        `, (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          let totalFeedback = 0;
          let sumRating = 0;
          let excellentCount = 0;
          let lowRatingCount = 0;
          
          rows.forEach(row => {
            const count = row.count || 0;
            const rating = row.rating || 0;
            totalFeedback += count;
            sumRating += rating * count;
            
            if (rating === 5) excellentCount += count;
            if (rating <= 2) lowRatingCount += count;
          });
          
          const avgRating = totalFeedback > 0 ? (sumRating / totalFeedback) : 0;
          
          resolve({
            avgRating: Math.round(avgRating * 10) / 10,
            totalFeedback,
            excellentCount,
            lowRatingCount
          });
        });
      });
      
      // 11. Top Products astăzi
      const topProducts = await new Promise((resolve, reject) => {
        db.all(`
          SELECT items 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [today], (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          const productMap = new Map();
          let totalRevenue = 0;
          
          rows.forEach(order => {
            if (!order.items) return;
            
            try {
              const items = safeParseItems(order.items);
              if (!Array.isArray(items)) return;
              
              items.forEach(item => {
                if (!item.name || !item.finalPrice || !item.quantity) return;
                
                const revenue = item.finalPrice * item.quantity;
                totalRevenue += revenue;
                
                if (productMap.has(item.name)) {
                  const existing = productMap.get(item.name);
                  existing.quantity_sold += item.quantity;
                  existing.revenue += revenue;
                } else {
                  productMap.set(item.name, {
                    product_name: item.name,
                    category: item.category || 'General',
                    quantity_sold: item.quantity,
                    revenue: revenue,
                    percentage: 0
                  });
                }
              });
            } catch (parseError) {
              console.warn('⚠️ Eroare la parsarea items:', parseError.message);
            }
          });
          
          // Calculează procentele
          const products = Array.from(productMap.values());
          products.forEach(product => {
            product.percentage = totalRevenue > 0 ? (product.revenue / totalRevenue * 100) : 0;
          });
          
          // Sortează după venit și ia top 5
          products.sort((a, b) => b.revenue - a.revenue);
          resolve(products.slice(0, 5));
        });
      });
      
      // 12. Revenue & Margin Data (ultimele 7 zile)
      const revenueMarginData = await new Promise((resolve, reject) => {
        db.all(`
          SELECT 
            DATE(timestamp) as date,
            items,
            total
          FROM orders 
          WHERE DATE(timestamp) >= date('now', '-7 days') AND is_paid = 1
          ORDER BY date ASC
        `, (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          const dailyData = new Map();
          
          rows.forEach(order => {
            const date = order.date;
            if (!dailyData.has(date)) {
              dailyData.set(date, { revenue: 0, cogs: 0 });
            }
            
            const dayData = dailyData.get(date);
            
            // Calculează revenue
            if (order.total && order.total > 0) {
              dayData.revenue += order.total;
            } else if (order.items) {
              try {
                const items = safeParseItems(order.items);
                if (Array.isArray(items)) {
                  items.forEach(item => {
                    if (item.finalPrice && item.quantity) {
                      dayData.revenue += item.finalPrice * item.quantity;
                    }
                  });
                }
              } catch (parseError) {
                console.warn('⚠️ Eroare la parsarea items:', parseError.message);
              }
            }
          });
          
          // Convertim la array și calculăm marja (simplificat)
          const result = Array.from(dailyData.entries()).map(([date, data]) => ({
            date,
            revenue: Math.round(data.revenue * 100) / 100,
            margin: data.revenue > 0 ? Math.round((data.revenue - data.cogs) / data.revenue * 100) : 0
          }));
          
          resolve(result);
        });
      });
      
      res.json({
        todayRevenue: Math.round(todayRevenue * 100) / 100,
        revenueChange: revenueChangeText,
        inventoryAlerts,
        customerRetention,
        cogsToday: Math.round(cogsToday * 100) / 100,
        tableTurnover: tableStats.turnover,
        tableUtilization: tableStats.utilization,
        avgRating: feedbackStats.avgRating,
        totalFeedback: feedbackStats.totalFeedback,
        excellentCount: feedbackStats.excellentCount,
        lowRatingCount: feedbackStats.lowRatingCount,
        todayOrders,
        todayOrdersChange: ordersChangeText,
        todayProfit: Math.round(todayProfit * 100) / 100,
        profitMargin: Math.round(profitMargin * 10) / 10,
        topProducts: topProducts || [],
        revenueMarginData: revenueMarginData || []
      });
      
    } catch (error) {
      console.error('❌ Error in admin dashboard KPI:', error);
      res.status(500).json({ error: 'Eroare la calcularea KPI-urilor dashboard' });
    }
  });
  
// GET /api/admin/dashboard/inventory-alerts - Alerte detaliate pentru stoc - ETAPA 5: Multi-Gestiune
app.get('/api/admin/dashboard/inventory-alerts', checkAdminAuth, async (req, res) => {
  try {
    const db = await dbPromise;
    
    // ETAPA 5: Filtrare opțională după location_id
    const locationId = req.query.location_id ? parseInt(req.query.location_id) : null;
    
    // ETAPA 5: Include location_id și JOIN cu management_locations
    const query = locationId
      ? `SELECT 
          i.id,
          i.name,
          i.current_stock,
          i.min_stock,
          i.unit,
          i.location_id,
          ml.name as location_name,
          ml.type as location_type,
          (i.current_stock - i.min_stock) as deficit,
          CASE 
            WHEN i.current_stock = 0 THEN 'CRITIC'
            WHEN i.current_stock <= i.min_stock THEN 'ATENȚIE'
            ELSE 'OK'
          END as status
        FROM ingredients i
        LEFT JOIN management_locations ml ON i.location_id = ml.id
        WHERE i.current_stock <= i.min_stock AND i.location_id = ?
        ORDER BY i.location_id, deficit ASC`
      : `SELECT 
          i.id,
          i.name,
          i.current_stock,
          i.min_stock,
          i.unit,
          i.location_id,
          ml.name as location_name,
          ml.type as location_type,
          (i.current_stock - i.min_stock) as deficit,
          CASE 
            WHEN i.current_stock = 0 THEN 'CRITIC'
            WHEN i.current_stock <= i.min_stock THEN 'ATENȚIE'
            ELSE 'OK'
          END as status
        FROM ingredients i
        LEFT JOIN management_locations ml ON i.location_id = ml.id
        WHERE i.current_stock <= i.min_stock
        ORDER BY i.location_id, deficit ASC`;
    
    const params = locationId ? [locationId] : [];
    
    db.all(query, params, (err, rows) => {
      if (err) {
        console.error('❌ [ETAPA 5] Error in inventory alerts:', err);
        return res.status(500).json({ error: err.message });
      }
      
      console.log(`✅ [ETAPA 5] Returnate ${rows ? rows.length : 0} alerte${locationId ? ` pentru location_id=${locationId}` : ''}`);
      
      // ETAPA 5: Grupează alertele per gestiune
      const alertsByLocation = {};
      const totalStats = {
        total: 0,
        critical: 0,
        warning: 0
      };
      
      (rows || []).forEach(row => {
        const locKey = row.location_name || `Location ${row.location_id}`;
        
        if (!alertsByLocation[locKey]) {
          alertsByLocation[locKey] = {
            location_id: row.location_id,
            location_name: row.location_name,
            location_type: row.location_type,
            alerts: [],
            stats: {
              total: 0,
              critical: 0,
              warning: 0
            }
          };
        }
        
        alertsByLocation[locKey].alerts.push(row);
        alertsByLocation[locKey].stats.total++;
        if (row.status === 'CRITIC') {
          alertsByLocation[locKey].stats.critical++;
          totalStats.critical++;
        } else if (row.status === 'ATENȚIE') {
          alertsByLocation[locKey].stats.warning++;
          totalStats.warning++;
        }
        totalStats.total++;
      });
      
      res.json({
        success: true,
        totalStats,
        byLocation: alertsByLocation,
        allAlerts: rows || []
      });
    });
    
  } catch (error) {
    console.error('❌ [ETAPA 5] Error in inventory alerts:', error);
    res.status(500).json({ success: false, error: 'Eroare la încărcarea alertelor de stoc' });
  }
});

// GET /api/admin/dashboard/revenue-chart - Date pentru graficul de evoluție venituri și marjă brută
app.get('/api/admin/dashboard/revenue-chart', checkAdminAuth, async (req, res) => {
  try {
    const db = await dbPromise;
    const days = 7; // Ultimele 7 zile
    
    // Generează datele pentru ultimele 7 zile
    const chartData = [];
    const today = new Date();
    
    for (let i = days - 1; i >= 0; i--) {
      const date = new Date(today);
      date.setDate(date.getDate() - i);
      const dateStr = date.toISOString().slice(0, 10);
      
      // Calculează veniturile pentru această zi
      const revenue = await new Promise((resolve, reject) => {
        db.all(`
          SELECT items, total 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [dateStr], (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          let totalRevenue = 0;
          rows.forEach(order => {
            if (order.total && order.total > 0) {
              totalRevenue += order.total;
            } else if (order.items) {
              try {
                const items = safeParseItems(order.items);
                if (Array.isArray(items)) {
                  items.forEach(item => {
                    if (item.finalPrice && item.quantity) {
                      totalRevenue += item.finalPrice * item.quantity;
                    }
                  });
                }
              } catch (parseError) {
                console.warn('⚠️ Eroare la parsarea items pentru comanda:', parseError.message);
              }
            }
          });
          
          resolve(totalRevenue);
        });
      });
      
      // Calculează COGS-ul pentru această zi
      const cogs = await new Promise((resolve, reject) => {
        db.all(`
          SELECT items 
          FROM orders 
          WHERE DATE(timestamp) = ? AND is_paid = 1
        `, [dateStr], async (err, rows) => {
          if (err) {
            reject(err);
            return;
          }
          
          let totalCOGS = 0;
          
          for (const order of rows) {
            if (!order.items) continue;
            
            try {
              const items = safeParseItems(order.items);
              if (!Array.isArray(items)) continue;
              
              for (const item of items) {
                if (!item.productId || !item.quantity) continue;
                
                // Găsește rețeta pentru produs
                const recipeRows = await new Promise((resolveRecipe, rejectRecipe) => {
                  db.all(`
                    SELECT r.quantity_needed, i.cost_per_unit
                    FROM recipes r
                    JOIN ingredients i ON r.ingredient_id = i.id
                    WHERE r.product_id = ?
                  `, [item.productId], (err, rows) => {
                    if (err) rejectRecipe(err);
                    else resolveRecipe(rows);
                  });
                });
                
                // Calculează costul ingredientelor pentru această cantitate
                recipeRows.forEach(recipe => {
                  if (recipe.quantity_needed && recipe.cost_per_unit) {
                    const ingredientCost = recipe.quantity_needed * recipe.cost_per_unit;
                    totalCOGS += ingredientCost * item.quantity;
                  }
                });
              }
              
            } catch (parseError) {
              console.warn('⚠️ Eroare la parsarea items pentru comanda:', parseError.message);
            }
          }
          
          resolve(totalCOGS);
        });
      });
      
      const grossMargin = revenue - cogs;
      const marginPercentage = revenue > 0 ? (grossMargin / revenue * 100) : 0;
      
      chartData.push({
        date: dateStr,
        revenue: Math.round(revenue * 100) / 100,
        cogs: Math.round(cogs * 100) / 100,
        grossMargin: Math.round(grossMargin * 100) / 100,
        marginPercentage: Math.round(marginPercentage * 10) / 10
      });
    }
    
    res.json(chartData);
    
  } catch (error) {
    console.error('❌ Error in revenue chart data:', error);
    res.status(500).json({ error: 'Eroare la încărcarea datelor pentru grafic' });
  }
});

