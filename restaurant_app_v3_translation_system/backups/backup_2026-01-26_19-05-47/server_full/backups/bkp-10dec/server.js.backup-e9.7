app.get('/api/admin/inventory/low-stock', checkAdminAuth, async (req, res) => {
  try {
    const db = await dbPromise;
    
    const lowStockIngredients = await new Promise((resolve, reject) => {
      db.all(`
        SELECT 
          i.*,
          CASE 
            WHEN i.current_stock <= 0 THEN 'out_of_stock'
            WHEN i.current_stock <= i.min_stock THEN 'low_stock'
            ELSE 'ok'
          END as stock_status
        FROM ingredients i
        WHERE i.current_stock <= i.min_stock
        ORDER BY (i.current_stock / i.min_stock) ASC
      `, (err, rows) => {
        if (err) reject(err);
        else resolve(rows || []);
