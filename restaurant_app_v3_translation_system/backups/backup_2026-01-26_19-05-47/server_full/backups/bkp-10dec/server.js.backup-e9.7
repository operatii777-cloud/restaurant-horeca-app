  app.get('/api/menu/all', async (req, res) => {
    const lang = (req.query.lang || 'ro').toLowerCase();
    
    try {
      // 🚀 OPTIMIZARE: Folosește cache-ul în loc de query direct la DB
      const cache = await loadMenuCache();
      
      // 🚀 CACHE HTTP: Permite browser-ului să cache-uiască meniul (5 minute)
      // Folosim timestamp-ul cache-ului pentru ETag (dacă cache-ul se schimbă, ETag se schimbă)
      const cacheTimestamp = cache.lastUpdated || Date.now();
      res.setHeader('Cache-Control', 'public, max-age=300'); // 5 minute
      res.setHeader('ETag', `"menu-${cacheTimestamp}"`); // ETag bazat pe cache timestamp
      
      // Verifică If-None-Match pentru a returna 304 Not Modified dacă cache-ul nu s-a schimbat
      const ifNoneMatch = req.headers['if-none-match'];
      if (ifNoneMatch === `"menu-${cacheTimestamp}"`) {
        return res.status(304).end(); // Not Modified
      }
      let products = cache.products;
      
      // Verifică setarea pentru controlul afișării produselor cu stoc 0
      const db = await dbPromise;
      const setting = await new Promise((resolve, reject) => {
        db.get(`SELECT value FROM app_settings WHERE key = 'auto_manage_product_display'`, (err, row) => {
          if (err) reject(err);
          else resolve(row);
        });
      });
      
      const autoManageDisplay = setting && setting.value === 'true';
      
      // Aplică filtrarea pentru auto-manage dacă este activată
      if (autoManageDisplay) {
        // Pentru auto-manage, trebuie să verificăm stocurile din DB
        const productsWithStock = await new Promise((resolve, reject) => {
          db.all(`SELECT m.id, COALESCE(ps.current_stock, 0) AS current_stock, COALESCE(ps.is_auto_managed, 1) AS is_auto_managed
                  FROM menu m
                  LEFT JOIN product_stock ps ON m.id = ps.product_id`, (err, rows) => {
            if (err) reject(err);
            else resolve(rows || []);
          });
        });
        
        const stockMap = new Map(productsWithStock.map(p => [p.id, { current_stock: p.current_stock, is_auto_managed: p.is_auto_managed }]));
        
        products = products.filter(product => {
          const stock = stockMap.get(product.id);
          return stock && (stock.current_stock > 0 || stock.is_auto_managed === 0);
        });
      }
      
      // Salvează categoria originală ÎNAINTE de transformare
      products = products.map(product => {
        const originalCategory = product.category; // Salvează categoria originală (română)
        return {
          ...product,
          category_original: originalCategory // Salvează categoria originală (română)
        };
      });

      // Aplică transformările pentru limbă
      if (lang === 'en') {
        products = products.map(product => ({
          ...product,
          name: product.name_en || product.name,
          category: product.category_en || product.category, // Categoria tradusă
          description: product.description_en || product.description,
          allergens: product.allergens_en || product.allergens,
          category_original: product.category_original || product.category // Păstrează categoria originală (fallback)
        }));
      }
      
      // Procesează personalizările pentru fiecare produs
      const promises = products.map(product => {
        // Salvează category_original în variabilă separată pentru closure
        const originalCategory = product.category_original || product.category;
        
        return new Promise((resolve, reject) => {
          const selectOptions = lang === 'en'
            ? `SELECT id, menu_item_id, COALESCE(NULLIF(option_name_en, ''), option_name) AS option_name, option_name AS option_name_ro, option_type, extra_price FROM customization_options WHERE menu_item_id = ?`
            : `SELECT id, menu_item_id, option_name, option_type, extra_price FROM customization_options WHERE menu_item_id = ?`;
          db.all(selectOptions, [product.id], (customErr, options) => {
            if (customErr) return reject(customErr);
            // Fallback: dacă traducerea lipsă, cădem pe română pentru acel câmp
            const safeProduct = { ...product };
            if (lang === 'en' && USE_EN_FALLBACK) {
              // if English equals Romanian or is empty, translate from Romanian on the fly
              if (safeProduct.name_ro && (!safeProduct.name || safeProduct.name.trim() === safeProduct.name_ro.trim())) {
                safeProduct.name = translateRoToEn(safeProduct.name_ro);
              }
              if (safeProduct.description_ro && (!safeProduct.description || safeProduct.description.trim() === (safeProduct.description_ro || '').trim())) {
                safeProduct.description = translateRoToEn(safeProduct.description_ro);
              }
              if (safeProduct.category_ro && (!safeProduct.category || safeProduct.category.trim() === safeProduct.category_ro.trim())) {
                safeProduct.category = translateRoToEn(safeProduct.category_ro);
              }
              if (safeProduct.allergens_ro && (!safeProduct.allergens || safeProduct.allergens.trim() === (safeProduct.allergens_ro || '').trim())) {
                safeProduct.allergens = translateRoToEn(safeProduct.allergens_ro);
              }
            }
            const mappedOptions = (options || []).map(o => {
              if (lang === 'en' && USE_EN_FALLBACK && o.option_name_ro && (!o.option_name || o.option_name.trim() === o.option_name_ro.trim())) {
                return { ...o, option_name: translateRoToEn(o.option_name_ro) };
              }
              return { ...o };
            });
            delete safeProduct.name_ro;
            delete safeProduct.description_ro;
            delete safeProduct.category_ro;
            delete safeProduct.allergens_ro;
            // Asigură-te că category_original este păstrat (folosește variabila din closure)
            safeProduct.category_original = originalCategory;
            resolve({ ...safeProduct, customizations: mappedOptions });
          });
        });
      });
  
      Promise.all(promises)
        .then(async (fullMenu) => {
          // 🚫 FILTREAZĂ produsele de ambalaje pentru clienți
          let filteredMenu = fullMenu.filter(product => product.is_takeout_only !== 1 && product.is_takeout_only !== true);
          console.log(`📦 Filtrat ${fullMenu.length - filteredMenu.length} produse de ambalaje din meniul clientului`);
          
          // 🚫 FILTREAZĂ categoriile Playwright (teste)
          const beforePlaywrightFilter = filteredMenu.length;
          filteredMenu = filteredMenu.filter(product => {
            const category = product.category || product.category_original || '';
            return !category.toLowerCase().includes('playwright');
          });
          const playwrightFiltered = beforePlaywrightFilter - filteredMenu.length;
          if (playwrightFiltered > 0) {
            console.log(`🚫 Filtrat ${playwrightFiltered} produse cu categorii Playwright (teste)`);
          }
          
          // Obține ordinea corectă a categoriilor din menu_pdf_categories (cu fallback dacă eșuează)
          let cleanOrderedCategories = [];
          
          try {
            const categoryOrder = await new Promise((resolve, reject) => {
              db.all(`
                SELECT category_name, category_type, order_index
                FROM menu_pdf_categories
                WHERE display_in_pdf = 1
                ORDER BY category_type, order_index, category_name
              `, (err, rows) => {
                if (err) {
                  console.error('⚠️ Eroare la obținerea ordinii categoriilor:', err);
                  resolve([]); // Fallback: returnează array gol
                } else {
                  resolve(rows || []);
                }
              });
            });

            // Creează un map pentru ordinea categoriilor
            const categoryOrderMap = new Map();
            
            categoryOrder.forEach((cat, index) => {
              // Pentru fiecare categorie din config, găsește categoria tradusă (EN) sau originală (RO)
              if (lang === 'en') {
                // Caută primul produs din această categorie pentru a obține category_en
                const productInCategory = filteredMenu.find(p => 
                  p.category_original === cat.category_name
                );
                
                // Folosește categoria tradusă din produs sau traduce automat
                const categoryNameEn = productInCategory ? 
                  productInCategory.category : 
                  (cat.category_name === 'Băuturi și Coctailuri' ? 'Alcoholic Cocktails' :
                   cat.category_name === 'Cafea/Ciocolată/Ceai' ? 'Coffee/Chocolate/Tea' :
                   cat.category_name === 'Răcoritoare' ? 'Soft Drinks' :
                   cat.category_name === 'Coctailuri Non-Alcoolice' ? 'Non-Alcoholic Cocktails' :
                   cat.category_name);
                
                categoryOrderMap.set(categoryNameEn, { order: index, original: cat.category_name });
              } else {
                categoryOrderMap.set(cat.category_name, { order: index, original: cat.category_name });
              }
            });

            // Creează lista de categorii ordonată (în ordinea din menu_pdf_categories)
            const orderedCategories = [];
            categoryOrderMap.forEach((value, key) => {
              orderedCategories[value.order] = key;
            });

            // Elimină undefined-urile
            cleanOrderedCategories = orderedCategories.filter(cat => cat !== undefined);
          } catch (categoryError) {
            console.error('⚠️ Eroare la procesarea ordinii categoriilor:', categoryError);
            // Fallback: folosește categorii din produse
            cleanOrderedCategories = [...new Set(filteredMenu.map(item => item.category))];
          }
          
          res.json({ 
            message: `Meniul complet a fost preluat.`, 
            data: filteredMenu, 
            lang,
            categories_ordered: cleanOrderedCategories
          });
        })
        .catch(error => {
          console.error('❌ Eroare la preluarea meniului:', error);
          res.status(500).json({ error: "Eroare la preluarea personalizărilor: " + error.message });
        });
      
    } catch (error) {
      console.error('❌ Eroare la încărcarea meniului:', error);
      res.status(500).json({ error: 'Eroare la încărcarea meniului' });
    }
  });

  // ==================== ENDPOINT PUT /api/menu/:id ====================
  // Actualizează un produs din meniu (folosit pentru alergeni)
  app.put('/api/menu/:id', async (req, res) => {
    const productId = parseInt(req.params.id);
    const { allergens, allergens_en, name, description, price, category } = req.body;

    if (!productId || isNaN(productId)) {
      return res.status(400).json({ error: 'ID produs invalid' });
    }

    try {
      const db = await dbPromise;

      const updates = [];
      const params = [];

      if (allergens !== undefined) {
        updates.push('allergens = ?');
        params.push(allergens);
      }

      if (allergens_en !== undefined) {
        updates.push('allergens_en = ?');
        params.push(allergens_en);
      }

      if (name !== undefined) {
        updates.push('name = ?');
        params.push(name);
      }

      if (description !== undefined) {
        updates.push('description = ?');
        params.push(description);
      }

      if (price !== undefined) {
        updates.push('price = ?');
        params.push(price);
      }

      if (category !== undefined) {
        updates.push('category = ?');
        params.push(category);
      }

      if (updates.length === 0) {
        return res.status(400).json({ error: 'Niciun câmp de actualizat' });
      }

      // Adaugă ID-ul la sfârșitul parametrilor
      params.push(productId);

      // Execută update-ul
      const query = `UPDATE menu SET ${updates.join(', ')} WHERE id = ?`;
      
      await new Promise((resolve, reject) => {
        db.run(query, params, function(err) {
          if (err) reject(err);
          else resolve(this);
        });
      });

      console.log(`✅ [Menu] Produs #${productId} actualizat:`, updates.join(', '));

      // Invalidează cache-ul
      if (menuCache) {
        menuCache.lastUpdated = 0;
      }
      await loadMenuCache();
      console.log(`🔄 Cache-ul meniului reîncărcat`);

      // Returnează produsul actualizat
      const updatedProduct = await new Promise((resolve, reject) => {
        db.get('SELECT * FROM menu WHERE id = ?', [productId], (err, row) => {
          if (err) reject(err);
          else resolve(row);
        });
      });

      res.json({
        success: true,
        message: 'Produs actualizat cu succes',
        product: updatedProduct
      });

    } catch (error) {
      console.error(`❌ [Menu] Eroare la actualizarea produsului #${productId}:`, error);
      res.status(500).json({ error: 'Eroare la actualizarea produsului: ' + error.message });
    }
  });

