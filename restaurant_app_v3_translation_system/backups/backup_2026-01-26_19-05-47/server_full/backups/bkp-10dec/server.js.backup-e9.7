  // GET /api/audit/alerts - Listă alertări active
  app.get('/api/audit/alerts', authenticateUser, requirePermission('users.view'), async (req, res) => {
    try {
      const db = await dbPromise;
      
      // Obține reguli active
      db.all('SELECT * FROM security_alert_rules WHERE is_active = 1', [], async (err, rules) => {
        if (err) {
          return res.status(500).json({ error: err.message });
        }
        
        const alerts = [];
        const now = new Date();
        
        // Pentru fiecare regulă, verifică dacă există alertări
        for (const rule of rules) {
          const timeWindow = new Date(now.getTime() - rule.time_window_minutes * 60 * 1000);
          
          if (rule.rule_type === 'failed_logins') {
            db.all(`
              SELECT username, ip, COUNT(*) as count
              FROM admin_login_history
              WHERE success = 0 AND login_time >= ?
              GROUP BY username, ip
              HAVING count >= ?
            `, [timeWindow.toISOString(), rule.threshold], (err, rows) => {
              if (!err && rows.length > 0) {
                rows.forEach(row => {
                  alerts.push({
                    id: alerts.length + 1,
                    alert_type: rule.rule_type,
                    rule_name: rule.rule_name,
                    severity: rule.severity,
                    message: `${row.count} încercări de login eșuate de la IP ${row.ip} pentru utilizator ${row.username}`,
                    username: row.username,
                    ip_address: row.ip,
                    timestamp: now.toISOString(),
                    resolved: false
                  });
                });
              }
            });
          } else if (rule.rule_type === 'massive_deletions') {
            db.all(`
              SELECT user_id, COUNT(*) as count
              FROM audit_log
              WHERE action = 'DELETE' AND timestamp >= ?
              GROUP BY user_id
              HAVING count >= ?
            `, [timeWindow.toISOString(), rule.threshold], (err, rows) => {
              if (!err && rows.length > 0) {
                rows.forEach(row => {
                  alerts.push({
                    id: alerts.length + 1,
                    alert_type: rule.rule_type,
                    rule_name: rule.rule_name,
                    severity: rule.severity,
                    message: `${row.count} ștergeri detectate în perioada recentă`,
                    user_id: row.user_id,
                    timestamp: now.toISOString(),
                    resolved: false
                  });
                });
              }
            });
          }
        }
        
        // Așteaptă puțin pentru query-uri asincrone
        setTimeout(() => {
          res.json(alerts);
        }, 500);
      });
    } catch (error) {
      console.error('❌ Eroare la obținerea alertărilor:', error);
      res.status(500).json({ error: 'Eroare la obținerea alertărilor' });
    }
  });

