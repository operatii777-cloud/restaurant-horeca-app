    const db = await dbPromise;

    const order = await getAsync(db, `SELECT id, total FROM orders WHERE id = ?`, [orderId]);
    if (!order) return res.status(404).json({ error: 'Comanda nu a fost găsită.' });

    // calcule TVA simplificat (mock)
    const totalAmount = safeNumber(order.total, 0);
    const vat_amount = roundNumber(totalAmount * 0.19, 2); // mock 19%

    // gen receipt number simplu
    const receiptNumber = `R${Date.now().toString().slice(-9)}`;

    let tx = false;
    try {
      await runAsync(db, 'BEGIN TRANSACTION');
      tx = true;

      const ins = await runAsync(
        db,
        `
          INSERT INTO fiscal_receipts (
            order_id, receipt_number, total_amount, vat_amount, payment_method, is_fiscal, vat_details
          ) VALUES (?, ?, ?, ?, ?, 1, ?)
        `,
        [orderId, receiptNumber, totalAmount, vat_amount, paymentMethod, JSON.stringify({ vat_19: vat_amount })]
      );

      await runAsync(
        db,
        `UPDATE orders SET status = 'paid', is_paid = 1 WHERE id = ?`,
        [orderId]
      );

      try {
        io.emit('orderPaid', { orderId, receiptNumber });
      } catch {}

      await runAsync(db, 'COMMIT');
      tx = false;

      // ========================================
      // ✅ NOU FLUX: Generează stock_moves SALE_OUT pentru POS
      // ========================================
      // După fiscalizare reușită, generează mișcări SALE_OUT pe baza rețetelor
      // Folosim consumeStockForOrder (idempotent, verifică dacă există deja)
      // NU mai folosim decreaseIngredientStock (eliminat pentru a evita dublu-consum)
      // ========================================
      try {
        const tenantId = DEFAULT_TENANT_ID;
        const result = await consumeStockForOrder(tenantId, orderId, ORDER_SOURCE.POS);
        console.log(`✅ [POS Fiscalize #${orderId}] consumeStockForOrder:`, result);
        if (result.skipped) {
          console.log(`ℹ️ [POS Fiscalize #${orderId}] Stock moves deja generate anterior - skip`);
        } else {
          console.log(`✅ [POS Fiscalize #${orderId}] ${result.consumedLines} linii stock_moves generate`);
        }
      } catch (consErr) {
        console.error(`❌ [POS Fiscalize #${orderId}] ⚠️ Eroare la consumeStockForOrder:`, consErr);
        // Nu blocăm fiscalizarea dacă apare o eroare la generarea stock_moves
      }

      res.json({ success: true, fiscalReceiptId: ins.lastID, receiptNumber });
    } catch (error) {
      if (tx) {
        try { await runAsync(db, 'ROLLBACK'); } catch {}
      }
      throw error;
    }
  } catch (error) {
    console.error('❌ Eroare la fiscalizare POS:', error);
    res.status(500).json({ error: 'Eroare la fiscalizare POS' });
  }
});

