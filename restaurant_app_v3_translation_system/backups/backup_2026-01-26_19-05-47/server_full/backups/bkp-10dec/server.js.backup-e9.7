      const storageUsedMB = totalSizeBytes / (1024 * 1024);
      res.json({
        backups: details,
        stats: {
          totalBackups: details.length,
          lastBackupAt: details[0]?.createdAt ?? null,
          retentionCount: DEFAULT_RETENTION,
          watchdogActive: null,
          storageUsedMB: Number.isFinite(storageUsedMB) ? Number(storageUsedMB.toFixed(2)) : null,
          storageQuotaMB: null,
        },
      });
    } catch (error) {
      console.error('Error fetching backup details:', error);
      res.status(500).json({ error: 'Eroare la obținerea detaliilor backup-urilor' });
