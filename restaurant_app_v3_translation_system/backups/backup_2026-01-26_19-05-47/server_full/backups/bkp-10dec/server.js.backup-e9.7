          name: productInfo?.name || 'Produs',
          quantity: item.quantity,
          finalPrice: item.finalPrice,
          isFree: item.isFree || false,
          customizations: item.customizations || [],
          status: 'pending', // Doar item-urile noi sunt pending
          station,
          isDailyMenu: item.isDailyMenu || false
        };
      }));
      
      // Combină item-urile existente cu cele noi
      const allItems = [...existingItems, ...enrichedNewItems];
      
      // Actualizează comanda în baza de date
      await new Promise((resolve, reject) => {
        db.run('UPDATE orders SET items = ?, timestamp = ?, status = ? WHERE id = ?', 
          [JSON.stringify(allItems), getCurrentUTCTimestamp(), 'pending', orderId], 
          function(err) {
