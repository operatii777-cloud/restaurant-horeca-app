  // Endpoint pentru achitarea unui grup de comenzi cu bon nefiscal grupat
  app.put('/api/orders/group-paid', async (req, res) => {
    const { tableNumber, clientIdentifier, payment_method = 'cash' } = req.body;
    
    if (!tableNumber || !clientIdentifier) {
      return res.status(400).json({ error: 'TableNumber și clientIdentifier sunt obligatorii.' });
    }
    
    const paidTime = getCurrentUTCTimestamp();
    
    try {
      // 1. Verifică dacă toate comenzile din grup sunt livrate
      const groupOrders = await new Promise((resolve, reject) => {
        db.all(`
          SELECT id, status, total, items 
          FROM orders 
          WHERE table_number = ? AND client_identifier = ? AND is_paid = 0
          ORDER BY timestamp ASC
        `, [tableNumber, clientIdentifier], (err, rows) => {
          if (err) reject(err);
          else resolve(rows);
        });
      });
      
      if (groupOrders.length === 0) {
        return res.status(404).json({ 
          error: 'Nu s-au găsit comenzi neplătite pentru acest grup.' 
        });
      }
      
      // Verifică dacă toate comenzile sunt livrate
      const notDeliveredOrders = groupOrders.filter(order => order.status !== 'delivered');
      if (notDeliveredOrders.length > 0) {
        return res.status(400).json({ 
          error: 'Nu se poate achita grupul de comenzi!',
          message: 'Toate comenzile din grup trebuie să fie livrate înainte de achitare.',
          pendingOrders: notDeliveredOrders.map(o => o.id)
        });
      }
      
      // 2. Marchează toate comenzile ca plătite
      const updateResult = await new Promise((resolve, reject) => {
        db.run('UPDATE orders SET is_paid = 1, paid_timestamp = ?, payment_method = ? WHERE table_number = ? AND client_identifier = ? AND is_paid = 0', 
          [paidTime, payment_method, tableNumber, clientIdentifier], function(err) {
          if (err) reject(err);
          else resolve({ changes: this.changes });
        });
      });
      
      // 3. Generează un singur bon nefiscal pentru toate comenzile din grup
      const groupReceiptResult = await generateGroupFiscalReceipt(groupOrders, payment_method);
      
      // 4. Actualizează toate comenzile cu același fiscal_receipt_id
      if (groupReceiptResult.success) {
        const updatePromises = groupOrders.map(order => {
          return new Promise((resolve, reject) => {
            db.run('UPDATE orders SET fiscal_receipt_id = ?, status = ? WHERE id = ?', 
              [groupReceiptResult.receipt_id, 'paid', order.id], (err) => {
              if (err) reject(err);
              else resolve();
            });
          });
        });
        
        await Promise.all(updatePromises);
        
        console.log(`✅ Bon nefiscal grupat generat: ${groupReceiptResult.receipt_number} pentru ${groupOrders.length} comenzi`);
        console.log(`💰 Suma totală: ${groupReceiptResult.total_amount} RON`);
      }
      
      // 5. Șterge sesiunea clientului din memorie pentru a permite comenzi noi
      if (clientSessions.has(tableNumber)) {
        const tableSession = clientSessions.get(tableNumber);
        // Găsește și șterge clientToken-ul pentru acest clientIdentifier
        for (const [token, identifier] of tableSession.clients.entries()) {
          if (identifier === clientIdentifier) {
            tableSession.clients.delete(token);
            break;
          }
        }
      }
      
      // 6. Trimite notificare WebSocket
      io.emit('groupPaid', { 
        tableNumber: tableNumber, 
        clientIdentifier: clientIdentifier,
        paidTime: paidTime,
        ordersUpdated: updateResult.changes,
        receiptNumber: groupReceiptResult.receipt_number,
        totalAmount: groupReceiptResult.total_amount
      });
      
      // Șterge complet sesiunea clientului din memorie pentru a permite comenzi noi cu un nou identificator
      if (clientSessions.has(tableNumber)) {
        const tableSession = clientSessions.get(tableNumber);
        // Găsește și șterge clientToken-ul pentru acest clientIdentifier
        for (const [token, identifier] of tableSession.clients.entries()) {
          if (identifier === clientIdentifier) {
            tableSession.clients.delete(token);
            console.log(`🔄 Sesiunea clientului ${clientIdentifier} de la masa ${tableNumber} a fost ștearsă pentru a permite o nouă sesiune`);
            break;
          }
        }
      }
      
      // Șterge și din activeClientSessions
      if (activeClientSessions[tableNumber]) {
        activeClientSessions[tableNumber] = activeClientSessions[tableNumber].filter(s => s.identifier !== clientIdentifier);
        console.log(`🔄 Clientul ${clientIdentifier} a fost eliminat din activeClientSessions pentru masa ${tableNumber}`);
      }
      
      res.json({ 
        success: true,
        message: `Grupul de comenzi pentru masa ${tableNumber} - client ${clientIdentifier} a fost achitat cu un singur bon nefiscal.`,
        ordersUpdated: updateResult.changes,
        tableNumber: tableNumber,
        clientIdentifier: clientIdentifier,
        receiptNumber: groupReceiptResult.receipt_number,
        totalAmount: groupReceiptResult.total_amount,
        groupOrders: groupOrders.map(o => o.id)
      });
      
    } catch (error) {
      console.error('❌ Eroare la achitarea grupului de comenzi:', error);
      res.status(500).json({ error: error.message });
    }
  });

