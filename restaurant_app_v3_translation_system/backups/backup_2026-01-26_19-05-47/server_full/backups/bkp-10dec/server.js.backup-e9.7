  // ========== MONITOR CLIENȚI - Centralizator comenzi bucătărie + bar ==========
  // Afișează comenzi "În Lucru" și "Gata de Livrare" pentru display public
  app.get('/api/orders-display/client-monitor', (req, res) => {
    const lang = (req.query.lang || 'ro').toLowerCase();
    
    // Preia toate comenzile active din ultimele 6 ore (include și completed pentru "Gata")
    const sixHoursAgo = new Date(Date.now() - 6 * 60 * 60 * 1000).toISOString();
    
    db.all(`
      SELECT id, table_number, type, timestamp, items, status, completed_timestamp 
      FROM orders 
      WHERE timestamp >= ? AND status NOT IN ('cancelled', 'paid')
      ORDER BY timestamp ASC
    `, [sixHoursAgo], (err, rows) => {
      if (err) {
        console.error('❌ Eroare SQL client-monitor:', err);
        return res.status(500).json({ error: err.message });
      }
      
      const inProgress = [];  // Comenzi cu cel puțin un item pending
      const ready = [];       // Comenzi cu TOATE itemurile completed
      
      (rows || []).forEach(order => {
        const items = safeParseItems(order.items) || [];
        
        // Filtrează doar itemurile din bucătărie și bar (ignoră alte stații)
        const relevantItems = items.filter(it => 
          it && (it.station === 'kitchen' || it.station === 'bar')
        );
        
        if (relevantItems.length === 0) return;
        
        // Numără statusurile
        const pendingItems = relevantItems.filter(it => 
          it.status === 'pending' || it.status === 'preparing' || !it.status
        );
        const completedItems = relevantItems.filter(it => 
          it.status === 'completed' || it.status === 'delivered'
        );
        
        const orderInfo = {
          id: order.id,
          orderNumber: String(order.id).slice(-4), // Ultimele 4 cifre
          tableNumber: order.table_number,
          type: order.type,
          timestamp: order.timestamp,
          completedTimestamp: order.completed_timestamp,
          totalItems: relevantItems.length,
          pendingCount: pendingItems.length,
          completedCount: completedItems.length,
          // Detalii pe stații
          kitchenPending: items.filter(it => it.station === 'kitchen' && (it.status === 'pending' || it.status === 'preparing' || !it.status)).length,
          kitchenDone: items.filter(it => it.station === 'kitchen' && (it.status === 'completed' || it.status === 'delivered')).length,
          barPending: items.filter(it => it.station === 'bar' && (it.status === 'pending' || it.status === 'preparing' || !it.status)).length,
          barDone: items.filter(it => it.station === 'bar' && (it.status === 'completed' || it.status === 'delivered')).length
        };
        
        // Clasificare: dacă toate sunt complete = GATA, altfel = ÎN LUCRU
        if (pendingItems.length === 0 && completedItems.length > 0) {
          ready.push(orderInfo);
        } else if (pendingItems.length > 0) {
          inProgress.push(orderInfo);
        }
      });
      
      // Sortează: cele gata - cele mai recente primele (pentru flash effect)
      ready.sort((a, b) => new Date(b.completedTimestamp || b.timestamp) - new Date(a.completedTimestamp || a.timestamp));
      
      res.json({ 
        inProgress, 
        ready,
        stats: {
          totalInProgress: inProgress.length,
          totalReady: ready.length
        }
      });
    });
  });

