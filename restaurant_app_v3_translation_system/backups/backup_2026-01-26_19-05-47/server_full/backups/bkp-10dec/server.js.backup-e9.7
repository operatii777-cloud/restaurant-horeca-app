    const timeout = setTimeout(() => {
        if (!res.headersSent) {
            console.log(`⏰ REQUEST TIMEOUT: ${req.path} (${timeoutMs}ms)`);
            res.status(408).json({ 
                error: 'Request timeout',
                timeout: timeoutMs,
                path: req.path
            });
        }
    }, timeoutMs);
    
    res.on('finish', () => clearTimeout(timeout));
    res.on('close', () => clearTimeout(timeout));
    next();
});

// Middleware pentru verificare autentificare admin
// ==================== MIDDLEWARE AUTENTIFICARE ȘI AUTORIZARE ====================

// Middleware pentru autentificare bazată pe sesiuni
async function authenticateUser(req, res, next) {
  try {
    const authHeader = req.headers['authorization'];
    const sessionCookie = req.headers.cookie && req.headers.cookie.includes('sessionToken=');
    
    let sessionToken = null;
    
    if (authHeader) {
      const token = authHeader.startsWith('Bearer ') ? authHeader.substring(7) : authHeader;
      if (token && token !== 'true' && !token.startsWith('admin_')) {
        sessionToken = token;
      }
    }
    
    if (sessionCookie) {
      const cookieMatch = req.headers.cookie.match(/sessionToken=([^;]+)/);
      if (cookieMatch) {
        sessionToken = cookieMatch[1];
      }
    }
    
    // Fallback pentru compatibilitate cu sistemul vechi
    if (!sessionToken && authHeader) {
      const token = authHeader.startsWith('Bearer ') ? authHeader.substring(7) : authHeader;
      if (token === 'true' || token.startsWith('admin_')) {
        req.user = { id: 1, username: 'admin', role_name: 'Super Admin' };
        return next();
      }
    }
    
    if (!sessionToken) {
      return res.status(401).json({ error: 'Token de sesiune necesar' });
    }
    
    const session = await validateSession(sessionToken);
    if (!session) {
      return res.status(401).json({ error: 'Sesiune invalidă sau expirată' });
    }
    
    // ✅ SESSION TIMEOUT: Verifică inactivitate (15 minute)
    const SESSION_TIMEOUT = 15 * 60 * 1000; // 15 minute
    if (session.last_activity) {
      const lastActivity = new Date(session.last_activity).getTime();
      const now = Date.now();
      
      if (now - lastActivity > SESSION_TIMEOUT) {
        // Expirare sesiune - șterge sesiunea
        const db = await dbPromise;
        db.run('DELETE FROM user_sessions WHERE session_token = ?', [sessionToken]);
        
        return res.status(401).json({ 
          error: 'Sesiune expirată din cauza inactivității', 
          code: 'SESSION_TIMEOUT' 
        });
      }
    }
    
    // Actualizează last_activity
    await updateSessionActivity(sessionToken);
    
    req.user = {
      id: session.user_id,
      username: session.username,
      role_id: session.role_id,
      role_name: session.role_name
    };
    
    next();
  } catch (error) {
    console.error('Eroare la autentificare:', error);
    res.status(500).json({ error: 'Eroare la autentificare' });
  }
}

// Middleware pentru verificarea permisiunilor
function requirePermission(permissionName) {
  return async (req, res, next) => {
    try {
      if (!req.user) {
        return res.status(401).json({ error: 'Autentificare necesară' });
      }
      
      const hasPermission = await checkPermission(req.user.id, permissionName);
      if (!hasPermission) {
        return res.status(403).json({ 
          error: 'Permisiune insuficientă', 
          required: permissionName,
          user_role: req.user.role_name 
        });
      }
      
      next();
    } catch (error) {
      console.error('Eroare la verificarea permisiunii:', error);
      res.status(500).json({ error: 'Eroare la verificarea permisiunii' });
    }
  };
}

// Middleware pentru audit log (îmbunătățit - loghează automat toate acțiunile)
function auditLog(action, resourceType = null) {
  return (req, res, next) => {
    const startTime = Date.now();
    const originalSend = res.send;
    
    res.send = function(data) {
      const duration = Date.now() - startTime;
      
      // Loghează doar dacă request-ul a fost procesat cu succes și există user
      if (res.statusCode < 400 && req.user) {
        const resourceId = req.params.id || req.body.id || null;
        const oldValues = req.body.oldValues ? JSON.stringify(req.body.oldValues) : null;
        const newValues = req.body.newValues ? JSON.stringify(req.body.newValues) : null;
        
        // Log audit complet cu toate detaliile
        logAuditEvent(
          req.user.id,
          `${req.method} ${req.path} - ${action}`,
          resourceType || req.path.split('/')[2] || 'unknown',
          resourceId,
          oldValues,
          newValues,
          req.ip,
          req.get('User-Agent')
        ).catch(err => console.error('Eroare la audit log:', err));
      }
      
      originalSend.call(this, data);
    };
    
    next();
  };
}

// Middleware pentru audit automat pe toate rutele /api/* (opțional - pentru logging complet)
function autoAuditMiddleware(req, res, next) {
  // Aplică doar pe rute sensibile (nu pe health checks, static files, etc.)
  if (req.path.startsWith('/api/') && req.user && req.method !== 'GET') {
    const startTime = Date.now();
    const originalSend = res.send;
    
    res.send = function(data) {
      if (res.statusCode < 400) {
        const resourceId = req.params.id || req.body.id || null;
        const resourceType = req.path.split('/')[2] || 'unknown';
        
        logAuditEvent(
          req.user.id,
          `${req.method} ${req.path}`,
          resourceType,
          resourceId,
          req.method === 'PUT' || req.method === 'PATCH' ? JSON.stringify(req.body) : null,
          req.method === 'POST' || req.method === 'PUT' || req.method === 'PATCH' ? JSON.stringify(req.body) : null,
          req.ip,
          req.get('User-Agent')
        ).catch(err => console.error('Eroare la auto audit log:', err));
      }
      
      originalSend.call(this, data);
    };
  }
  
  next();
}

// Middleware pentru compatibilitate cu sistemul vechi
function checkAdminAuth(req, res, next) {
  const authHeader = req.headers['authorization'];
  const adminCookie = req.headers.cookie && req.headers.cookie.includes('adminAuth=true');
  
  if (authHeader) {
    const token = authHeader.startsWith('Bearer ') ? authHeader.substring(7) : authHeader;
    
    if (token && (token.startsWith('admin_') || token === 'true')) {
      req.user = { id: 1, username: 'admin', role_name: 'Super Admin' };
      next();
      return;
    }
  }
  
  if (adminCookie) {
    req.user = { id: 1, username: 'admin', role_name: 'Super Admin' };
    next();
    return;
  }
  
  // Pentru testare, acceptă și request-uri fără autentificare dacă sunt din localhost
  if (req.headers.host && req.headers.host.includes('localhost')) {
    console.log('⚠️ Acces admin permis pentru localhost (mod testare)');
    next();
    return;
  }
  
  res.status(401).json({ error: 'Necesită autentificare admin' });
}

