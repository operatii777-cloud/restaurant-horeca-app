io.on('connection', (socket) => {
  console.log('✅ Client conectat:', socket.id);

  // Gestionare erori pentru socket individual
  socket.on('error', (error) => {
    console.error(`❌ [SOCKET ERROR] Eroare pentru socket ${socket.id}:`, error.message);
    console.error('📍 Stack:', error.stack);
  });

  // Gestionare deconectare neașteptată
  socket.on('disconnect', (reason) => {
    console.log(`⚠️ Client deconectat: ${socket.id}, motiv: ${reason}`);
    // Șterge socket-ul din activeClientSessions
    for (const tableNumber in activeClientSessions) {
      activeClientSessions[tableNumber] = activeClientSessions[tableNumber].filter(s => s.socketId !== socket.id);
    }
  });

