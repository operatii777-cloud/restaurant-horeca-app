        return res.status(400).json({ 
          success: false, 
          error: 'Tip de raport invalid' 
        });
    }
    
    // Generează HTML pentru PDF
    const html = generatePDFHTML(title, data, type);
    
    res.setHeader('Content-Type', 'text/html');
    res.send(html);
    
  } catch (error) {
    console.error('Eroare la exportul PDF:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Eroare la generarea raportului PDF' 
    });
  }
});

