  // Funcție pentru crearea unei comenzi supervisor noi
  async function createNewSupervisorOrder(orderData, res) {
    try {
      const db = await dbPromise;
      const { type, isTogether, items, tableNumber, clientIdentifier, food_notes, drink_notes, general_notes, currentTime } = orderData;
      
      // Procesează item-urile
      const barCategories = new Set(['Cafea/Ciocolată/Ceai', 'Răcoritoare', 'Băuturi și Coctailuri']);
      
      const enrichedItems = await Promise.all(items.map(async (item) => {
        // Obține numele produsului din baza de date
        const productInfo = await new Promise((resolve, reject) => {
          db.get('SELECT name, category FROM menu WHERE id = ?', [item.productId], (err, row) => {
            if (err) reject(err);
            else resolve(row);
          });
        });
        
        const category = productInfo?.category || '';
        const station = barCategories.has(category) ? 'bar' : 'kitchen';
        const itemId = `it_${Date.now()}_${Math.floor(Math.random()*1e9)}`;
        
        return {
          itemId,
          productId: item.productId,
          name: productInfo?.name || 'Produs',
          quantity: item.quantity,
          finalPrice: item.finalPrice,
          isFree: item.isFree || false,
          customizations: item.customizations || [],
          status: 'pending',
          station,
          isDailyMenu: item.isDailyMenu || false
        };
      }));
      
      // Calculează totalul
      const total = enrichedItems.reduce((sum, item) => sum + (item.finalPrice * item.quantity), 0);
      
      // Inserează comanda în baza de date
      const result = await new Promise((resolve, reject) => {
        db.run(`INSERT INTO orders (type, isTogether, items, table_number, client_identifier, 
                food_notes, drink_notes, general_notes, timestamp, total, status) 
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
          [type, isTogether, JSON.stringify(enrichedItems), tableNumber, clientIdentifier,
           food_notes, drink_notes, general_notes, currentTime, total, 'pending'],
          function(err) {
            if (err) reject(err);
            else resolve(this);
          });
      });
      
      const orderId = result.lastID;
      
      // Trimite notificări pentru fiecare item
      enrichedItems.forEach(item => {
        io.emit('newOrder', {
          orderId: orderId,
          item: item,
          tableNumber: tableNumber,
          clientIdentifier: clientIdentifier,
          orderType: type, // here/takeout
          isTogether: isTogether, // true/false
          isSupervisorOrder: true // Flag pentru comenzi supervisor
        });
      });
      
      console.log(`✅ Comandă supervisor creată: ${orderId} pentru masa ${tableNumber} - ${clientIdentifier}`);
      
      return res.json({
        success: true,
        message: 'Comanda supervisor a fost creată cu succes',
        orderId: orderId,
        tableNumber: tableNumber,
        clientIdentifier: clientIdentifier,
        items: enrichedItems.length
      });
      
    } catch (error) {
      console.error('❌ Eroare la crearea comenzii supervisor:', error);
      return res.status(500).json({ error: 'Eroare la crearea comenzii supervisor' });
    }
  }
  
