const sanitizeNirLinesPayload = (lines) => {
  if (!Array.isArray(lines) || lines.length === 0) {
    const error = new Error('Trebuie să adaugi cel puțin o linie în NIR.');
    error.statusCode = 400;
    throw error;
  }

  return lines.map((line, index) => {
    const ingredientId = toPositiveInt(line.ingredient_id);
    const quantity = safeNumber(line.quantity, 0);
    const unitPrice = Math.max(0, safeNumber(line.unit_price, 0));
    const tvaPercent = Math.max(0, safeNumber(line.tva_percent, 0));

    if (!ingredientId) {
      const error = new Error(`Ingredient ID invalid la linia ${index + 1}.`);
      error.statusCode = 400;
      throw error;
    }
    if (quantity <= 0) {
      const error = new Error(`Cantitatea trebuie să fie > 0 la linia ${index + 1}.`);
      error.statusCode = 400;
      throw error;
    }

    const totalLine = roundNumber(quantity * unitPrice, 4);
    const totalTvaLine = roundNumber(totalLine * (tvaPercent / 100), 4);
    const lotNumber =
      typeof line.lot_number === 'string' && line.lot_number.trim()
        ? line.lot_number.trim()
        : null;

    return {
      ingredient_id: ingredientId,
      quantity,
      unit_price: unitPrice,
      tva_percent: tvaPercent,
      total_line: totalLine,
      total_tva_line: totalTvaLine,
      lot_number: lotNumber,
      line_index: index,
    };
  });
};

