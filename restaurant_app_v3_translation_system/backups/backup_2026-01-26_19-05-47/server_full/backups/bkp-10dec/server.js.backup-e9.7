// GET /api/admin/inventory/filters - Filtre rapide pentru stocuri
app.get('/api/admin/inventory/filters', checkAdminAuth, async (req, res) => {
  try {
    const db = await dbPromise;
    
    // Obține categorii unice
    const categories = await new Promise((resolve, reject) => {
      db.all(`
        SELECT DISTINCT category 
        FROM ingredients 
        WHERE category IS NOT NULL AND category != '' AND is_available = 1
        ORDER BY category
      `, (err, rows) => {
        if (err) reject(err);
        else resolve(rows || []);
      });
    });
    
    // Obține furnizori unici
    const suppliers = await new Promise((resolve, reject) => {
      db.all(`
        SELECT DISTINCT supplier 
        FROM ingredients 
        WHERE supplier IS NOT NULL AND supplier != '' AND is_available = 1
        ORDER BY supplier
      `, (err, rows) => {
        if (err) reject(err);
        else resolve(rows || []);
      });
    });
    
    // Obține unități unice
    const units = await new Promise((resolve, reject) => {
      db.all(`
        SELECT DISTINCT unit 
        FROM ingredients 
        WHERE unit IS NOT NULL AND unit != '' AND is_available = 1
        ORDER BY unit
      `, (err, rows) => {
        if (err) reject(err);
        else resolve(rows || []);
      });
    });
    
    // Statistici rapide
    const stats = await new Promise((resolve, reject) => {
      db.get(`
        SELECT 
          COUNT(*) as total_ingredients,
          COUNT(CASE WHEN current_stock <= 0 THEN 1 END) as out_of_stock,
          COUNT(CASE WHEN current_stock <= min_stock AND current_stock > 0 THEN 1 END) as low_stock,
          COUNT(CASE WHEN current_stock > min_stock THEN 1 END) as ok_stock
        FROM ingredients 
        WHERE is_available = 1
      `, (err, row) => {
        if (err) reject(err);
        else resolve(row || {});
      });
    });
    
    res.json({
      success: true,
      data: {
        categories: categories.map(c => c.category),
        suppliers: suppliers.map(s => s.supplier),
        units: units.map(u => u.unit),
        stats: stats
      }
    });
    
  } catch (error) {
    console.error('Eroare la obținerea filtrelor:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Eroare la obținerea filtrelor' 
    });
  }
});

// GET /api/admin/inventory/filtered - Stocuri cu filtre
app.get('/api/admin/inventory/filtered', checkAdminAuth, async (req, res) => {
  try {
    const { 
      category, 
      supplier, 
      unit, 
      stock_status, 
      min_stock, 
      max_stock,
      sort_by,
      sort_order
    } = req.query;
    
    const db = await dbPromise;
    
    let whereClause = 'WHERE i.is_available = 1';
    let params = [];
    
    if (category) {
      whereClause += ' AND i.category = ?';
      params.push(category);
    }
    
    if (supplier) {
      whereClause += ' AND i.supplier = ?';
      params.push(supplier);
    }
    
    if (unit) {
      whereClause += ' AND i.unit = ?';
      params.push(unit);
    }
    
    if (stock_status) {
      switch (stock_status) {
        case 'out_of_stock':
          whereClause += ' AND i.current_stock <= 0';
          break;
        case 'low_stock':
          whereClause += ' AND i.current_stock <= i.min_stock AND i.current_stock > 0';
          break;
        case 'ok_stock':
          whereClause += ' AND i.current_stock > i.min_stock';
          break;
      }
    }
    
    if (min_stock) {
      whereClause += ' AND i.current_stock >= ?';
      params.push(parseFloat(min_stock));
    }
    
    if (max_stock) {
      whereClause += ' AND i.current_stock <= ?';
      params.push(parseFloat(max_stock));
    }
    
    let orderClause = 'ORDER BY i.name';
    if (sort_by) {
      const validSortFields = ['name', 'category', 'current_stock', 'min_stock', 'cost_per_unit', 'last_updated'];
      if (validSortFields.includes(sort_by)) {
        orderClause = `ORDER BY i.${sort_by}`;
        if (sort_order === 'desc') {
          orderClause += ' DESC';
        }
      }
    }
    
    const ingredients = await new Promise((resolve, reject) => {
      db.all(`
        SELECT 
          i.id,
          i.name,
          i.category,
          i.unit,
          i.current_stock,
          i.min_stock,
          i.cost_per_unit,
          i.supplier,
          i.last_updated,
          CASE 
            WHEN i.current_stock <= 0 THEN 'out_of_stock'
            WHEN i.current_stock <= i.min_stock THEN 'low_stock'
            ELSE 'ok_stock'
          END as stock_status,
          (i.current_stock * i.cost_per_unit) as total_value
        FROM ingredients i
        ${whereClause}
        ${orderClause}
      `, params, (err, rows) => {
        if (err) reject(err);
        else resolve(rows || []);
      });
    });
    
    res.json({
      success: true,
      data: ingredients,
      summary: {
        total: ingredients.length,
        out_of_stock: ingredients.filter(i => i.stock_status === 'out_of_stock').length,
        low_stock: ingredients.filter(i => i.stock_status === 'low_stock').length,
        ok_stock: ingredients.filter(i => i.stock_status === 'ok_stock').length,
        total_value: ingredients.reduce((sum, i) => sum + (i.total_value || 0), 0)
      }
    });
    
  } catch (error) {
    console.error('Eroare la filtrarea stocurilor:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Eroare la filtrarea stocurilor' 
    });
  }
});

