  max: 1000, // Max 1000 request-uri per 15 min per IP
  message: { error: 'Prea multe request-uri. Încercați din nou în 15 minute.' },
  standardHeaders: true,
  legacyHeaders: false,
  skip: (req) => {
    const ip = req.ip || '';
    return ip === '::1' || ip === '127.0.0.1' || ip === '::ffff:127.0.0.1';
  },
  handler: (req, res) => {
    console.warn(`⚠️ Rate limit depășit pentru IP: ${req.ip}`);
    res.status(429).json({ 
      error: 'Prea multe request-uri',
      retryAfter: '15 minute'
    });
  }
});
app.use(globalLimiter);
