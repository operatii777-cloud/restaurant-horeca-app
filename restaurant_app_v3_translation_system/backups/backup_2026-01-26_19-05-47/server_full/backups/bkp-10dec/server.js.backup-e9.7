app.get('/api/admin/inventory/invoices', checkAdminAuth, async (req, res) => {
  try {
    const { status, supplier, start_date, end_date } = req.query;
    const db = await dbPromise;
    
    let whereClause = 'WHERE 1=1';
    let params = [];
    
    if (status) {
      whereClause += ' AND status = ?';
      params.push(status);
    }
    
    if (supplier) {
      whereClause += ' AND supplier_name LIKE ?';
      params.push(`%${supplier}%`);
    }
    
    if (start_date && end_date) {
      whereClause += ' AND invoice_date BETWEEN ? AND ?';
      params.push(start_date, end_date);
    }
    
    const invoices = await new Promise((resolve, reject) => {
      db.all(`
        SELECT * FROM supplier_invoices 
        ${whereClause}
        ORDER BY invoice_date DESC, created_at DESC
      `, params, (err, rows) => {
        if (err) reject(err);
        else resolve(rows || []);
      });
    });
    
    res.json({
      success: true,
      data: invoices
    });
    
  } catch (error) {
    console.error('Eroare la obținerea facturilor:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Eroare la obținerea facturilor' 
    });
  }
});

// PUT /api/admin/inventory/invoices/:id/process - Procesează o factură
app.put('/api/admin/inventory/invoices/:id/process', checkAdminAuth, async (req, res) => {
  try {
    const invoiceId = req.params.id;
    const { batches } = req.body; // Array de loturi din factură
    
    if (!batches || !Array.isArray(batches)) {
      return res.status(400).json({ 
        success: false, 
        error: 'Lipsește array-ul de loturi' 
      });
    }

    const db = await dbPromise;
    
    // Începem tranzacția
    db.run('BEGIN TRANSACTION', async (err) => {
      if (err) {
        return res.status(500).json({ 
          success: false, 
          error: 'Eroare la începerea tranzacției' 
        });
      }

      try {
        // Adăugăm fiecare lot
        for (const batch of batches) {
          await addIngredientBatch(batch.ingredient_id, batch);
        }
        
        // Actualizăm statusul facturii
        await new Promise((resolve, reject) => {
          db.run(`
            UPDATE supplier_invoices 
            SET status = 'processed', processed_at = CURRENT_TIMESTAMP
            WHERE id = ?
          `, [invoiceId], function(err) {
            if (err) reject(err);
            else resolve();
          });
        });
        
        // Commit tranzacția
        db.run('COMMIT', (commitErr) => {
          if (commitErr) {
            return res.status(500).json({ 
              success: false, 
              error: 'Eroare la finalizarea procesării' 
            });
          }
          
          res.json({
            success: true,
            message: `Factura a fost procesată cu succes. Adăugate ${batches.length} loturi.`
          });
        });
        
      } catch (error) {
        // Rollback în caz de eroare
        db.run('ROLLBACK', () => {
          console.error('Eroare la procesarea facturii:', error);
          res.status(500).json({ 
            success: false, 
            error: 'Eroare la procesarea facturii' 
          });
        });
      }
    });
    
  } catch (error) {
    console.error('Eroare la procesarea facturii:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Eroare la procesarea facturii' 
    });
  }
});

// GET /api/admin/inventory/expiring - Obține ingredientele care expiră în curând
app.get('/api/admin/inventory/expiring', checkAdminAuth, async (req, res) => {
  try {
    const { days = 7 } = req.query;
    const db = await dbPromise;
    
    const expiringBatches = await new Promise((resolve, reject) => {
      db.all(`
        SELECT 
          ib.*,
          i.name as ingredient_name,
          i.unit,
          i.min_stock,
          i.current_stock,
          CASE 
            WHEN ib.expiry_date <= date('now') THEN 'expired'
            WHEN ib.expiry_date <= date('now', '+${parseInt(days)} days') THEN 'expiring_soon'
            ELSE 'ok'
          END as expiry_status
        FROM ingredient_batches ib
        JOIN ingredients i ON ib.ingredient_id = i.id
        WHERE ib.expiry_date IS NOT NULL 
          AND ib.expiry_date <= date('now', '+${parseInt(days)} days')
          AND ib.remaining_quantity > 0
        ORDER BY ib.expiry_date ASC
      `, (err, rows) => {
        if (err) reject(err);
        else resolve(rows || []);
      });
    });
    
    res.json({
      success: true,
      data: expiringBatches,
      summary: {
        total_expiring: expiringBatches.length,
        expired: expiringBatches.filter(b => b.expiry_status === 'expired').length,
        expiring_soon: expiringBatches.filter(b => b.expiry_status === 'expiring_soon').length
      }
    });
    
  } catch (error) {
    console.error('Eroare la obținerea ingredientelor care expiră:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Eroare la obținerea ingredientelor care expiră' 
    });
  }
});

