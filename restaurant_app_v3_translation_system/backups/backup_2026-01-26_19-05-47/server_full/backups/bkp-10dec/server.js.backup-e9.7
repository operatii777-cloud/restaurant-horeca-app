// Populate English columns in DB from Romanian using the translator where EN is missing
async function autoPopulateEnTranslations(db) {
  try {
    await new Promise((resolve) => db.serialize(resolve));
    // Menu rows
    await new Promise((resolve) => {
      db.all('SELECT id, name, description, category, allergens, COALESCE(name_en, "") AS name_en, COALESCE(description_en, "") AS description_en, COALESCE(category_en, "") AS category_en, COALESCE(allergens_en, "") AS allergens_en FROM menu', [], (err, rows) => {
        if (err) return resolve();
        const tasks = (rows || []).map(r => new Promise(res2 => {
          const nextNameEn = r.name_en && r.name_en.trim() ? r.name_en : translateRoToEn(r.name || '');
          const nextDescEn = r.description_en && r.description_en.trim() ? r.description_en : translateRoToEn(r.description || '');
          const nextCatEn = r.category_en && r.category_en.trim() ? r.category_en : translateRoToEn(r.category || '');
          const nextAllEn = r.allergens_en && r.allergens_en.trim() ? r.allergens_en : translateRoToEn(r.allergens || '');
          db.run('UPDATE menu SET name_en = ?, description_en = ?, category_en = ?, allergens_en = ? WHERE id = ?', [nextNameEn, nextDescEn, nextCatEn, nextAllEn, r.id], () => res2());
        }));
        Promise.all(tasks).then(() => resolve());
      });
    });
    // Customization options
    await new Promise((resolve) => {
      db.all('SELECT id, option_name, COALESCE(option_name_en, "") AS option_name_en FROM customization_options', [], (err, rows) => {
        if (err) return resolve();
        const tasks = (rows || []).map(r => new Promise(res2 => {
          const nextOptEn = r.option_name_en && r.option_name_en.trim() ? r.option_name_en : translateRoToEn(r.option_name || '');
          db.run('UPDATE customization_options SET option_name_en = ? WHERE id = ?', [nextOptEn, r.id], () => res2());
        }));
        Promise.all(tasks).then(() => resolve());
      });
    });
    // Re-export CSVs so files reflect updated EN for manual refinement
    // await exportTranslationsCSV(); // Commented out to avoid error
  } catch (e) {
    console.error('autoPopulateEnTranslations error:', e);
  }
}

/**
 * 🔄 Calculează și actualizează automat alergenii unui produs final
 * pe baza ingredientelor din rețetă
 * 
 * @param {number} productId - ID-ul produsului din tabela menu
 * @param {object} db - Conexiunea la baza de date
 * @returns {Promise<string>} - Lista de alergeni calculați
 */
async function calculateAndUpdateProductAllergens(productId, db) {
    try {
        console.log(`🔄 [Alergeni] Calculare automată pentru produsul #${productId}...`);

        // 1. Obține toate ingredientele din rețetă
        const ingredients = await new Promise((resolve, reject) => {
            db.all(`
                SELECT i.allergens, i.potential_allergens, i.additives, i.name
                FROM recipes r
                JOIN ingredients i ON r.ingredient_id = i.id
                WHERE r.product_id = ? AND r.item_type = 'ingredient'
            `, [productId], (err, rows) => {
                if (err) reject(err);
                else resolve(rows || []);
            });
        });

        if (ingredients.length === 0) {
            console.log(`⚠️ [Alergeni] Produsul #${productId} nu are ingrediente în rețetă`);
            return '';
        }

        console.log(`   📦 Găsite ${ingredients.length} ingrediente în rețetă`);

        // 2. Colectează toți alergenii unici
        const allergensSet = new Set();
        const potentialAllergensSet = new Set();
        const additivesSet = new Set();

        for (const ingredient of ingredients) {
            // Alergeni declarați
            if (ingredient.allergens) {
                ingredient.allergens.split(',').forEach(a => {
                    const allergen = a.trim();
                    if (allergen && allergen !== '0' && allergen !== '-') {
                        allergensSet.add(allergen);
                        console.log(`   ✓ Alergen din "${ingredient.name}": ${allergen}`);
                    }
                });
            }

            // Alergeni potențiali
            if (ingredient.potential_allergens) {
                ingredient.potential_allergens.split(',').forEach(a => {
                    const allergen = a.trim();
                    if (allergen && allergen !== '0' && allergen !== '-') {
                        potentialAllergensSet.add(allergen);
                    }
                });
            }

            // Aditivi
            if (ingredient.additives) {
                ingredient.additives.split(',').forEach(a => {
                    const additive = a.trim();
                    if (additive && additive !== '0' && additive !== '-') {
                        additivesSet.add(additive);
                    }
                });
            }
        }

        // 3. Construiește lista finală de alergeni
        const allergensList = Array.from(allergensSet).sort().join(', ');
        const potentialAllergensList = Array.from(potentialAllergensSet).sort().join(', ');
        const additivesList = Array.from(additivesSet).sort().join(', ');

        // 4. Construiește textul complet pentru afișare
        let finalAllergensText = allergensList;
        if (potentialAllergensList) {
            finalAllergensText += ` (posibil: ${potentialAllergensList})`;
        }

        // 5. Traduce automat în engleză
        const finalAllergensTextEn = translateRoToEn(finalAllergensText);

        console.log(`   ✅ Alergeni calculați: ${finalAllergensText || 'niciunul'}`);
        if (additivesList) {
            console.log(`   ℹ️ Aditivi identificați: ${additivesList}`);
        }

        // 6. Salvează în baza de date
        await new Promise((resolve, reject) => {
            db.run(`
                UPDATE menu 
                SET allergens = ?, allergens_en = ?
                WHERE id = ?
            `, [finalAllergensText, finalAllergensTextEn, productId], (err) => {
                if (err) reject(err);
                else resolve();
            });
        });

        console.log(`   💾 Salvat în tabela menu pentru produsul #${productId}`);

        // 7. Invalidează cache-ul pentru a reflecta modificările
        // FIX: Nu setăm cache-ul la null pentru a evita race conditions
        // În loc, resetăm timestamp-ul pentru a forța reîncărcarea
        if (menuCache) {
            menuCache.lastUpdated = 0; // Forțează reîncărcare la următorul acces
        }
        await loadMenuCache(); // Reîncarcă cache-ul
        console.log(`   🔄 Cache invalidat și reîncărcat`);

        return finalAllergensText;

    } catch (error) {
        console.error(`❌ [Alergeni] Eroare la calcularea alergenilor pentru produsul #${productId}:`, error);
        throw error;
    }
}

async function startServer() {
  console.log('🔍 [DEBUG] startServer() apelat...');
  
  let db;
  try {
    console.log('🔍 [DEBUG] Aștept dbPromise în startServer()...');
    db = await dbPromise;
    console.log('✅ [DEBUG] dbPromise obținut în startServer()');
    console.log("✅ Baza de date este gata. Se pornesc endpoint-urile serverului...");
  } catch (dbError) {
    console.error('❌ [DEBUG] Eroare la obținerea dbPromise în startServer():', dbError.message);
    console.error('❌ [DEBUG] Stack:', dbError.stack);
    console.error('❌ [DEBUG] Cod eroare:', dbError.code);
    // Continuă fără database pentru debug (temporar)
    console.log('⚠️ [DEBUG] Continuă fără database (mod debug)...');
    db = null;
  }

  // 🔥 Configurare processor pentru In-Memory Queue (dacă este activ)
  if (stockQueue && queueType === 'memory') {
    console.log('🔧 Configurare processor pentru In-Memory Queue...');
    
    stockQueue.process(async (job) => {
      const { orderId, finalItems, orderType } = job.data;

      const normalizeOrderType = (type) => {
        const value = (type || '').toString().toLowerCase();
        if (['here', 'restaurant', 'dine_in', 'dine-in'].includes(value)) return 'dine_in';
        if (['takeout', 'pick-up', 'pickup', 'takeaway'].includes(value)) return 'takeout';
        if (value === 'delivery') return 'delivery';
        if (['drive_thru', 'drive-thru', 'drivethru'].includes(value)) return 'drive_thru';  // NOU (05 Dec 2025)
        return 'dine_in';
      };

      const normalizedOrderType = normalizeOrderType(orderType);
      const packagingType =
        normalizedOrderType === 'dine_in' ? 'packaging_restaurant' : 'packaging_delivery';

      console.log(`🔄 [Queue Processor] Procesare comanda #${orderId} - ${finalItems.length} produse`);
      
      // Calculează ingredientele de scăzut (logica din server.js)
      const ingredientsMap = new Map();
      
      // ETAPA 4: Map pentru a stoca location_id per ingredient
      const ingredientLocationMap = new Map(); // { ingredient_id: location_id }
      
      for (const item of finalItems) {
        const productId = item.productId;
        const qty = item.quantity;
        
        // ETAPA 4: Obține preparation_section pentru produs
        const product = await new Promise((resolve, reject) => {
          db.get(`SELECT preparation_section FROM menu WHERE id = ?`, [productId], (err, row) => {
            if (err) reject(err);
            else resolve(row);
          });
        });
        
        // ETAPA 4: Determină location_id din preparation_section
        const locationId = product && product.preparation_section 
          ? await getLocationIdFromPreparationSection(product.preparation_section)
          : 1; // Default: Gestiune Principală
        
        console.log(`🔵 [Queue] Produs #${productId} → Preparation: ${product?.preparation_section || 'n/a'} → Location ID: ${locationId}`);
        
        // Obține rețeta pentru produs
        const recipes = await new Promise((resolve, reject) => {
          db.all(
            `
            SELECT ingredient_id, quantity_needed, item_type, unit, waste_percentage, variable_consumption 
            FROM recipes 
            WHERE product_id = ? AND (item_type = 'ingredient' OR item_type = ? OR item_type = 'packaging_delivery')
          `,
            [productId, packagingType],
            (err, rows) => {
              if (err) reject(err);
              else resolve(rows || []);
            }
          );
        });
        
        // Calculează cantitatea necesară pentru fiecare ingredient
        for (const recipe of recipes) {
          // Skip packaging-uri necorespunzătoare tipului de comandă
          if (normalizedOrderType === 'dine_in' && recipe.item_type === 'packaging_delivery') {
            continue;
          }
          
          // Calculează cantitatea brută (cu waste)
          const grossQuantity = calculateGrossQuantity(
            recipe,
            normalizedOrderType,
            item.customizations || []
          );
          
          const totalNeeded = grossQuantity * qty;

          if (!Number.isFinite(totalNeeded)) {
            console.warn(
              `⚠️ [Queue Processor #${orderId}] Cantitate invalidă pentru ingredient ${recipe.ingredient_id} (grossQuantity=${grossQuantity}, qty=${qty}). Ingredientul este omis.`
            );
            continue;
          }
          
          // Adaugă în map (agregare per ingredient)
          if (ingredientsMap.has(recipe.ingredient_id)) {
            ingredientsMap.set(recipe.ingredient_id, ingredientsMap.get(recipe.ingredient_id) + totalNeeded);
          } else {
            ingredientsMap.set(recipe.ingredient_id, totalNeeded);
          }
          
          // ETAPA 4: Stochează location_id pentru acest ingredient
          if (!ingredientLocationMap.has(recipe.ingredient_id)) {
            ingredientLocationMap.set(recipe.ingredient_id, locationId);
          }
        }
      }
      
      // ========================================
      // 🔴 LEGACY STOCK CONSUMPTION – DISABLED (moved to consumeStockForOrder)
      // ========================================
      // ❌ ELIMINAT: await decreaseIngredientStock(ingredientsToDecrease, orderId);
      // 
      // MOTIV: decreaseIngredientStock modifica ingredients.current_stock direct (legacy)
      //        și cauza dublu-consum când era apelat împreună cu consumeStockForOrder.
      // 
      // ✅ NOU FLUX: Folosim doar consumeStockForOrder care:
      //        - Generează stock_moves SALE_OUT (singura sursă de adevăr pentru vânzări)
      //        - NU modifică ingredients.current_stock (legacy rămâne pentru compatibilitate)
      //        - Este idempotent (verifică dacă există deja stock_moves pentru comandă)
      // ========================================
      
      // Calculează ingredientele pentru logging (nu mai sunt folosite pentru decreaseIngredientStock)
      const ingredientsToDecrease = Array.from(ingredientsMap.entries()).map(([ingredientId, quantity]) => ({
        ingredient_id: ingredientId,
        quantity,
        location_id: ingredientLocationMap.get(ingredientId) || 1
      }));
      
      console.log(`🔵 [Queue Processor #${orderId}] ${ingredientsToDecrease.length} ingrediente calculate pentru stock_moves`);
      console.log(`🔵 [ETAPA 4] Ingrediente cu location_id:`, ingredientsToDecrease.map(i => `${i.ingredient_id}→L${i.location_id}`).join(', '));
      
      // Determină sursa comenzii pentru stock_moves (05 Dec 2025 - extins pentru drive-thru)
      const tenantId = DEFAULT_TENANT_ID;
      let source = ORDER_SOURCE.QR; // default pentru dine_in/takeout
      
      if (normalizedOrderType === 'delivery') {
        source = ORDER_SOURCE.DELIVERY;
      } else if (normalizedOrderType === 'drive_thru') {
        source = ORDER_SOURCE.DRIVE_THRU;
      } else if (normalizedOrderType === 'dine_in' || normalizedOrderType === 'takeout') {
        // Pentru QR/Supervisor/KIOSK, determinăm sursa din orderType sau context
        // Dacă orderType conține "supervisor" sau "kiosk", folosim sursa corespunzătoare
        const orderTypeStr = (orderType || '').toString().toLowerCase();
        if (orderTypeStr.includes('supervisor')) {
          source = ORDER_SOURCE.SUPERVISOR;
        } else if (orderTypeStr.includes('kiosk')) {
          source = ORDER_SOURCE.KIOSK;
        } else {
          source = ORDER_SOURCE.QR; // default pentru QR orders
        }
      }
      
      // Generează stock_moves SALE_OUT prin consumeStockForOrder (idempotent, verifică dacă există deja)
      try {
        const result = await consumeStockForOrder(tenantId, orderId, source);
        console.log(`✅ [Queue Processor #${orderId}] consumeStockForOrder (${source}):`, result);
        if (result.skipped) {
          console.log(`ℹ️ [Queue Processor #${orderId}] Stock moves deja generate anterior - skip`);
        } else {
          console.log(`✅ [Queue Processor #${orderId}] ${result.consumedLines} linii stock_moves generate`);
        }
      } catch (err) {
        console.error(`❌ [Queue Processor #${orderId}] ⚠️ Eroare la consumeStockForOrder:`, err);
        // Nu aruncăm eroare - logăm doar pentru debugging
      }
    });
    
    console.log('✅ In-Memory Queue processor configurat');
  }

  // ========================================
  // 🏥 ADVANCED HEALTH MONITORING
  // ========================================
  
