// GET /api/admin/inventory/export/excel - Export Excel pentru rapoarte stocuri
app.get('/api/admin/inventory/export/excel', checkAdminAuth, async (req, res) => {
  try {
    const { type, start_date, end_date, category, status } = req.query;
    const db = await dbPromise;
    
    let data = [];
    let filename = '';
    
    switch (type) {
      case 'stock_overview':
        data = await new Promise((resolve, reject) => {
          db.all(`
            SELECT 
              i.id,
              i.name,
              i.category,
              i.unit,
              i.current_stock,
              i.min_stock,
              i.cost_per_unit,
              i.supplier,
              i.last_updated,
              CASE 
                WHEN i.current_stock <= 0 THEN 'Fără stoc'
                WHEN i.current_stock <= i.min_stock THEN 'Stoc scăzut'
                ELSE 'OK'
              END as stock_status
            FROM ingredients i
            WHERE i.is_available = 1
            ORDER BY i.name
          `, (err, rows) => {
            if (err) reject(err);
            else resolve(rows || []);
          });
        });
        filename = 'raport_stoc_general';
        break;
        
      case 'low_stock':
        data = await new Promise((resolve, reject) => {
          db.all(`
            SELECT 
              i.name,
              i.category,
              i.unit,
              i.current_stock,
              i.min_stock,
              i.cost_per_unit,
              i.supplier,
              (i.min_stock - i.current_stock) as shortage,
              CASE 
                WHEN i.current_stock <= 0 THEN 'Fără stoc'
                ELSE 'Stoc scăzut'
              END as status
            FROM ingredients i
            WHERE i.current_stock <= i.min_stock AND i.is_available = 1
            ORDER BY (i.current_stock / i.min_stock) ASC
          `, (err, rows) => {
            if (err) reject(err);
            else resolve(rows || []);
          });
        });
        filename = 'raport_stoc_scazut';
        break;
        
      case 'expiring':
        const days = req.query.days || 30;
        data = await new Promise((resolve, reject) => {
          db.all(`
            SELECT 
              ib.batch_number,
              i.name as ingredient_name,
              i.category,
              i.unit,
              ib.quantity,
              ib.remaining_quantity,
              ib.purchase_date,
              ib.expiry_date,
              ib.supplier,
              ib.unit_cost,
              CASE 
                WHEN ib.expiry_date <= date('now') THEN 'Expirat'
                WHEN ib.expiry_date <= date('now', '+${parseInt(days)} days') THEN 'Expiră în curând'
                ELSE 'OK'
              END as expiry_status
            FROM ingredient_batches ib
            JOIN ingredients i ON ib.ingredient_id = i.id
            WHERE ib.expiry_date IS NOT NULL 
              AND ib.expiry_date <= date('now', '+${parseInt(days)} days')
              AND ib.remaining_quantity > 0
            ORDER BY ib.expiry_date ASC
          `, (err, rows) => {
            if (err) reject(err);
            else resolve(rows || []);
          });
        });
        filename = `raport_expirari_${days}_zile`;
        break;
        
      case 'batches':
        data = await new Promise((resolve, reject) => {
          db.all(`
            SELECT 
              ib.batch_number,
              ib.barcode,
              i.name as ingredient_name,
              i.category,
              i.unit,
              ib.quantity,
              ib.remaining_quantity,
              ib.purchase_date,
              ib.expiry_date,
              ib.supplier,
              ib.invoice_number,
              ib.unit_cost,
              ib.created_at
            FROM ingredient_batches ib
            JOIN ingredients i ON ib.ingredient_id = i.id
            ORDER BY ib.purchase_date DESC
          `, (err, rows) => {
            if (err) reject(err);
            else resolve(rows || []);
          });
        });
        filename = 'raport_loturi';
        break;
        
      case 'invoices':
        data = await new Promise((resolve, reject) => {
          db.all(`
            SELECT 
              invoice_number,
              supplier_name,
              invoice_date,
              total_amount,
              file_type,
              status,
              created_at,
              processed_at
            FROM supplier_invoices
            ORDER BY invoice_date DESC
          `, (err, rows) => {
            if (err) reject(err);
            else resolve(rows || []);
          });
        });
        filename = 'raport_facturi';
        break;
        
      default:
        return res.status(400).json({ 
          success: false, 
          error: 'Tip de raport invalid' 
        });
    }
    
    // Generează Excel
