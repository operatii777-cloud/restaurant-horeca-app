  app.get('/api/feedback/recent', async (req, res) => {
    const { limit = 50, minRating, maxRating, period = 'today' } = req.query;
    
    console.log('📊 GET /api/feedback/recent apelat');
    console.log('📊 Params:', { limit, minRating, maxRating, period });
    
    try {
      const db = await dbPromise;
      console.log('✅ DB Promise rezolvat');
      
      // Calculează intervalul de timp bazat pe period
      let timeCondition = '';
      switch (period) {
        case 'today':
          timeCondition = "date(timestamp) = date('now', 'localtime')";
          break;
        case 'week':
          timeCondition = "date(timestamp) >= date('now', 'localtime', '-7 days')";
          break;
        case 'month':
          timeCondition = "date(timestamp) >= date('now', 'localtime', '-1 month')";
          break;
        case 'quarter':
          timeCondition = "date(timestamp) >= date('now', 'localtime', '-3 months')";
          break;
        case 'semester':
          timeCondition = "date(timestamp) >= date('now', 'localtime', '-6 months')";
          break;
        case 'year':
          timeCondition = "date(timestamp) >= date('now', 'localtime', '-1 year')";
          break;
        case 'overall':
        case 'all':
          timeCondition = '1=1'; // Toate timpurile
          break;
        default:
          timeCondition = "date(timestamp) = date('now', 'localtime')";
      }
      
      let query = `
        SELECT 
          f.id, f.order_id, f.client_identifier, f.table_number, 
          f.rating, f.comment, f.timestamp
        FROM feedback f
        WHERE ${timeCondition}
      `;
      
      const params = [];
      
      if (minRating) {
        query += ' AND f.rating >= ?';
        params.push(minRating);
      }
      
      if (maxRating) {
        query += ' AND f.rating <= ?';
        params.push(maxRating);
      }
      
      query += ' ORDER BY f.timestamp DESC LIMIT ?';
      params.push(parseInt(limit));
      
      console.log('🔍 Query SQL:', query);
      console.log('🔍 Params:', params);
      
      const feedbacks = await new Promise((resolve, reject) => {
        db.all(query, params, (err, rows) => {
          if (err) {
            console.error('❌ Eroare query feedbacks:', err);
            reject(err);
          } else {
            console.log(`✅ Găsite ${rows?.length || 0} feedback-uri`);
            resolve(rows || []);
          }
        });
      });
      
      // Calculează statistici pentru perioada selectată
      console.log('📊 Calculez statistici...');
      const stats = await new Promise((resolve, reject) => {
        db.get(`
          SELECT 
            COUNT(*) as total,
            AVG(rating) as avgRating,
            SUM(CASE WHEN rating = 5 THEN 1 ELSE 0 END) as rating5,
            SUM(CASE WHEN rating = 4 THEN 1 ELSE 0 END) as rating4,
            SUM(CASE WHEN rating = 3 THEN 1 ELSE 0 END) as rating3,
            SUM(CASE WHEN rating = 2 THEN 1 ELSE 0 END) as rating2,
            SUM(CASE WHEN rating = 1 THEN 1 ELSE 0 END) as rating1
          FROM feedback
          WHERE ${timeCondition}
        `, (err, row) => {
          if (err) {
            console.error('❌ Eroare query stats:', err);
            reject(err);
          } else {
            console.log('✅ Statistici calculate:', row);
            resolve(row);
          }
        });
      });
      
      res.json({
        success: true,
        period: period, // Include period pentru debugging și UI
        recentFeedback: feedbacks,
        total: stats.total || 0,
        averageRating: stats.avgRating ? parseFloat(stats.avgRating) : 0,
        ratingDistribution: {
          5: stats.rating5 || 0,
          4: stats.rating4 || 0,
          3: stats.rating3 || 0,
          2: stats.rating2 || 0,
          1: stats.rating1 || 0
        }
      });
      
    } catch (error) {
      console.error('❌ Eroare la obținerea feedback-urilor:', error);
      res.status(500).json({ 
        success: false, 
        error: 'Eroare la obținerea feedback-urilor' 
      });
    }
  });

  app.get('/api/orders/history', (req, res) => {
    const dateFilter = req.query.date;
    const lang = (req.query.lang || 'ro').toLowerCase();
    let sqlQuery = 'SELECT * FROM orders WHERE status IN ("completed", "delivered", "cancelled")';
    const params = [];
    
    if (dateFilter) {
      sqlQuery += ' AND date(timestamp) = ?';
      params.push(dateFilter);
    }
    sqlQuery += ' ORDER BY timestamp DESC';
    
    db.all(sqlQuery, params, (err, rows) => {
      if (err) { return res.status(500).json({ error: err.message }); }
      
      const promises = rows.map(order => {
        return new Promise((resolve, reject) => {
          let items;
          try {
            items = safeParseItems(order.items);
          } catch (parseError) {
            console.error(`Eroare la parsarea JSON pentru comanda ${order.id}:`, parseError.message);
            console.error(`JSON corupt: ${order.items.substring(0, 200)}...`);
            // Încearcă să corecteze JSON-ul corupt
            try {
              const fixedJson = order.items
                .replace(/\\:/g, ':')  // Corectează \: cu :
                .replace(/\\"/g, '"')  // Corectează \" cu "
                .replace(/\\,/g, ',')  // Corectează \, cu ,
                .replace(/\\{/g, '{')  // Corectează \{ cu {
                .replace(/\\}/g, '}')  // Corectează \} cu }
                .replace(/\\\[/g, '[')  // Corectează \[ cu [
                .replace(/\\\]/g, ']'); // Corectează \] cu ]
              items = JSON.parse(fixedJson);
              console.log(`JSON corectat pentru comanda ${order.id}`);
            } catch (fixError) {
              console.error(`Nu s-a putut corecta JSON-ul pentru comanda ${order.id}:`, fixError.message);
              items = []; // Folosește array gol dacă nu se poate corecta
            }
          }
          const itemPromises = items.map(item => {
            return new Promise((resolveItem, rejectItem) => {
              const sel = lang === 'en' ? 'SELECT name_en, name FROM menu WHERE id = ?' : 'SELECT name FROM menu WHERE id = ?';
              db.get(sel, [item.productId], (itemErr, p) => {
                if (itemErr) return rejectItem(itemErr);
                if (lang === 'en') {
                  const enName = p && p.name_en && String(p.name_en).trim() ? p.name_en : translateRoToEn(p ? p.name : '');
                  resolveItem({ ...item, name: enName || 'N/A' });
                } else {
                resolveItem({ ...item, name: (p && p.name) ? p.name : 'N/A' });
                }
              });
            });
          });
          
          Promise.all(itemPromises).then(enriched => {
            const custIds = Array.from(new Set((enriched || []).flatMap(it => (it.customizations || []).map(c => c && c.id).filter(id => Number.isInteger(id)))));
            const finishResolve = (finalItems) => {
              let orderData = { ...order, items: finalItems };
            orderData = formatOrderTimestamps(orderData);
            if (order.completed_timestamp) {
              orderData.cookingTime = Math.round((new Date(order.completed_timestamp) - new Date(order.timestamp)) / 1000 / 60);
            }
            if (order.delivered_timestamp && order.completed_timestamp) {
              orderData.deliveryTime = Math.round((new Date(order.delivered_timestamp) - new Date(order.completed_timestamp)) / 1000 / 60);
            }
            if (order.delivered_timestamp) {
              orderData.totalTime = Math.round((new Date(order.delivered_timestamp) - new Date(order.timestamp)) / 1000 / 60);
            }
            resolve(orderData);
            };

            if (custIds.length === 0) {
              return finishResolve(enriched);
            }

            const placeholders = custIds.map(() => '?').join(',');
            const sql = `SELECT id, option_name, option_name_en FROM customization_options WHERE id IN (${placeholders})`;
            db.all(sql, custIds, (e2, rows2) => {
              const optMap = new Map((rows2 || []).map(r => [r.id, { ro: r.option_name || '', en: r.option_name_en || '' }]));
              const mapped = (enriched || []).map(it => ({
                ...it,
                customizations: (it.customizations || []).map(c => {
                  if (c && Number.isInteger(c.id) && optMap.has(c.id)) {
                    const rec = optMap.get(c.id);
                    return {
                      ...c,
                      name: (lang === 'en')
                        ? (rec.en && String(rec.en).trim() ? rec.en : translateRoToEn(rec.ro || c.name || ''))
                        : (rec.ro || c.name)
                    };
                  }
                  // fallback to existing names
                  if (lang === 'en' && c && c.name_en && String(c.name_en).trim()) return { ...c, name: c.name_en };
                  if (lang === 'ro' && c && c.name_ro && String(c.name_ro).trim()) return { ...c, name: c.name_ro };
                  return { ...c };
                })
              }));
              finishResolve(mapped);
            });
          }).catch(reject);
        });
      });
      
      Promise.all(promises).then(orders => res.json({ orders })).catch(err => res.status(500).json({ error: err.message }));
    });
  });

