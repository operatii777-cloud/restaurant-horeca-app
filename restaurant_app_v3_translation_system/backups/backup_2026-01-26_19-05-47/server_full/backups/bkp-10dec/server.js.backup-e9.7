  // NOTĂ: Endpoint-urile pentru /api/suppliers/orders sunt definite mai sus (după /api/waste)
  // Duplicate-ul de aici a fost eliminat
  // GET /api/costs - Analiză costuri și prețuri
  app.get('/api/costs', async (req, res) => {
    try {
      const { period, category_id } = req.query;
      
      // Query pentru calcularea costurilor produselor
      let query = `
        SELECT 
          m.id,
          m.name,
          m.name_en,
          m.price,
          m.category,
          COALESCE(SUM(r.quantity_needed * i.cost_per_unit), 0) as recipe_cost,
          m.price - COALESCE(SUM(r.quantity_needed * i.cost_per_unit), 0) as profit,
          CASE 
            WHEN m.price > 0 THEN ((m.price - COALESCE(SUM(r.quantity_needed * i.cost_per_unit), 0)) / m.price * 100)
            ELSE 0
          END as profit_margin
        FROM menu m
        LEFT JOIN recipes r ON m.id = r.product_id
        LEFT JOIN ingredients i ON r.ingredient_id = i.id
        WHERE m.is_sellable = 1
      `;
      const params = [];
      
      if (category_id) {
        query += ' AND m.category_id = ?';
        params.push(category_id);
      }
      
      query += ' GROUP BY m.id ORDER BY profit_margin DESC';
      
      db.all(query, params, (err, rows) => {
        if (err) {
          console.error('❌ Error fetching costs:', err);
          return res.status(500).json({ error: err.message });
        }
        
        const costs = rows.map(row => ({
          id: row.id,
          name: row.name,
          name_en: row.name_en,
          price: row.price,
          category: row.category,
          recipe_cost: parseFloat(row.recipe_cost || 0),
          profit: parseFloat(row.profit || 0),
          profit_margin: parseFloat(row.profit_margin || 0)
        }));
        
        console.log(`✅ GET /api/costs: ${costs.length} produse analizate`);
        res.json({ success: true, data: costs });
      });
    } catch (error) {
      console.error('❌ Error in GET /api/costs:', error);
      res.status(500).json({ error: error.message });
    }
  });
  
