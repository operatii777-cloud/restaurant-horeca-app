    // WAL mode pentru performanță mai bună
    db.run('PRAGMA journal_mode=WAL', (err) => {
      if (err) console.error('Eroare WAL mode:', err);
      else console.log('✅ WAL mode activat');
    });
    
    // Sincronizare normală (mai rapidă decât FULL)
    db.run('PRAGMA synchronous=NORMAL', (err) => {
      if (err) console.error('Eroare synchronous:', err);
      else console.log('✅ Synchronous NORMAL activat');
    });
    
    // Cache în memorie pentru performanță
    db.run('PRAGMA cache_size=10000', (err) => {
      if (err) console.error('Eroare cache_size:', err);
      else console.log('✅ Cache size: 10MB');
    });
    
    // Temp store în memorie
    db.run('PRAGMA temp_store=MEMORY', (err) => {
      if (err) console.error('Eroare temp_store:', err);
      else console.log('✅ Temp store în memorie');
    });
    
    // Timeout pentru operațiuni blocate
    db.run('PRAGMA busy_timeout=30000', (err) => {
      if (err) console.error('Eroare busy_timeout:', err);
      else console.log('✅ Busy timeout: 30s');
    });
    
    console.log('🚀 SQLite optimizat pentru performanță maximă!');
  }).catch(err => {
