  app.put('/api/admin/kiosk/users/:id', checkAdminAuth, async (req, res) => {
    try {
      const { id } = req.params;
      const { password, role, full_name, is_active } = req.body;
      
      const db = await dbPromise;
      
      // Verifică dacă utilizatorul există
      db.get('SELECT id FROM kiosk_users WHERE id = ?', [id], (err, user) => {
        if (err) {
          return res.status(500).json({ error: err.message });
        }
        
        if (!user) {
          return res.status(404).json({ error: 'Utilizator nu a fost găsit' });
        }
        
        // Construiește query-ul de update
        const updates = [];
        const params = [];
        
        if (password) {
          if (password.length < 4) {
            return res.status(400).json({ error: 'Parola trebuie să aibă minim 4 caractere' });
          }
          const crypto = require('crypto');
          const salt = crypto.randomBytes(16).toString('hex');
          const hash = crypto.pbkdf2Sync(password, salt, 10000, 64, 'sha512').toString('hex');
          const password_hash = `${salt}:${hash}`;
          updates.push('password_hash = ?');
          params.push(password_hash);
        }
        
        if (role && ['waiter', 'supervisor', 'admin'].includes(role)) {
          updates.push('role = ?');
          params.push(role);
