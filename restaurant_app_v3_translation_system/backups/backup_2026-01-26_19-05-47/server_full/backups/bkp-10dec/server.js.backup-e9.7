      await runAsync(db, 'COMMIT');
      transactionActive = false;

      res.json({ success: true, consumption_id: noteId });
    } catch (error) {
      if (transactionActive) {
        try {
          await runAsync(db, 'ROLLBACK');
        } catch (rollbackError) {
          console.error('⚠️ Eroare rollback bon consum:', rollbackError);
        }
      }
      throw error;
    }
  } catch (error) {
    console.error('❌ Eroare la salvarea bonului de consum:', error);
    res.status(500).json({ error: 'Eroare la salvarea bonului de consum' });
  }
});

