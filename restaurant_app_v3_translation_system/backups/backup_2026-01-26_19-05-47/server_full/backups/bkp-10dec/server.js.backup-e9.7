  app.post('/api/admin/transfer-tables', checkAdminAuth, async (req, res) => {
    try {
      const { fromWaiterId, toWaiterId, tables } = req.body ?? {};
      if (!fromWaiterId || !toWaiterId || !Array.isArray(tables) || tables.length === 0) {
        return res.status(400).json({ error: 'Parametri incompleți pentru transferul meselor.' });
      }

      const db = await dbPromise;
      db.get('SELECT tables FROM waiters WHERE id = ?', [fromWaiterId], (sourceErr, fromWaiter) => {
        if (sourceErr) {
          return res.status(500).json({ error: sourceErr.message });
        }
        if (!fromWaiter) {
          return res.status(404).json({ error: 'Ospătarul sursă nu a fost găsit.' });
        }

        const fromTables = parseWaiterTables(fromWaiter.tables);
        const remainingTables = fromTables.filter((table) => !tables.includes(table));

        db.get('SELECT tables FROM waiters WHERE id = ?', [toWaiterId], (destErr, toWaiter) => {
          if (destErr) {
            return res.status(500).json({ error: destErr.message });
          }
          if (!toWaiter) {
            return res.status(404).json({ error: 'Ospătarul destinație nu a fost găsit.' });
          }

          const toTables = parseWaiterTables(toWaiter.tables);
          const newToTables = Array.from(new Set([...toTables, ...tables]));

          db.run(
            'UPDATE waiters SET tables = ?, updated_at = CURRENT_TIMESTAMP WHERE id = ?',
            [JSON.stringify(remainingTables), fromWaiterId],
            (updateSourceErr) => {
              if (updateSourceErr) {
                return res.status(500).json({ error: updateSourceErr.message });
              }

              db.run(
                'UPDATE waiters SET tables = ?, updated_at = CURRENT_TIMESTAMP WHERE id = ?',
                [JSON.stringify(newToTables), toWaiterId],
                (updateDestErr) => {
                  if (updateDestErr) {
                    return res.status(500).json({ error: updateDestErr.message });
                  }

                  res.json({ success: true });
                }
              );
            }
          );
        });
      });
    } catch (error) {
      console.error('Eroare la transferul de mese:', error);
      res.status(500).json({ error: 'Nu am putut transfera mesele.' });
    }
  });

