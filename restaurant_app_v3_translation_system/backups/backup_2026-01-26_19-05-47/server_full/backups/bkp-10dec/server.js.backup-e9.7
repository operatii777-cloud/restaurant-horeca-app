function safeParseJson(value, fallback = null) {
  if (!value) {
    return fallback;
  }

  if (typeof value !== 'string') {
    return fallback;
  }

  try {
    return JSON.parse(value);
  } catch (error) {
    return fallback;
  }
}

function parseWaiterTables(rawValue) {
  if (!rawValue) {
    return [];
  }

  if (Array.isArray(rawValue)) {
    return rawValue;
  }

  try {
    const parsed = JSON.parse(rawValue);
    return Array.isArray(parsed) ? parsed : [];
  } catch (error) {
    console.warn('⚠️ Nu s-a putut parsa lista de mese pentru ospătar:', error);
    return [];
  }
}

function computePinRotationStatus(lastRotatedAt) {
  const now = new Date();
  const rotatedDate = lastRotatedAt ? new Date(lastRotatedAt) : null;
  const dueDate = rotatedDate ? new Date(rotatedDate.getTime() + PIN_ROTATION_INTERVAL_DAYS * DAY_IN_MS) : null;

  const daysSinceRotation = rotatedDate ? Math.floor((now.getTime() - rotatedDate.getTime()) / DAY_IN_MS) : null;
  const daysUntilDue = dueDate ? Math.ceil((dueDate.getTime() - now.getTime()) / DAY_IN_MS) : null;

  const requiresRotation = !rotatedDate || !dueDate || now >= dueDate;
  const warning = !requiresRotation && daysUntilDue !== null && daysUntilDue <= PIN_ROTATION_WARNING_DAYS;

  return {
    rotatedAt: rotatedDate ? rotatedDate.toISOString() : null,
    dueAt: dueDate ? dueDate.toISOString() : null,
    daysSinceRotation,
    daysUntilDue,
    requiresRotation,
    warning
  };
}

function sanitizeWaiterRow(row) {
  return {
    id: row.id,
    name: row.name,
    role: row.role || 'waiter',
    active: !!row.active,
    tables: parseWaiterTables(row.tables),
    createdAt: row.created_at,
    updatedAt: row.updated_at,
    lastLoginAt: row.last_login_at,
    pinPolicyVersion: row.pin_policy_version ?? PIN_ROTATION_POLICY_VERSION,
    pinStatus: computePinRotationStatus(row.pin_last_rotated_at),
    pinCompromised: !row.pin_hash,
    pinLastRotatedBy: row.pin_rotated_by || null
  };
}

function encodeInterfacePinPayload(hashData, { actorId = null, actorName = null } = {}) {
  return JSON.stringify({
    algorithm: PIN_HASH_ALGORITHM,
    keyLength: PIN_HASH_KEY_LENGTH,
    hash: hashData.hash,
    salt: hashData.salt,
    rotationPolicyVersion: PIN_ROTATION_POLICY_VERSION,
    lastRotatedAt: new Date().toISOString(),
    actorId,
    actorName
  });
}

function buildInterfacePinResponse(interfaceId, storedValue) {
  const parsed = safeParseJson(storedValue, null);

  if (parsed && parsed.hash) {
    return {
      interface: interfaceId,
      hasPin: true,
      pin: PIN_MASK,
      pinMask: PIN_MASK,
      lastRotatedAt: parsed.lastRotatedAt || null,
      policyVersion: parsed.rotationPolicyVersion ?? PIN_ROTATION_POLICY_VERSION,
      rotatedBy: parsed.actorName || null,
      algorithm: parsed.algorithm || PIN_HASH_ALGORITHM
    };
  }

  if (typeof storedValue === 'string' && PIN_PATTERN.test(storedValue)) {
    return {
      interface: interfaceId,
      hasPin: true,
      pin: PIN_MASK,
      pinMask: PIN_MASK,
      lastRotatedAt: null,
      policyVersion: PIN_ROTATION_POLICY_VERSION,
      rotatedBy: null,
      algorithm: PIN_HASH_ALGORITHM,
      legacy: true
    };
  }

  return {
    interface: interfaceId,
    hasPin: false,
    pin: null,
    pinMask: null,
    lastRotatedAt: null,
    policyVersion: PIN_ROTATION_POLICY_VERSION,
    rotatedBy: null,
    algorithm: PIN_HASH_ALGORITHM
  };
}

async function migrateLegacyInterfacePins() {
  try {
    const db = await dbPromise;
    db.all(`SELECT key, value FROM app_settings WHERE key LIKE 'pin_%'`, (err, rows) => {
      if (err || !rows || rows.length === 0) {
        if (err) {
          console.error('Eroare la încărcarea PIN-urilor legacy:', err);
        }
        return;
      }

      const migrations = rows
        .filter((row) => row && typeof row.value === 'string' && PIN_PATTERN.test(row.value))
        .map((row) => {
          const { hash, salt } = createPinHash(row.value);
          const payload = encodeInterfacePinPayload({ hash, salt });
          return new Promise((resolve) => {
            db.run('UPDATE app_settings SET value = ? WHERE key = ?', [payload, row.key], (updateErr) => {
              if (updateErr) {
                console.error(`Eroare la migrarea PIN-ului legacy pentru ${row.key}:`, updateErr);
              } else {
                console.log(`🔐 PIN legacy migrat la hash pentru ${row.key}`);
              }
              resolve();
            });
          });
        });

      if (migrations.length > 0) {
        Promise.allSettled(migrations).then(() => {
          console.log(`✅ Migrare PIN legacy finalizată pentru ${migrations.length} interfețe.`);
        });
      }
    });
  } catch (error) {
    console.error('Eroare la migrarea PIN-urilor legacy:', error);
  }
}

