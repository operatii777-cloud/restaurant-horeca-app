function parseCustomizationsPayload(raw) {
  if (raw === undefined) {
    return null;
  }

  let parsed = raw;
  if (typeof raw === 'string') {
    const trimmed = raw.trim();
    if (trimmed === '') {
      return [];
    }
    try {
      parsed = JSON.parse(trimmed);
    } catch (parseError) {
      throw new Error('PAYLOAD_INVALID');
    }
  }

  if (!Array.isArray(parsed)) {
    throw new Error('PAYLOAD_INVALID');
  }

  const sanitized = parsed
    .map((entry) => {
      if (!entry || typeof entry !== 'object') {
        return null;
      }

      const optionName = typeof entry.option_name === 'string' ? entry.option_name.trim() : '';
      if (!optionName) {
        return null;
      }

      const optionNameEnRaw = typeof entry.option_name_en === 'string' ? entry.option_name_en.trim() : '';
      const optionTypeRaw = typeof entry.option_type === 'string' ? entry.option_type.trim().toLowerCase() : '';
      const extraPriceRaw = Number(entry.extra_price);
      const idRaw = Number(entry.id);

      return {
        id: Number.isInteger(idRaw) && idRaw > 0 ? idRaw : null,
        option_name: optionName,
        option_name_en: optionNameEnRaw || optionName,
        option_type: optionTypeRaw || 'option',
        extra_price: Number.isFinite(extraPriceRaw) ? Math.round(extraPriceRaw * 100) / 100 : 0,
      };
    })
    .filter(Boolean);

  return sanitized;
}

function runAsync(db, sql, params = []) {
  return new Promise((resolve, reject) => {
    db.run(sql, params, function callback(err) {
      if (err) reject(err);
      else resolve(this);
    });
  });
}

async function runIgnoringMissingTable(db, sql, params = []) {
  try {
    await runAsync(db, sql, params);
  } catch (error) {
    if ((error.message || '').includes('no such table')) {
      console.warn(`⚠️  Skip execuție pentru tabel lipsă în interogare: ${sql}`);
      return;
    }
    throw error;
  }
}

function allAsync(db, sql, params = []) {
  return new Promise((resolve, reject) => {
    db.all(sql, params, (err, rows) => {
      if (err) reject(err);
      else resolve(rows || []);
    });
  });
}

function getAsync(db, sql, params = []) {
  return new Promise((resolve, reject) => {
    db.get(sql, params, (err, row) => {
      if (err) reject(err);
      else resolve(row || null);
    });
  });
}

function safeNumber(value, fallback = 0) {
  const parsed = Number(value);
  return Number.isFinite(parsed) ? parsed : fallback;
}

function roundNumber(value, decimals = 2) {
  const parsed = safeNumber(value, 0);
  const factor = 10 ** decimals;
  return Math.round(parsed * factor) / factor;
}

function toPositiveInt(value) {
  const parsed = Number(value);
  return Number.isInteger(parsed) && parsed > 0 ? parsed : null;
}

async function consumeFromStockLots(db, ingredientId, quantityNeeded) {
  let remaining = safeNumber(quantityNeeded, 0);
  if (remaining <= 0) {
    return 0;
  }

  const lots = await allAsync(
    db,
    `
      SELECT id, quantity_remaining
      FROM stock_lots
      WHERE ingredient_id = ? AND quantity_remaining > 0
      ORDER BY created_at ASC, id ASC
    `,
    [ingredientId]
  );

  for (const lot of lots) {
    if (remaining <= 0) {
      break;
    }
    const lotQty = safeNumber(lot.quantity_remaining, 0);
    if (lotQty <= 0) {
      continue;
    }
    const deduction = Math.min(remaining, lotQty);
    await runAsync(
      db,
      `UPDATE stock_lots SET quantity_remaining = quantity_remaining - ? WHERE id = ?`,
      [deduction, lot.id]
    );
    remaining -= deduction;
  }

  return remaining;
}

async function fetchProductCustomizations(db, productId) {
  const rows = await allAsync(
    db,
    `SELECT id, menu_item_id, option_name, option_name_en, option_type, extra_price
       FROM customization_options
      WHERE menu_item_id = ?
      ORDER BY id`,
    [productId]
  );

  return rows.map((row) => ({
    id: row.id,
    menu_item_id: row.menu_item_id,
    option_name: row.option_name,
    option_name_en: row.option_name_en || row.option_name,
    option_type: row.option_type || 'option',
    extra_price: Number(row.extra_price) || 0,
  }));
}

async function syncProductCustomizations(db, productId, customizations) {
  const existingRows = await allAsync(
    db,
    'SELECT id FROM customization_options WHERE menu_item_id = ?',
    [productId]
  );

  const existingIds = new Set(existingRows.map((row) => row.id));
  const requestedIds = new Set(
    customizations.filter((custom) => Number.isInteger(custom.id)).map((custom) => custom.id)
  );

  const deleteIds = [...existingIds].filter((id) => !requestedIds.has(id));

  await runAsync(db, 'BEGIN TRANSACTION');

  try {
    for (const deleteId of deleteIds) {
      await runAsync(db, 'DELETE FROM customization_options WHERE id = ? AND menu_item_id = ?', [
        deleteId,
        productId,
      ]);
    }

    for (const custom of customizations) {
      const params = [
        custom.option_name,
        custom.option_name_en || custom.option_name,
        custom.option_type || 'option',
        Number.isFinite(custom.extra_price) ? custom.extra_price : 0,
      ];

      if (custom.id) {
        await runAsync(
          db,
          `UPDATE customization_options
              SET option_name = ?, option_name_en = ?, option_type = ?, extra_price = ?
            WHERE id = ? AND menu_item_id = ?`,
          [...params, custom.id, productId]
        );
      } else {
        await runAsync(
          db,
          `INSERT INTO customization_options (menu_item_id, option_name, option_name_en, option_type, extra_price)
           VALUES (?, ?, ?, ?, ?)`,
          [productId, ...params]
        );
      }
    }

    await runAsync(db, 'COMMIT');
  } catch (transactionError) {
    try {
      await runAsync(db, 'ROLLBACK');
    } catch (rollbackError) {
      console.error('⚠️ Eroare la rollback pentru customizations:', rollbackError);
    }
    throw transactionError;
  }

  return fetchProductCustomizations(db, productId);
}

