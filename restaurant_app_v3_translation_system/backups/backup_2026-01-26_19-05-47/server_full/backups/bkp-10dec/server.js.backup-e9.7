      const currentTime = getCurrentUTCTimestamp();
    
      // OPTIMIZARE: Procesare cu query-uri rapide pentru numele produselor
      const barCategories = new Set(['Cafea/Ciocolată/Ceai', 'Răcoritoare', 'Băuturi și Coctailuri']);
    
    // Verifică Happy Hour-urile active și aplică reducerile
    const applyHappyHourDiscounts = async (enrichedItems) => {
      try {
        const activeHappyHourSettings = await getActiveHappyHourSettings();
        if (activeHappyHourSettings.length > 0) {
