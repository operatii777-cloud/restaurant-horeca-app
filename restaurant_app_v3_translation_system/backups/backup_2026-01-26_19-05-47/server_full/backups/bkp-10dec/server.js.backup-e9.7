app.put('/api/admin/production/batches/:id', checkAdminAuth, async (req, res) => {
  try {
    const tenantId = DEFAULT_TENANT_ID;
    const batchId = toPositiveInt(req.params.id);
    if (!batchId) {
      return res.status(400).json({ error: 'ID batch invalid.' });
    }

    const db = await dbPromise;
    const {
      batch_date,
      recipe_id,
      recipe_name,
      responsible,
      location_id,
      notes,
      status,
    } = req.body || {};

    const updates = [];
    const params = [];

    if (batch_date) {
      updates.push('batch_date = ?');
      params.push(batch_date);
    }
    if (recipe_id !== undefined) {
      updates.push('recipe_id = ?');
      params.push(recipe_id ? toPositiveInt(recipe_id) : null);
    }
    if (recipe_name !== undefined) {
      updates.push('recipe_name = ?');
      params.push(typeof recipe_name === 'string' ? recipe_name.trim() : null);
    }
    if (responsible !== undefined) {
      updates.push('responsible = ?');
      params.push(typeof responsible === 'string' ? responsible.trim() : '');
    }
    if (location_id !== undefined) {
      updates.push('location_id = ?');
      params.push(toPositiveInt(location_id) || 1);
    }
    if (notes !== undefined) {
      updates.push('notes = ?');
      params.push(typeof notes === 'string' && notes.trim() ? notes.trim() : null);
    }
    if (status) {
      updates.push('status = ?');
      params.push(status);
      if (status === 'completed') {
        updates.push('completed_at = ?');
        params.push(new Date().toISOString());
      }
    }

    if (!updates.length) {
      return res.status(400).json({ error: 'Nu există câmpuri de actualizat.' });
    }

    updates.push('updated_at = ?');
    params.push(new Date().toISOString());
    params.push(batchId, tenantId);

    await runAsync(
      db,
      `UPDATE production_batches SET ${updates.join(', ')} WHERE id = ? AND tenant_id = ?`,
      params
    );

    res.json({ success: true });
  } catch (error) {
    console.error('❌ Eroare la actualizarea batch-ului:', error);
    res.status(500).json({ error: 'Eroare la actualizarea batch-ului' });
  }
});

