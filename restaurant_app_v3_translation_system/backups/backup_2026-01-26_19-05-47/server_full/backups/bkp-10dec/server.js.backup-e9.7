    if (ingredientId) {
      filters.push('sm.ingredient_id = ?');
      params.push(ingredientId);
    }

    const dateFrom = typeof req.query.date_from === 'string' ? req.query.date_from.trim() : '';
    if (dateFrom) {
      filters.push('DATE(sm.date) >= DATE(?)');
      params.push(dateFrom);
    }

    const dateTo = typeof req.query.date_to === 'string' ? req.query.date_to.trim() : '';
    if (dateTo) {
      filters.push('DATE(sm.date) <= DATE(?)');
      params.push(dateTo);
    }

    const supplierFilter = typeof req.query.supplier === 'string' ? req.query.supplier.trim() : '';
    if (supplierFilter) {
      filters.push(
        '(COALESCE(sup.company_name, sup.name, cn.destination, ih.location, ih.responsible, "") LIKE ?)'
      );
      params.push(`%${supplierFilter}%`);
    }

    const documentFilter = typeof req.query.document_number === 'string' ? req.query.document_number.trim() : '';
    if (documentFilter) {
      filters.push('(COALESCE(nh.document_number, cn.document_number, ih.document_number, "") LIKE ?)');
      params.push(`%${documentFilter}%`);
    }

    const whereClause = filters.length ? `WHERE ${filters.join(' AND ')}` : '';
    const limit = Math.min(toPositiveInt(req.query.limit) ?? 200, 1000);
    const offsetRaw = safeNumber(req.query.offset, 0);
    const offset = offsetRaw >= 0 ? Math.floor(offsetRaw) : 0;
    params.push(limit);
    params.push(offset);

    const moves = await allAsync(
      db,
      `
        SELECT 
          sm.*,
          ing.name AS ingredient_name,
          ing.unit AS ingredient_unit,
          nh.document_number AS nir_document_number,
          COALESCE(sup.company_name, sup.name) AS nir_supplier_name,
          cn.document_number AS consume_document_number,
          cn.destination AS consume_destination,
          ih.document_number AS inventory_document_number,
          ih.location AS inventory_location,
          ih.responsible AS inventory_responsible,
          th.document_number AS transfer_document_number,
          th.source_location AS transfer_source_location,
          th.target_location AS transfer_target_location
        FROM stock_moves sm
        LEFT JOIN ingredients ing ON ing.id = sm.ingredient_id
        LEFT JOIN nir_headers nh ON nh.id = sm.reference_id AND sm.type = 'NIR'
        LEFT JOIN suppliers sup ON sup.id = nh.supplier_id
        LEFT JOIN consumption_notes cn ON cn.id = sm.reference_id AND sm.type = 'CONSUME'
        LEFT JOIN inventory_headers ih ON ih.id = sm.reference_id AND (sm.type = 'ADJUST' OR sm.type = 'ADJUSTMENT')
        LEFT JOIN transfer_headers th ON th.id = sm.reference_id AND sm.type = 'TRANSFER'
        ${whereClause}
        ORDER BY sm.date DESC, sm.id DESC
        LIMIT ? OFFSET ?
      `,
      params
    );

    const normalizedMoves = moves.map((move) => {
      const m = move?.type === 'ADJUSTMENT' ? { ...move, type: 'ADJUST' } : move;
      return m;
    });

    res.json(normalizedMoves);
  } catch (error) {
    console.error('❌ Eroare la listarea mișcărilor de stoc:', error);
    res.status(500).json({ error: 'Eroare la listarea mișcărilor de stoc' });
  }
});

