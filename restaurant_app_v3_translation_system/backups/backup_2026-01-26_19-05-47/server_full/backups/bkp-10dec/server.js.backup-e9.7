app.get('/api/admin/inventories/:id', checkAdminAuth, async (req, res) => {
  const inventoryId = toPositiveInt(req.params.id);
  if (!inventoryId) {
    return res.status(400).json({ error: 'ID inventar invalid.' });
  }

  try {
    const db = await dbPromise;
    const tenantId = DEFAULT_TENANT_ID;

    const header = await getAsync(
      db,
      `SELECT * FROM inventory_headers WHERE id = ? AND tenant_id = ?`,
      [inventoryId, tenantId]
    );

    if (!header) {
      return res.status(404).json({ error: 'Inventarul nu a fost găsit.' });
    }

    const lines = await allAsync(
      db,
      `
        SELECT 
          il.*,
          ing.name AS ingredient_name,
          COALESCE(il.unit, ing.unit) AS resolved_unit
        FROM inventory_lines il
        LEFT JOIN ingredients ing ON ing.id = il.ingredient_id
        WHERE il.inventory_id = ? AND il.tenant_id = ?
        ORDER BY il.id
      `,
      [inventoryId, tenantId]
    );

    const totals = lines.reduce(
      (acc, line) => {
        const diff = safeNumber(line.diff_qty, 0);
        const diffValue = safeNumber(line.diff_value, 0);
        if (diff > 0) {
          acc.total_positive += diff;
          acc.total_positive_value += diffValue;
        } else if (diff < 0) {
          acc.total_negative += diff;
          acc.total_negative_value += diffValue;
        }
        return acc;
      },
      {
        total_positive: 0,
        total_negative: 0,
        total_positive_value: 0,
        total_negative_value: 0,
      }
    );

    res.json({
      header,
      lines: lines.map((line) => ({
        id: line.id,
        ingredient_id: line.ingredient_id,
        ingredient_name: line.ingredient_name,
        unit: line.resolved_unit,
        stock_system: safeNumber(line.stock_system, 0),
        stock_counted: safeNumber(line.stock_counted, 0),
        diff_qty: safeNumber(line.diff_qty, 0),
        diff_value: safeNumber(line.diff_value, 0),
        cost_unit: safeNumber(line.cost_unit, 0),
      })),
      totals,
    });
  } catch (error) {
    console.error('❌ Eroare la preluarea inventarului:', error);
    res.status(500).json({ error: 'Eroare la preluarea inventarului' });
  }
});

app.post('/api/admin/inventories', checkAdminAuth, async (req, res) => {
  const headerPayload = req.body?.header ?? {};
  const linesPayload = Array.isArray(req.body?.lines) ? req.body.lines : [];

  const documentNumber =
    typeof headerPayload.document_number === 'string' ? headerPayload.document_number.trim() : '';
  const documentDate =
    typeof headerPayload.document_date === 'string' ? headerPayload.document_date.trim() : '';
  const location = typeof headerPayload.location === 'string' ? headerPayload.location.trim() : '';
  const responsible =
    typeof headerPayload.responsible === 'string' ? headerPayload.responsible.trim() : '';
  const notes =
    typeof headerPayload.notes === 'string' && headerPayload.notes.trim()
      ? headerPayload.notes.trim()
      : null;
  const headerId = toPositiveInt(headerPayload.id);

  if (!documentNumber) {
    return res.status(400).json({ error: 'Numărul inventarului este obligatoriu.' });
  }
  if (!documentDate) {
    return res.status(400).json({ error: 'Data inventarului este obligatorie.' });
  }
  if (!location) {
    return res.status(400).json({ error: 'Locația/depozitul este obligatorie.' });
  }
  if (!responsible) {
    return res.status(400).json({ error: 'Responsabilul inventarului este obligatoriu.' });
  }

  let sanitizedLines;
  try {
    sanitizedLines = sanitizeInventoryLinesPayload(linesPayload);
  } catch (payloadError) {
    return res
      .status(payloadError.statusCode || 400)
      .json({ error: payloadError.message || 'Payload invalid pentru inventar.' });
  }

  try {
    const db = await dbPromise;
    const tenantId = DEFAULT_TENANT_ID;
    let transactionActive = false;

    try {
      await runAsync(db, 'BEGIN TRANSACTION');
      transactionActive = true;

      let inventoryId = headerId;

      if (inventoryId) {
        const exists = await getAsync(
          db,
          `SELECT id FROM inventory_headers WHERE id = ? AND tenant_id = ?`,
          [inventoryId, tenantId]
        );

        if (!exists) {
          const error = new Error('Inventarul specificat nu există.');
          error.statusCode = 404;
          throw error;
        }

        await runAsync(
          db,
          `
            UPDATE inventory_headers
            SET
              document_number = ?,
              document_date = ?,
              location = ?,
              responsible = ?,
              notes = ?,
              updated_at = datetime('now')
            WHERE id = ? AND tenant_id = ?
          `,
          [documentNumber, documentDate, location, responsible, notes, inventoryId, tenantId]
        );

        await runAsync(
          db,
          `DELETE FROM inventory_lines WHERE inventory_id = ? AND tenant_id = ?`,
          [inventoryId, tenantId]
        );
        await runAsync(
          db,
          `DELETE FROM stock_moves WHERE tenant_id = ? AND type IN ('ADJUST', 'ADJUSTMENT') AND reference_type = 'INVENTORY' AND reference_id = ?`,
          [tenantId, inventoryId]
        );
      } else {
        const headerResult = await runAsync(
          db,
          `
            INSERT INTO inventory_headers (
              tenant_id,
              document_number,
              document_date,
              location,
              responsible,
              notes,
              created_by
            ) VALUES (?, ?, ?, ?, ?, ?, ?)
          `,
          [tenantId, documentNumber, documentDate, location, responsible, notes, req.user?.id ?? null]
        );
        inventoryId = headerResult.lastID;
      }

      const ingredientIds = [...new Set(sanitizedLines.map((line) => line.ingredient_id))];
      let ingredientMap = new Map();
      if (ingredientIds.length) {
        const placeholders = ingredientIds.map(() => '?').join(',');
        const rows = await allAsync(
          db,
          `SELECT id, unit, cost_per_unit, current_stock FROM ingredients WHERE id IN (${placeholders})`,
          ingredientIds
        );
        ingredientMap = new Map(rows.map((row) => [row.id, row]));
      }

      const totals = {
        total_positive: 0,
        total_negative: 0,
        total_positive_value: 0,
        total_negative_value: 0,
      };

      for (const line of sanitizedLines) {
        const ingredient = ingredientMap.get(line.ingredient_id);
        if (!ingredient) {
          const error = new Error(`Ingredientul cu ID ${line.ingredient_id} nu există.`);
          error.statusCode = 400;
          throw error;
        }
        const unit = line.unit || ingredient.unit || null;
        const costUnit = safeNumber(ingredient.cost_per_unit, 0);
        const diffQty = roundNumber(line.diff_qty, 4);
        const diffValue = roundNumber(diffQty * costUnit, 4);

        if (diffQty > 0) {
          totals.total_positive += diffQty;
          totals.total_positive_value += diffValue;
        } else if (diffQty < 0) {
          totals.total_negative += diffQty;
          totals.total_negative_value += diffValue;
        }

        await runAsync(
          db,
          `
            INSERT INTO inventory_lines (
              tenant_id,
              inventory_id,
              ingredient_id,
              unit,
              stock_system,
              stock_counted,
              diff_qty,
              diff_value,
              cost_unit
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
          `,
          [
            tenantId,
            inventoryId,
            line.ingredient_id,
            unit,
            line.stock_system,
            line.stock_counted,
            diffQty,
            diffValue,
            costUnit,
          ]
        );

        await runAsync(
          db,
          `UPDATE ingredients SET current_stock = ? WHERE id = ?`,
          [line.stock_counted, line.ingredient_id]
        );

        if (diffQty !== 0) {
          const reason =
            diffQty > 0 ? STOCK_MOVE_REASON.ADJUST_IN : STOCK_MOVE_REASON.ADJUST_OUT;
          await createStockMove({
            tenant_id: tenantId,
            ingredient_id: line.ingredient_id,
            qty: Math.abs(diffQty),
            direction: diffQty > 0 ? 'IN' : 'OUT',
            reason,
            source: STOCK_MOVE_SOURCE.INVENTORY,
            reference_type: 'INVENTORY',
            reference_id: inventoryId,
            unit_price: costUnit,
            value: Math.abs(diffValue),
            tva_percent: 0,
            meta: {
              document_number: documentNumber,
              document_date: documentDate,
              location,
              responsible,
            },
          });
        }
      }

      await runAsync(db, 'COMMIT');
      transactionActive = false;

      res.json({ id: inventoryId, totals });
    } catch (error) {
      if (transactionActive) {
        try {
          await runAsync(db, 'ROLLBACK');
        } catch (rollbackError) {
          console.error('⚠️ Eroare rollback inventar:', rollbackError);
        }
      }
      if (error.statusCode) {
        return res.status(error.statusCode).json({ error: error.message });
      }
      throw error;
    }
  } catch (error) {
    console.error('❌ Eroare la salvarea inventarului:', error);
    res.status(500).json({ error: 'Eroare la salvarea inventarului' });
  }
});

