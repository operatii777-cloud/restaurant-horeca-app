  // POST /api/fiscal/receipt/:orderId - Emite Bon de Comandă/Notă de Plată/Bon Fiscal (pentru admin)
  app.post('/api/fiscal/receipt/:orderId', checkAdminAuth, async (req, res) => {
      const { orderId } = req.params;
      const { payment_method = 'cash', is_fiscal = 1, waiter_id = null } = req.body || {}; // is_fiscal: 0 - nota de plata, 1 - bon nefiscal

      try {
          // 1. Obține detaliile comenzii specifice
          const db = await dbPromise;
          const order = await new Promise((resolve, reject) => {
              db.get('SELECT id, total, items, status, table_number, client_identifier, type, timestamp, is_paid, paid_timestamp FROM orders WHERE id = ?', [orderId], (err, row) => {
                  if (err) reject(err);
                  else resolve(row);
              });
          });
          
          if (!order) {
              return res.status(404).json({ error: 'Comanda nu a fost găsită.' });
          }
          
          // Verifică dacă comanda este deja plătită - permite generarea bonului nefiscal pentru comenzi achitate
          // Comanda poate fi achitată dar să nu aibă încă bon nefiscal generat
          
          // 2. Verifică dacă există alte comenzi pentru același client la aceeași masă cu același paid_timestamp (sesiune de plată)
          const groupOrders = await new Promise((resolve, reject) => {
              db.all(`
                  SELECT id, total, items, status, table_number, type, timestamp, is_paid, paid_timestamp
                  FROM orders 
                  WHERE table_number = ? AND client_identifier = ? AND status IN ('delivered', 'paid') AND is_paid = 1
                  ORDER BY timestamp ASC
              `, [order.table_number, order.client_identifier], (err, rows) => {
                  if (err) reject(err);
                  else {
                      // Filtrează doar comenzile cu același paid_timestamp ca comanda curentă (aceeași sesiune de plată)
                      const currentOrderPaidTimestamp = order.paid_timestamp;
                      const filteredRows = rows.filter(row => row.paid_timestamp === currentOrderPaidTimestamp);
                      resolve(filteredRows);
                  }
              });
          });
          
          // 3. Verifică dacă comanda este livrată sau plătită
          if (!['delivered', 'paid'].includes(order.status)) {
              return res.status(400).json({ 
                  error: 'Nu se poate genera bon nefiscal!',
                  message: 'Comanda trebuie să fie livrată sau plătită înainte de generarea bonului nefiscal.'
              });
          }
          
          // 4. Generează bon nefiscal pentru grupul de comenzi (individual sau multiplu)
          console.log(`🔄 Generez bon nefiscal pentru grupul de comenzi: ${groupOrders.map(o => o.id).join(', ')}`);
          
          // Folosește logica de bon nefiscal grupat pentru orice număr de comenzi
          const receiptResult = await generateGroupFiscalReceipt(groupOrders, payment_method);
          
          if (!receiptResult.success) {
              return res.status(500).json({ error: receiptResult.error });
          }
          
          // Generează PDF-ul pentru bonul fiscal
          const pdfPath = await generateFiscalPDF({ 
              receipt_number: receiptResult.receipt_number, 
              total_amount: receiptResult.total_amount, 
              vat_amount: receiptResult.vat_amount, 
              issue_date: new Date(),
              order_id: groupOrders.map(o => o.id).join(','),
              table_number: order.table_number,
              order_type: groupOrders.length > 1 ? 'group' : 'individual',
              order_date: order.timestamp
          }, receiptResult.allItems || [], 'receipt');
          
          // Returnează răspunsul pentru bonul fiscal
          res.json({
              success: true,
              receipt_number: receiptResult.receipt_number,
              receipt_id: receiptResult.receipt_id,
              total_amount: receiptResult.total_amount,
              vat_amount: receiptResult.vat_amount,
              payment_method: payment_method,
              is_group_receipt: groupOrders.length > 1,
              order_ids: groupOrders.map(o => o.id),
              order_count: groupOrders.length,
              pdf_url: `/documents/${path.basename(pdfPath)}`
          });
          
      } catch (error) {
          console.error('❌ Eroare la generarea bonului nefiscal:', error);
          res.status(500).json({ error: error.message });
      }
  });

