          });
        }
      });
    });

    Promise.all(enrichItemPromises).then(async (enriched) => {
      // VERIFICARE STOC ÎNAINTE DE PROCESARE (doar avertizare, nu blocare)
      console.log('🔍 Verificare stoc pentru comenză...');
      const stockIssues = await checkStockAvailability(enriched);
      
      if (stockIssues.length > 0) {
        console.warn('⚠️ Avertizare stoc:', stockIssues);
        // Nu blocăm comanda, doar afișăm avertizare
      } else {
        console.log('✅ Stoc verificat - toate ingredientele sunt disponibile');
      }
      
      // Aplică Happy Hour discounts
      const { items: finalItems, discount: happyHourDiscount, happyHourSettings } = await applyHappyHourDiscounts(enriched);
      
      // Adaugă ambalaje pentru comenzile takeaway, delivery și drive-thru (05 Dec 2025)
      // Toate aceste tipuri de comenzi necesită ambalaje (nu farfurii)
      const normalizedType = (type || '').toString().toLowerCase();
      const needsPackaging = ['takeaway', 'takeout', 'pick-up', 'pickup', 'delivery', 'drive_thru', 'drive-thru', 'drivethru'].includes(normalizedType);
      
      if (needsPackaging) {
        console.log(`📦 Comandă ${type} detectată - se adaugă ambalaje...`);
        const { getRequiredPackagingForOrder } = require('./database');
        
        try {
          const requiredPackaging = await getRequiredPackagingForOrder(finalItems, type);
          console.log(`📦 Ambalaje necesare pentru ${type}:`, requiredPackaging);
          
          // Adaugă produsele pentru ambalaje la finalItems
          for (const [packagingName, quantity] of Object.entries(requiredPackaging)) {
            // Găsește ID-ul produsului pentru ambalaj
            const packagingProduct = await new Promise((resolve, reject) => {
              db.get('SELECT id, price FROM menu WHERE name = ? AND category = "Ambalaje și Accesorii"', [packagingName], (err, row) => {
                if (err) reject(err);
                else resolve(row);
              });
            });
            
            if (packagingProduct) {
