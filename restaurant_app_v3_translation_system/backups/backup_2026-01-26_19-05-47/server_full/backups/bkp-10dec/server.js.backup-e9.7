  // Raport analiză trend-uri temporale
  app.get('/api/admin/reports/time-trends', checkAdminAuth, async (req, res) => {
    try {
      const { period = 'daily', startDate, endDate } = req.query;
      const db = await dbPromise;
      
      let dateFormat, groupBy;
      switch (period) {
        case 'hourly':
          dateFormat = '%Y-%m-%d %H:00:00';
          groupBy = 'DATE(o.timestamp), HOUR(o.timestamp)';
          break;
        case 'daily':
          dateFormat = '%Y-%m-%d';
          groupBy = 'DATE(o.timestamp)';
          break;
        case 'weekly':
          dateFormat = '%Y-W%V';
          groupBy = 'strftime("%Y-W%V", o.timestamp)';
          break;
        case 'monthly':
          dateFormat = '%Y-%m';
          groupBy = 'strftime("%Y-%m", o.timestamp)';
          break;
        default:
          dateFormat = '%Y-%m-%d';
          groupBy = 'DATE(o.timestamp)';
      }
      
      let whereClause = 'WHERE o.status = "completed" AND o.is_paid = 1';
      let params = [];
      
      if (startDate && endDate) {
        whereClause += ' AND DATE(o.timestamp) BETWEEN ? AND ?';
        params.push(startDate, endDate);
      }
      
      const query = `
        SELECT 
          strftime('${dateFormat}', o.timestamp) as period,
          COUNT(*) as total_orders,
          SUM(o.total) as total_revenue,
          AVG(o.total) as avg_order_value,
          COUNT(DISTINCT o.client_identifier) as unique_customers,
          COUNT(DISTINCT o.table_number) as tables_served
        FROM orders o
        ${whereClause}
        GROUP BY ${groupBy}
        ORDER BY period ASC
      `;
      
      db.all(query, params, (err, rows) => {
        if (err) {
          return res.status(500).json({ error: err.message });
        }
        
        res.json({
          success: true,
          data: rows,
          period: period,
          summary: {
            totalPeriods: rows.length,
            totalRevenue: rows.reduce((sum, r) => sum + r.total_revenue, 0),
            totalOrders: rows.reduce((sum, r) => sum + r.total_orders, 0),
            avgDailyRevenue: rows.length > 0 ? rows.reduce((sum, r) => sum + r.total_revenue, 0) / rows.length : 0
          }
        });
      });
    } catch (error) {
      res.status(500).json({ error: 'Eroare la generarea raportului de trend-uri temporale.' });
    }
  });

