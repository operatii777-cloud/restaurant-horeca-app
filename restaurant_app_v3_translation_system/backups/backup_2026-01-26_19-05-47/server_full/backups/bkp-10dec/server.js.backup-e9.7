// PUT - Actualizează transfer (status și alte câmpuri)
app.put('/api/transfers/:id', async (req, res) => {
  try {
    const { status, approved_by } = req.body;
    
    if (!status) {
      return res.status(400).json({ 
        success: false, 
        error: 'Status lipsă' 
      });
    }

    const updated = await transferHelpers.updateTransferStatus(
      req.params.id, 
      status, 
      approved_by
    );
    
    if (!updated) {
      return res.status(404).json({ success: false, error: 'Transfer negăsit' });
    }

    // Dacă status-ul este 'completed', procesează transferul automat
    if (status === 'completed') {
      try {
        const result = await transferHelpers.processTransfer(req.params.id);
        res.json({ 
          success: true, 
          message: `Transfer actualizat și procesat cu succes`,
          data: result
        });
      } catch (processError) {
        console.error('⚠️ Transfer actualizat dar eroare la procesare:', processError);
        res.json({ 
          success: true, 
          message: `Transfer actualizat la status: ${status}, dar eroare la procesare: ${processError.message}`,
          warning: processError.message
        });
      }
    } else {
      res.json({ 
        success: true, 
        message: `Transfer actualizat la status: ${status}` 
      });
    }
  } catch (error) {
    console.error('❌ Eroare la actualizare transfer:', error);
    res.status(500).json({ success: false, error: error.message });
  }
});

