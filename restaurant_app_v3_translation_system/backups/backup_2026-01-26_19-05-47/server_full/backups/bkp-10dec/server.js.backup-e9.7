    // POST /api/admin/daily-menu - Salvează/actualizează meniul zilei (admin)
    // Creează meniu zilnic (cu RBAC)
    app.post('/api/admin/daily-menu', authenticateUser, requirePermission('menu:create'), (req, res) => {
      const { soupId, mainCourseId, discount } = req.body;
      const today = new Date().toISOString().slice(0, 10);

      if (!soupId || !mainCourseId) {
        return res.status(400).json({ error: 'Soup ID and Main Course ID are required.' });
      }

      const sql = `
        INSERT INTO daily_menu (date, soup_id, main_course_id, discount, is_active)
        VALUES (?, ?, ?, ?, 1)
        ON CONFLICT(date) DO UPDATE SET
        soup_id = excluded.soup_id,
        main_course_id = excluded.main_course_id,
        discount = excluded.discount,
        is_active = 1
      `;

      db.run(sql, [today, soupId, mainCourseId, discount], function(err) {
