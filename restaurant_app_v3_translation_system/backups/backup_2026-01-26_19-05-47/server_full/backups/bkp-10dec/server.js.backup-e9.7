  // PUT /api/settings/schedule - Actualizare program (bulk)
  app.put('/api/settings/schedule', authenticateUser, requirePermission('settings.update'), auditLog('UPDATE', 'schedule'), async (req, res) => {
    try {
      const { schedules } = req.body; // Array de obiecte { location_id, day_of_week, open_time, close_time, is_closed, break_start, break_end }
      const db = await dbPromise;
      
      if (!Array.isArray(schedules)) {
        return res.status(400).json({ error: 'schedules trebuie să fie un array' });
      }
      
      db.serialize(() => {
        db.run('BEGIN TRANSACTION');
        
        schedules.forEach((schedule) => {
          db.run(
            `INSERT OR REPLACE INTO restaurant_schedule (location_id, day_of_week, open_time, close_time, is_closed, break_start, break_end, updated_at)
             VALUES (?, ?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP)`,
            [
              schedule.location_id || null,
              schedule.day_of_week,
              schedule.open_time || null,
              schedule.close_time || null,
              schedule.is_closed ? 1 : 0,
              schedule.break_start || null,
              schedule.break_end || null
            ]
          );
        });
        
        db.run('COMMIT', (err) => {
          if (err) {
            db.run('ROLLBACK');
            return res.status(500).json({ error: err.message });
          }
          res.json({ success: true });
        });
      });
    } catch (error) {
      res.status(500).json({ error: 'Eroare la actualizarea programului' });
    }
  });

