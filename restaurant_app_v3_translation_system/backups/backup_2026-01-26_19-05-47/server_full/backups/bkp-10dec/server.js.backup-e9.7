      success: true,
      config: {
        method: config.method || 'FIFO'
      }
    });
  } catch (error) {
    console.error('❌ Eroare la obținerea configurației de evaluare stoc:', error);
    res.status(500).json({ error: 'Eroare la obținerea configurației', details: error.message });
  }
});

// Actualizează configurația de evaluare stoc
app.put('/api/settings/stock-valuation', checkAdminAuth, async (req, res) => {
  try {
    const { method } = req.body;
    
    if (!['FIFO', 'LIFO', 'AVERAGE'].includes(method)) {
      return res.status(400).json({ error: 'Metodă invalidă. Trebuie să fie FIFO, LIFO sau AVERAGE' });
    }
    
    const db = await dbPromise;
    
    // Verifică dacă există deja o configurație
    const existing = await new Promise((resolve, reject) => {
      db.get('SELECT id FROM stock_valuation_config WHERE ingredient_id IS NULL AND location_id IS NULL', (err, row) => {
        if (err) reject(err);
        else resolve(row);
      });
    });
    
    if (existing) {
      // Actualizează
      await new Promise((resolve, reject) => {
        db.run('UPDATE stock_valuation_config SET method = ?, updated_at = datetime("now") WHERE id = ?', [method, existing.id], (err) => {
          if (err) reject(err);
          else resolve();
        });
      });
    } else {
      // Creează
      await new Promise((resolve, reject) => {
        db.run('INSERT INTO stock_valuation_config (method) VALUES (?)', [method], (err) => {
          if (err) reject(err);
          else resolve();
        });
      });
    }
    
    res.json({
      success: true,
      method,
      message: `Metoda de evaluare stoc actualizată la ${method}`
    });
  } catch (error) {
    console.error('❌ Eroare la actualizarea configurației de evaluare stoc:', error);
    res.status(500).json({ error: 'Eroare la actualizarea configurației', details: error.message });
  }
});

