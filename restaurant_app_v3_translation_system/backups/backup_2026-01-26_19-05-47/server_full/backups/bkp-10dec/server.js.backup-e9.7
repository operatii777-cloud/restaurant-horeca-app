    res.json({
      success: true,
      data: lowStockIngredients,
      summary: {
        total_low_stock: lowStockIngredients.length,
        out_of_stock: lowStockIngredients.filter(i => i.stock_status === 'out_of_stock').length,
        low_stock: lowStockIngredients.filter(i => i.stock_status === 'low_stock').length
      }
    });
    
  } catch (error) {
    console.error('Eroare la obținerea ingredientelor cu stoc scăzut:', error);
    res.status(500).json({ 
