  // GET /api/anaf/validate-cui/:cui - Validare CUI prin API public ANAF
  app.get('/api/anaf/validate-cui/:cui', async (req, res) => {
    try {
      const { cui } = req.params;
      
      // Clean CUI (remove RO prefix, spaces)
      const cleanCUI = cui.replace(/^RO/i, '').replace(/\s/g, '');
      
      // ANAF Public API pentru verificare CUI (fără certificat)
      const https = require('https');
      const anafURL = `https://webservicesp.anaf.ro/PlatitorTvaRest/api/v8/ws/tva`;
      
      const postData = JSON.stringify([{ cui: parseInt(cleanCUI), data: new Date().toISOString().split('T')[0] }]);
      
      const options = {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Content-Length': Buffer.byteLength(postData)
        }
      };
      
      const request = https.request(anafURL, options, (anafRes) => {
        let data = '';
        
        anafRes.on('data', chunk => { data += chunk; });
        
        anafRes.on('end', () => {
          try {
            const result = JSON.parse(data);
            
            // ANAF returnează un array cu un singur element
            if (result && result.found && result.found.length > 0) {
              const company = result.found[0];
              
              console.log(`✅ CUI ${cui} validat: ${company.denumire || 'Unknown'}`);
              
              res.json({
                success: true,
                valid: true,
                data: {
                  cui: company.cui,
                  denumire: company.denumire,
                  adresa: company.adresa,
                  scpTVA: company.scpTVA, // true = platitor TVA
                  dataInceputTvaInactivitate: company.dataInceputTvaInactivitate,
                  dataInactivare: company.dataInactivare,
                  dataActualizare: company.dataActualizare
                }
              });
            } else if (result && result.notfound && result.notfound.length > 0) {
              console.log(`⚠️ CUI ${cui} NU găsit în baza ANAF`);
              res.json({
                success: true,
                valid: false,
                message: 'CUI nu a fost găsit în baza de date ANAF'
              });
            } else if (result && result.cod) {
              // ANAF a returnat o eroare (ex: cod 4 = CUI invalid format)
              console.log(`⚠️ ANAF error code ${result.cod}: ${result.message || 'Unknown'}`);
              res.json({
                success: true,
                valid: false,
                message: result.message || 'CUI invalid sau eroare ANAF'
              });
            } else {
              // Răspuns complet neașteptat
              console.error('❌ ANAF unexpected response:', data.substring(0, 200));
              res.json({
                success: false,
                error: 'Răspuns unexpected de la ANAF',
                details: data.substring(0, 100)
              });
            }
          } catch (e) {
            console.error('❌ Error parsing ANAF response:', e);
            console.error('   Raw data:', data.substring(0, 200));
            res.status(500).json({ 
              error: 'Eroare la parsarea răspunsului ANAF', 
              details: e.message 
            });
          }
        });
      });
      
      request.on('error', (error) => {
        console.error('❌ ANAF API error:', error);
        res.status(500).json({
          success: false,
          error: 'Eroare la conectarea cu API-ul ANAF',
          details: error.message
        });
      });
      
      request.write(postData);
      request.end();
      
    } catch (error) {
      console.error('❌ Error in GET /api/anaf/validate-cui:', error);
      res.status(500).json({ error: error.message });
    }
  });
  
