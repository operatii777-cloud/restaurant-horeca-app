          Math.round(totalVAT11 * 100) / 100,  // Salvează TVA 11%
          0,  // TVA 5% (deocamdată 0)
          0   // TVA 0% (deocamdată 0)
        ], function(err) {
          if (err) reject(err);
          else resolve(this.lastID);
        });
      });
      
