  // GET /api/kiosk/tables/positions - Obține toate pozițiile meselor (pentru KIOSK, fără autentificare admin)
  app.get('/api/kiosk/tables/positions', async (req, res) => {
    try {
      const db = await dbPromise;
      
      // Obține pozițiile din tables_positions
      const positions = await new Promise((resolve, reject) => {
        db.all('SELECT table_id, x, y FROM tables_positions', [], (err, rows) => {
          if (err) reject(err);
          else resolve(rows || []);
        });
      });

      // Obține statusul meselor din orders - masa devine ocupată DOAR dacă există comenzi neachitate cu items
      const tablesStatus = await new Promise((resolve, reject) => {
        db.all(`
          SELECT table_number, status, items, is_paid
          FROM orders 
          WHERE table_number IS NOT NULL 
          AND status IN ('pending', 'preparing', 'ready', 'served')
          ORDER BY timestamp DESC
        `, [], (err, rows) => {
          if (err) reject(err);
          else resolve(rows || []);
        });
      });

      // Creează map pentru status
      // Masa devine ocupată DOAR dacă există o comandă NEACHITATĂ cu items (nu doar comandă goală)
      // După achitare (is_paid = 1), masa devine liberă
      const statusMap = {};
      tablesStatus.forEach((t) => {
        // Dacă comanda este achitată, masa devine liberă
        if (t.is_paid === 1 || t.is_paid === true) {
          if (!statusMap[t.table_number]) {
            statusMap[t.table_number] = 'free';
          }
          return; // Nu procesăm mai departe dacă e achitată
        }
        
        // Verifică dacă comanda are items și nu este achitată
        if (t.status === 'pending' || t.status === 'preparing') {
          try {
            const items = typeof t.items === 'string' ? JSON.parse(t.items) : t.items;
            if (Array.isArray(items) && items.length > 0) {
              // Comandă neachitată cu items - masa ocupată
              statusMap[t.table_number] = 'occupied';
            } else {
              // Comandă goală sau fără items - masa rămâne liberă
              if (!statusMap[t.table_number]) {
                statusMap[t.table_number] = 'free';
              }
            }
          } catch {
            // Eroare la parsing - considerăm liberă
            if (!statusMap[t.table_number]) {
              statusMap[t.table_number] = 'free';
            }
          }
        } else {
          // Comenzi ready/served - masa liberă (dacă nu e deja setată ca ocupată)
          if (!statusMap[t.table_number]) {
            statusMap[t.table_number] = 'free';
          }
        }
      });

      // Combină pozițiile cu status-ul
      const result = positions.map((pos) => ({
        table_id: pos.table_id,
        x: pos.x,
        y: pos.y,
        status: statusMap[pos.table_id] || 'free'
      }));

      res.json(result);
    } catch (error) {
      console.error('❌ Eroare la obținerea pozițiilor meselor KIOSK:', error);
      res.status(500).json({ error: 'Eroare la obținerea pozițiilor' });
    }
  });

