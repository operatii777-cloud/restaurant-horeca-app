  // Funcție pentru verificarea stocului scăzut și trimiterea notificărilor
  function checkLowStockAndNotify() {
    db.all(`
      SELECT 
        ps.*,
        m.name,
        m.category
      FROM product_stock ps
      JOIN menu m ON ps.product_id = m.id
      WHERE ps.current_stock <= ps.min_stock AND ps.is_auto_managed = 1
    `, (err, lowStockProducts) => {
      if (err) {
        console.error('Eroare la verificarea stocului scăzut:', err.message);
        return;
      }

      if (lowStockProducts && lowStockProducts.length > 0) {
        const notification = {
          type: 'low_stock',
          message: `⚠️ Stoc scăzut pentru ${lowStockProducts.length} produse!`,
          products: lowStockProducts.map(p => ({
            name: p.name,
            current_stock: p.current_stock,
            min_stock: p.min_stock,
            category: p.category
          })),
          timestamp: new Date().toISOString()
        };

        // Trimite notificarea tuturor clienților conectați
        io.emit('lowStockAlert', notification);
        console.log(`Notificare stoc scăzut trimisă pentru ${lowStockProducts.length} produse`);
      }
    });
  }

