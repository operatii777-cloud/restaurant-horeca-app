<section class="category-section{{#if page_break_after}} force-page-break{{/if}} split-{{split_info.pages}}" data-split-pages="{{split_info.pages}}" data-split-layout="{{#each split_info.per_page}}{{this}}{{#unless @last}}-{{/unless}}{{/each}}"{{#if split_info.is_single_page}} data-single-page="true"{{/if}}>
  
  {{#if category_image_url}}
    <!-- Category Header WITH Image -->
    <div class="category-image-container">
      <img src="{{category_image_url}}" alt="{{#if (eq @root.metadata.lang "ro")}}{{name_ro}}{{else}}{{name_en}}{{/if}}" class="category-image">
      <div class="category-image-overlay"></div>
      <div class="category-title-overlay">
        <span class="category-icon">{{icon}}</span>
        <h3 class="category-name">
          {{#if (eq @root.metadata.lang "ro")}}
            {{name_ro}}
          {{else}}
            {{name_en}}
          {{/if}}
        </h3>
      </div>
    </div>
  {{else}}
    <!-- Category Header WITHOUT Image (fallback) -->
    <div class="category-header">
      <span class="category-icon">{{icon}}</span>
      <h3 class="category-name">
        {{#if (eq @root.metadata.lang "ro")}}
          {{name_ro}}
        {{else}}
          {{name_en}}
        {{/if}}
      </h3>
    </div>
  {{/if}}
  
  <!-- Products List (COMPACT - fără min-height) -->
  <div class="products-list">
    {{#each products}}
      {{> product-item}}
    {{/each}}
  </div>
  
</section>

