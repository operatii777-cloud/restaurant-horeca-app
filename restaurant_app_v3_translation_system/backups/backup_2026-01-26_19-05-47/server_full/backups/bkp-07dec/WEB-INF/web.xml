<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Restaurant App - Fiscal System</display-name>
    <description>Aplicație Restaurant cu Sistem Fiscal Complet</description>

    <!-- ==================== CONFIGURARE SERVLET-URI FISCALE ==================== -->
    
    <!-- Controller Principal pentru Operațiuni Fiscale -->
    <servlet>
        <servlet-name>FiscalController</servlet-name>
        <servlet-class>controllers.FiscalController</servlet-class>
        <load-on-startup>1</load-on-startup>
        <init-param>
            <param-name>config</param-name>
            <param-value>fiscal-config.properties</param-value>
        </init-param>
    </servlet>
    
    <!-- Mapping pentru toate endpoint-urile fiscale -->
    <servlet-mapping>
        <servlet-name>FiscalController</servlet-name>
        <url-pattern>/api/raport/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>FiscalController</servlet-name>
        <url-pattern>/api/fiscal/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>FiscalController</servlet-name>
        <url-pattern>/api/istoric/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>FiscalController</servlet-name>
        <url-pattern>/api/rapoarte/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>FiscalController</servlet-name>
        <url-pattern>/api/arhiva/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>FiscalController</servlet-name>
        <url-pattern>/api/export/*</url-pattern>
    </servlet-mapping>

    <!-- ==================== CONFIGURARE CORS PENTRU FRONTEND ==================== -->
    
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>filters.CorsFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- ==================== CONFIGURARE SECURITATE ==================== -->
    
    <filter>
        <filter-name>SecurityFilter</filter-name>
        <filter-class>filters.SecurityFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>SecurityFilter</filter-name>
        <url-pattern>/api/fiscal/*</url-pattern>
    </filter-mapping>

    <!-- ==================== CONFIGURARE LOGGING ==================== -->
    
    <filter>
        <filter-name>LoggingFilter</filter-name>
        <filter-class>filters.LoggingFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>LoggingFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- ==================== CONFIGURARE ERROR PAGES ==================== -->
    
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.html</location>
    </error-page>
    
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.html</location>
    </error-page>
    
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/error/exception.html</location>
    </error-page>

    <!-- ==================== CONFIGURARE SESSION ==================== -->
    
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure>
        </cookie-config>
    </session-config>

    <!-- ==================== CONFIGURARE MIME TYPES ==================== -->
    
    <mime-mapping>
        <extension>json</extension>
        <mime-type>application/json</mime-type>
    </mime-mapping>
    
    <mime-mapping>
        <extension>xml</extension>
        <mime-type>application/xml</mime-type>
    </mime-mapping>
    
    <mime-mapping>
        <extension>pdf</extension>
        <mime-type>application/pdf</mime-type>
    </mime-mapping>
    
    <mime-mapping>
        <extension>zip</extension>
        <mime-type>application/zip</mime-type>
    </mime-mapping>

    <!-- ==================== CONFIGURARE WELCOME FILES ==================== -->
    
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>admin-advanced.html</welcome-file>
        <welcome-file>comanda.html</welcome-file>
    </welcome-file-list>

    <!-- ==================== CONFIGURARE CONTEXT PARAMETERS ==================== -->
    
    <context-param>
        <param-name>database.url</param-name>
        <param-value>jdbc:mysql://localhost:3306/restaurant_db</param-value>
    </context-param>
    
    <context-param>
        <param-name>database.username</param-name>
        <param-value>root</param-value>
    </context-param>
    
    <context-param>
        <param-name>database.password</param-name>
        <param-value>password</param-value>
    </context-param>
    
    <context-param>
        <param-name>fiscal.company.name</param-name>
        <param-value>SC RESTAURANT TRATTORIA SRL</param-value>
    </context-param>
    
    <context-param>
        <param-name>fiscal.company.cui</param-name>
        <param-value>RO12345678</param-value>
    </context-param>
    
    <context-param>
        <param-name>fiscal.company.address</param-name>
        <param-value>Strada Principală 123, Sector 1, București</param-value>
    </context-param>
    
    <context-param>
        <param-name>fiscal.archive.path</param-name>
        <param-value>arhiva_rapoarte</param-value>
    </context-param>

    <!-- ==================== CONFIGURARE RESOURCE REFERENCES ==================== -->
    
    <resource-ref>
        <description>Database Connection Pool</description>
        <res-ref-name>jdbc/RestaurantDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

</web-app>
