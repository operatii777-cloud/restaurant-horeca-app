# ============================================
# .dockerignore - Exclude from Docker build
# ============================================

# Node modules (will be installed in container)
node_modules
npm-debug.log

# Logs
logs
*.log

# Development files
.git
.gitignore
.env
.env.*
*.md
README.md

# Test files
__tests__
coverage
*.test.js
*.spec.js
playwright-report

# Backup files
backups/*
*.backup
*.bak

# IDE files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Development tools
.editorconfig
.prettierrc
.eslintrc

# Documentation
docs
documentation

# Screenshots
screenshots
*.png
*.jpg
*.jpeg
!public/images/**

# Temporary files
tmp
temp
*.tmp

# Build artifacts (if any)
dist
build

# CI/CD files (not needed in container)
.github
.gitlab-ci.yml
.travis.yml

# Docker files (already in image)
Dockerfile*
docker-compose*.yml
.dockerignore

