<div class="product-item{{#if should_break_after}} break-after{{/if}}" data-index="{{index_in_category}}"{{#if should_break_after}} data-break-after="true"{{/if}}>
  
  <!-- Product Image - CONDITIONAL based on settings.showImages -->
  {{#if ../../../settings.showImages}}
    {{#if image_url}}
      <div class="product-image">
        <img src="{{image_url}}" alt="{{name}}" />
      </div>
    {{/if}}
  {{/if}}
  
  <!-- Product Header: Name + Price -->
  <div class="product-header">
    <span class="product-name">{{name}}</span>
    {{#if ../../../settings.showPrices}}
      <span class="product-price">{{price}} RON</span>
    {{/if}}
  </div>
  
  <!-- Product Meta: Portion + Allergens + Additives -->
  <div class="product-meta">
    {{#if portion}}
      <span class="product-portion">{{portion}}</span>
    {{/if}}
    
    <span class="product-allergens {{#unless allergens}}no-allergens{{/unless}}">
      ⚠️ {{allergens_formatted}}
    </span>
    
    <span class="product-additives">
      🧪 {{additives_formatted}}
    </span>
  </div>
  
  <!-- Description (if available AND settings.showDescriptions is true) -->
  {{#if ../../../settings.showDescriptions}}
    {{#if description}}
      <p class="product-description">{{description}}</p>
    {{/if}}
  {{/if}}
  
</div>

