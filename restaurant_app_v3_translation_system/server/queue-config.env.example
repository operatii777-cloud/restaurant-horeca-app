# Redis Queue Configuration
# Copiază acest fișier ca .env.queue în folderul server/

REDIS_URL=redis://127.0.0.1:6379
# Pentru Docker, folosește: redis://redis:6379

# SQLite Database Path (relativ la folder server/)
SQLITE_DB=./data/app.sqlite3

# API Base URL (pentru worker logging/callbacks)
API_BASE=http://localhost:3000

