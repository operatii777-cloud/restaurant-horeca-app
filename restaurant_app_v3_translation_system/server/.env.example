# Restaurant HORECA App - Environment Configuration
# Copy this file to .env and customize the values

# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=3001
TZ=Europe/Bucharest

# ========================================
# Database Configuration
# ========================================
# SQLite database path (relative to server directory)
DATABASE_PATH=./restaurant.db

# ========================================
# Security Configuration
# ========================================
# Session secret for secure cookies (CHANGE THIS IN PRODUCTION!)
# Generate a random secret with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-secure-random-secret-in-production

# ========================================
# Optional: Redis Queue Configuration
# ========================================
# Uncomment if using Redis for job queuing
# REDIS_URL=redis://127.0.0.1:6379
# For Docker, use: redis://redis:6379

# ========================================
# Optional: Advanced Configuration
# ========================================
# API base URL (for worker logging/callbacks)
# API_BASE=http://localhost:3001

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File upload size limit (in MB)
# MAX_FILE_SIZE=10

# Enable debug logging
# DEBUG=true

# ========================================
# Optional: External Services
# ========================================
# SMTP Configuration (for email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-password

# Payment Gateway (if using Stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ========================================
# Database Backup Configuration
# ========================================
# Automatic backup interval (in hours)
# BACKUP_INTERVAL=24

# Backup retention (in days)
# BACKUP_RETENTION=7
